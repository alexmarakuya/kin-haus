  <script is:inline>
  (function() {
    var modal = document.getElementById('bookingModal');
    if (!modal) return;
    var checkinEl = document.getElementById('bmCheckin');
    var checkoutEl = document.getElementById('bmCheckout');
    var roomEl = document.getElementById('bmRoom');
    var nightsEl = document.getElementById('bmNights');
    var nameEl = document.getElementById('bmName');
    var whatsappEl = document.getElementById('bmWhatsapp');
    var waCodeEl = document.getElementById('bmWaCode');
    var msgEl = document.getElementById('bmMessage');
    var waBtn = document.getElementById('bmWaBtn');
    var waBtnText = document.getElementById('bmWaBtnText');
    var airbnbBtn = document.getElementById('bmAirbnbBtn');
    var calendarEl = document.getElementById('bmCalendar');
    var loadingEl = document.getElementById('bmLoading');
    var legendEl = document.getElementById('bmLegend');
    var rangeErrorEl = document.getElementById('bmRangeError');
    var pricingEl = document.getElementById('bmPricing');

    var fpInstance = null;
    var bookedSet = new Set();
    var activePromoCode = '';
    var activePromoDiscount = 0;
    var currentRoomHigh = 0;
    var currentRoomLow = 0;

    var roomRates = {
      'nest': { high: 5000, low: 3500 },
      'master': { high: 3200, low: 2240 },
      'nomad': { high: 2400, low: 1680 }
    };

    // Load dynamic rates from API if available
    fetch('/api/pricing').then(function(r) { return r.json(); }).then(function(data) {
      if (data.nest) roomRates.nest = data.nest;
      if (data.master) roomRates.master = data.master;
      if (data.nomad) roomRates.nomad = data.nomad;
    }).catch(function() {});

    var roomNames = {
      'nest': 'The Nest',
      'master': 'The Explorer',
      'nomad': 'Nomad Room'
    };

    var airbnbLinks = {
      'The Nest': 'https://www.airbnb.com/rooms/1511809226602265595',
      'The Explorer': 'https://www.airbnb.com/rooms/1618003971883950106',
      'Nomad Room': 'https://www.airbnb.com/rooms/1618012678467611754'
    };

    var EUR_RATE = 37;
    var USD_RATE = 34;

    function isLowSeason(dateStr) {
      var m = new Date(dateStr).getMonth();
      return m >= 3 && m <= 9;
    }

    function fmtPrice(thb) {
      var cur = localStorage.getItem('kin-currency') || 'thb';
      if (cur === 'eur') return '\u20AC' + Math.round(thb / EUR_RATE).toLocaleString();
      if (cur === 'usd') return '$' + Math.round(thb / USD_RATE).toLocaleString();
      return '\u0E3F' + thb.toLocaleString();
    }

    function toDateStr(d) {
      var y = d.getFullYear();
      var m = ('0' + (d.getMonth() + 1)).slice(-2);
      var day = ('0' + d.getDate()).slice(-2);
      return y + '-' + m + '-' + day;
    }

    function rangeHasBookedDates(start, end) {
      var d = new Date(start);
      var endDate = new Date(end);
      while (d < endDate) {
        if (bookedSet.has(toDateStr(d))) return true;
        d.setDate(d.getDate() + 1);
      }
      return false;
    }

    var datesReady = false;

    function checkReady() {
      var waNum = whatsappEl.value.replace(/\D/g, '');
      var hint = document.getElementById('bmWaHint');
      if (waNum.length > 0 && waNum.length < 7) {
        hint.textContent = 'Enter at least 7 digits';
        hint.style.display = 'block';
      } else {
        hint.textContent = '';
        hint.style.display = 'none';
      }
      if (datesReady && waNum.length >= 7) {
        waBtn.disabled = false;
        waBtnText.textContent = 'Send via WhatsApp';
      } else if (datesReady) {
        waBtn.disabled = true;
        waBtnText.textContent = 'Enter WhatsApp number';
      } else {
        waBtn.disabled = true;
        waBtnText.textContent = 'Select dates to book';
      }
    }

    whatsappEl.addEventListener('input', checkReady);

    function updateSelection(ci, co) {
      checkinEl.value = ci;
      checkoutEl.value = co;
      if (ci && co) {
        var nights = Math.round((new Date(co) - new Date(ci)) / 86400000);
        if (nights > 0) {
          nightsEl.textContent = nights + ' night' + (nights !== 1 ? 's' : '');
          updatePricing(nights);
          datesReady = true;
          checkReady();
          return;
        }
      }
      nightsEl.textContent = '';
      pricingEl.innerHTML = '';
      datesReady = false;
      checkReady();
    }

    function updatePricing(nights) {
      var high = currentRoomHigh;
      var low = currentRoomLow;
      if (!high && !low) {
        var page = document.querySelector('.room-page');
        if (page && page.dataset.thbHigh) {
          high = parseInt(page.dataset.thbHigh);
          low = parseInt(page.dataset.thbLow);
        } else { pricingEl.innerHTML = ''; return; }
      }
      var isLow = isLowSeason(checkinEl.value);
      var rate = isLow ? low : high;
      var subtotal = rate * nights;
      var discount = 0;
      var discountLabel = '';
      var discountPct = '';
      if (nights >= 28) { discount = 0.40; discountLabel = 'Monthly discount'; discountPct = '40%'; }
      else if (nights >= 7) { discount = 0.15; discountLabel = 'Weekly discount'; discountPct = '15%'; }
      var discountAmt = Math.round(subtotal * discount);
      var afterStayDiscount = subtotal - discountAmt;
      var promoAmt = 0;
      if (activePromoDiscount > 0) {
        promoAmt = Math.round(afterStayDiscount * (activePromoDiscount / 100));
      }
      var total = afterStayDiscount - promoAmt;
      var html = '<div class="bm-price-card">';
      html += '<div class="bm-calc-row">';
      html += '<span class="bm-calc-label">' + fmtPrice(rate) + ' &times; ' + nights + ' night' + (nights !== 1 ? 's' : '') + '</span>';
      html += '<span class="bm-calc-value">' + fmtPrice(subtotal) + '</span>';
      html += '</div>';
      if (discount > 0) {
        html += '<div class="bm-calc-row bm-calc-discount">';
        html += '<span class="bm-calc-label"><span class="bm-discount-pill">' + discountPct + '</span> ' + discountLabel + '</span>';
        html += '<span class="bm-calc-value">&minus;' + fmtPrice(discountAmt) + '</span>';
        html += '</div>';
      }
      if (promoAmt > 0) {
        html += '<div class="bm-calc-row bm-calc-discount">';
        html += '<span class="bm-calc-label"><span class="bm-discount-pill">' + activePromoDiscount + '%</span> Promo ' + activePromoCode + '</span>';
        html += '<span class="bm-calc-value">&minus;' + fmtPrice(promoAmt) + '</span>';
        html += '</div>';
      }
      html += '<div class="bm-divider"></div>';
      html += '<div class="bm-total-row"><span class="bm-total-label">Total</span><span class="bm-total">' + fmtPrice(total) + '</span></div>';
      html += '</div>';
      pricingEl.innerHTML = html;
    }

    function getFullWhatsapp() {
      var num = whatsappEl.value.replace(/\D/g, '');
      if (!num) return '';
      if (num.charAt(0) === '0') num = num.substring(1);
      return '+' + waCodeEl.value + num;
    }

    function buildWaMessage() {
      var room = roomEl.textContent;
      var ci = checkinEl.value;
      var co = checkoutEl.value;
      var name = nameEl.value.trim();
      var wa = getFullWhatsapp();
      var msg = msgEl.value.trim();
      var text = 'Hi! I\'d like to book ' + room + ' at Kin Haus.\n\nCheck-in: ' + ci + '\nCheck-out: ' + co;
      if (name) text = 'Hi, I\'m ' + name + '. I\'d like to book ' + room + ' at Kin Haus.\n\nCheck-in: ' + ci + '\nCheck-out: ' + co;
      if (wa) text += '\nWhatsApp: ' + wa;
      if (activePromoCode) text += '\nPromo code: ' + activePromoCode + ' (' + activePromoDiscount + '% off)';
      if (msg) text += '\n\n' + msg;
      return text;
    }

    var confirmEl = document.getElementById('bmConfirm');
    var confirmBody = document.getElementById('bmConfirmBody');
    var confirmBack = document.getElementById('bmConfirmBack');
    var confirmSend = document.getElementById('bmConfirmSend');

    function getBookingTotal() {
      var page = document.querySelector('.room-page');
      var high = page && page.dataset.thbHigh ? parseInt(page.dataset.thbHigh) : 0;
      var low = page && page.dataset.thbLow ? parseInt(page.dataset.thbLow) : 0;
      var ci = checkinEl.value;
      var co = checkoutEl.value;
      var nights = 0;
      var amount = 0;
      if (ci && co) {
        nights = Math.round((new Date(co) - new Date(ci)) / 86400000);
        var rate = isLowSeason(ci) ? low : high;
        var subtotal = rate * nights;
        var discount = nights >= 28 ? 0.40 : nights >= 7 ? 0.15 : 0;
        var afterStay = Math.round(subtotal * (1 - discount));
        var promoAmt = activePromoDiscount > 0 ? Math.round(afterStay * (activePromoDiscount / 100)) : 0;
        amount = afterStay - promoAmt;
      }
      return { nights: nights, amount: amount };
    }

    waBtn.addEventListener('click', function() {
      if (waBtn.disabled) return;
      // Build confirmation summary
      var info = getBookingTotal();
      var html = '';
      html += '<div class="bm-confirm-row"><span class="bm-confirm-label">Room</span><span class="bm-confirm-value">' + roomEl.textContent + '</span></div>';
      html += '<div class="bm-confirm-row"><span class="bm-confirm-label">Check-in</span><span class="bm-confirm-value">' + checkinEl.value + '</span></div>';
      html += '<div class="bm-confirm-row"><span class="bm-confirm-label">Check-out</span><span class="bm-confirm-value">' + checkoutEl.value + '</span></div>';
      html += '<div class="bm-confirm-row"><span class="bm-confirm-label">Nights</span><span class="bm-confirm-value">' + info.nights + '</span></div>';
      if (info.amount > 0) html += '<div class="bm-confirm-row"><span class="bm-confirm-label">Total</span><span class="bm-confirm-total">' + fmtPrice(info.amount) + '</span></div>';
      var guestName = nameEl.value.trim();
      if (guestName) html += '<div class="bm-confirm-row"><span class="bm-confirm-label">Guest</span><span class="bm-confirm-value">' + guestName + '</span></div>';
      confirmBody.innerHTML = html;
      confirmEl.classList.add('visible');
    });

    confirmBack.addEventListener('click', function() {
      confirmEl.classList.remove('visible');
    });

    confirmSend.addEventListener('click', function() {
      confirmEl.classList.remove('visible');
      var text = buildWaMessage();
      var info = getBookingTotal();
      var inquiry = {
        room: roomEl.textContent,
        checkin: checkinEl.value,
        checkout: checkoutEl.value,
        guest: nameEl.value.trim() || 'Guest',
        whatsapp: getFullWhatsapp(),
        message: msgEl.value.trim(),
        amount: info.amount,
        currency: 'thb',
        promoCode: activePromoCode || '',
        promoDiscount: activePromoDiscount || 0
      };
      fetch('/api/inquiries', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(inquiry)
      }).catch(function() {});
      if (window.posthog) posthog.capture('inquiry_submitted', { room: inquiry.room, nights: info.nights, amount: info.amount });
      var encoded = encodeURIComponent(text);
      window.open('https://wa.me/66638034860?text=' + encoded, '_blank');
    });

    function openModal(roomSlug) {
      var roomName = roomNames[roomSlug] || 'Room';
      roomEl.textContent = roomName;
      airbnbBtn.href = airbnbLinks[roomName] || '#';
      if (window.posthog) posthog.capture('booking_modal_opened', { room: roomSlug });

      // Set rates for this room
      var rates = roomRates[roomSlug] || { high: 0, low: 0 };
      currentRoomHigh = rates.high;
      currentRoomLow = rates.low;

      // Reset state
      checkinEl.value = '';
      checkoutEl.value = '';
      nightsEl.textContent = '';
      pricingEl.innerHTML = '';
      nameEl.value = '';
      waCodeEl.value = '66';
      whatsappEl.value = '';
      msgEl.value = '';
      datesReady = false;
      waBtn.disabled = true;
      waBtnText.textContent = 'Select dates to book';
      rangeErrorEl.classList.remove('visible');
      bookedSet.clear();
      activePromoCode = '';
      activePromoDiscount = 0;
      document.getElementById('bmPromoCode').value = '';
      confirmEl.classList.remove('visible');
      // Reset promo toggle
      var pt = document.getElementById('bmPromoToggle');
      var pw = document.getElementById('bmPromoWrap');
      if (pt) pt.style.display = '';
      if (pw) pw.style.display = 'none';
      document.getElementById('bmPromoStatus').innerHTML = '';

      // Destroy previous flatpickr
      if (fpInstance) { fpInstance.destroy(); fpInstance = null; }
      calendarEl.innerHTML = '';

      // Show loading, hide legend
      loadingEl.style.display = 'flex';
      legendEl.style.display = 'none';

      modal.classList.add('open');
      document.body.style.overflow = 'hidden';

      // Fetch availability
      fetch('/api/availability/' + roomSlug)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          loadingEl.style.display = 'none';
          legendEl.style.display = 'flex';

          // Build booked set for validation
          (data.bookedDates || []).forEach(function(d) { bookedSet.add(d); });

          fpInstance = flatpickr(calendarEl, {
            mode: 'range',
            inline: true,
            minDate: data.range ? data.range.min : 'today',
            maxDate: data.range ? data.range.max : new Date().fp_incr(90),
            disable: data.bookedDates || [],
            showMonths: 1,
            animate: false,
            onChange: function(selectedDates) {
              rangeErrorEl.classList.remove('visible');
              if (selectedDates.length === 2) {
                var start = toDateStr(selectedDates[0]);
                var end = toDateStr(selectedDates[1]);
                // Validate: no booked dates in between
                if (rangeHasBookedDates(start, end)) {
                  rangeErrorEl.classList.add('visible');
                  fpInstance.clear();
                  updateSelection('', '');
                  return;
                }
                updateSelection(start, end);
              } else {
                updateSelection('', '');
              }
            }
          });
        })
        .catch(function() {
          loadingEl.innerHTML = '<span style="color:#c0392b">Failed to load availability. Please try again.</span>';
        });
    }

    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
      if (fpInstance) { fpInstance.destroy(); fpInstance = null; }
    }

    // CTA button click handler
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.avail-cta');
      if (btn && btn.dataset.room) {
        e.preventDefault();
        openModal(btn.dataset.room);
      }
    });

    modal.querySelector('.bm-close').addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });

    // Promo toggle
    var promoToggle = document.getElementById('bmPromoToggle');
    var promoWrap = document.getElementById('bmPromoWrap');
    promoToggle.addEventListener('click', function(e) {
      e.preventDefault();
      promoWrap.style.display = promoWrap.style.display === 'none' ? '' : 'none';
      promoToggle.style.display = 'none';
    });

    // Promo code apply
    var promoInput = document.getElementById('bmPromoCode');
    var promoStatus = document.getElementById('bmPromoStatus');
    var promoApplyBtn = document.getElementById('bmPromoApply');

    function applyPromoCode() {
      var code = promoInput.value.trim().toUpperCase();
      if (!code) { promoStatus.innerHTML = ''; activePromoCode = ''; activePromoDiscount = 0; recalcPricing(); return; }
      promoApplyBtn.textContent = '...';
      fetch('/api/discount-codes/validate?code=' + encodeURIComponent(code))
        .then(function(res) { return res.json(); })
        .then(function(data) {
          promoApplyBtn.textContent = 'Apply';
          if (data.valid) {
            activePromoCode = code;
            activePromoDiscount = data.discount;
            promoStatus.innerHTML = '<span class="bm-promo-ok">' + code + ' applied -- ' + data.discount + '% off</span>';
          } else {
            activePromoCode = '';
            activePromoDiscount = 0;
            promoStatus.innerHTML = '<span class="bm-promo-err">Invalid or expired code</span>';
          }
          recalcPricing();
        })
        .catch(function() {
          promoApplyBtn.textContent = 'Apply';
          promoStatus.innerHTML = '<span class="bm-promo-err">Could not validate code</span>';
        });
    }

    function recalcPricing() {
      if (datesReady && checkinEl.value && checkoutEl.value) {
        var nights = Math.round((new Date(checkoutEl.value) - new Date(checkinEl.value)) / 86400000);
        if (nights > 0) updatePricing(nights);
      }
    }

    promoApplyBtn.addEventListener('click', applyPromoCode);
    promoInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); applyPromoCode(); }
    });
  })();
  </script>

  <!-- Currency Dropdown -->
  <script is:inline>
  (function() {
    var EUR_RATE = 37;
    var USD_RATE = 34;
    var dropdown = document.getElementById('currencyToggle');
    if (!dropdown) return;
    var selected = document.getElementById('currencySelected');
    var label = document.getElementById('currencyLabel');
    var options = dropdown.querySelectorAll('.currency-option');
    var saved = localStorage.getItem('kin-currency') || 'thb';
    var LABELS = { thb: '\u0E3F THB', usd: '$ USD', eur: '\u20AC EUR' };

    function fmtTHB(n) { return '\u0E3F' + n.toLocaleString(); }
    function fmtEUR(n) { return '\u20AC' + Math.round(n / EUR_RATE).toLocaleString(); }
    function fmtUSD(n) { return '$' + Math.round(n / USD_RATE).toLocaleString(); }

    function fmtCurrency(thb, currency) {
      if (currency === 'eur') return fmtEUR(thb);
      if (currency === 'usd') return fmtUSD(thb);
      return fmtTHB(thb);
    }

    function convert(currency) {
      document.querySelectorAll('[data-thb]').forEach(function(el) {
        var thb = parseInt(el.dataset.thb);
        var tpl = el.dataset.priceTpl || '{price}';
        var price = fmtCurrency(thb, currency);
        el.textContent = tpl.replace('{price}', price);
      });
      document.querySelectorAll('[data-thb-range]').forEach(function(el) {
        var parts = el.dataset.thbRange.split(',');
        var low = parseInt(parts[0]);
        var high = parseInt(parts[1]);
        var tpl = el.dataset.priceTpl || '{low} - {high} / night';
        var lp = fmtCurrency(low, currency);
        var hp = fmtCurrency(high, currency);
        el.textContent = tpl.replace('{low}', lp).replace('{high}', hp);
      });
      options.forEach(function(b) {
        b.classList.toggle('active', b.dataset.currency === currency);
      });
      label.innerHTML = LABELS[currency] || LABELS.thb;
      localStorage.setItem('kin-currency', currency);
      dropdown.classList.remove('open');
    }

    selected.addEventListener('click', function(e) {
      e.stopPropagation();
      dropdown.classList.toggle('open');
    });

    options.forEach(function(b) {
      b.addEventListener('click', function(e) {
        e.stopPropagation();
        convert(b.dataset.currency);
      });
    });

    document.addEventListener('click', function() {
      dropdown.classList.remove('open');
    });

    if (saved !== 'thb') convert(saved);
  })();
  </script>
</BaseLayout>
