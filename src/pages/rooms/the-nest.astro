---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "HotelRoom",
    "name": "The Nest at Kin Haus",
    "description": "Private top-floor retreat with panoramic views, king-size bed, and ensuite bathroom at Kin Haus co-living villa, Koh Phangan.",
    "url": "https://kinhaus.space/rooms/the-nest",
    "image": "https://kinhaus.space/images/rooms/kinhaus-nest-1.jpg",
    "bed": { "@type": "BedDetails", "typeOfBed": "King", "numberOfBeds": 1 },
    "occupancy": { "@type": "QuantitativeValue", "value": 2 },
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Ensuite Bathroom", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Air Conditioning", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Panoramic Views", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Blackout Blinds", "value": true }
    ],
    "offers": {
      "@type": "Offer",
      "priceCurrency": "THB",
      "price": "3500",
      "description": "Low season rate (Apr-Oct). High season: 5,000 THB/night.",
      "availability": "https://schema.org/InStock"
    },
    "containedInPlace": { "@type": "LodgingBusiness", "name": "Kin Haus", "url": "https://kinhaus.space" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kinhaus.space/" },
      { "@type": "ListItem", "position": 2, "name": "Rooms", "item": "https://kinhaus.space/rooms" },
      { "@type": "ListItem", "position": 3, "name": "The Nest", "item": "https://kinhaus.space/rooms/the-nest" }
    ]
  }
];
---

<MarketingLayout
  title="The Nest -- Private Room with Ensuite | Kin Haus, Koh Phangan"
  description="Book The Nest at Kin Haus: a private top-floor room with panoramic views, king-size bed, and ensuite bathroom. From 3,500 THB/night in Koh Phangan, Thailand."
  jsonLd={jsonLd}
>
  <style>
    .room-page { padding: 60px 40px; max-width: 800px; margin: 0 auto; }
    .room-page h1 { font-size: 36px; font-weight: 600; margin-bottom: 6px; }
    .room-rate { font-family: 'JetBrains Mono', monospace; font-size: 14px; color: var(--accent); margin-bottom: 8px; }
    .room-season { font-size: 11px; color: #8b8b85; margin-bottom: 24px; }
    .room-hero { height: 380px; border-radius: 12px; overflow: hidden; margin-bottom: 32px; background: var(--warm); }
    .room-hero img { width: 100%; height: 100%; object-fit: cover; }
    .room-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 12px; border-radius: 8px; overflow: hidden; }
    .room-gallery img { width: 100%; height: 160px; object-fit: cover; border-radius: 8px; }
    .room-gallery-label { font-size: 11px; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.06em; color: #8b8b85; margin-bottom: 8px; margin-top: 20px; }
    .room-gallery-label:first-of-type { margin-top: 0; }
    .room-galleries { margin-bottom: 32px; }
    .room-desc { font-size: 15px; color: #52524e; line-height: 1.7; margin-bottom: 28px; }
    .room-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0; margin-bottom: 32px; }
    .room-feature { display: flex; align-items: center; gap: 10px; padding: 12px 0; border-bottom: 1px solid #eeecea; font-size: 13px; color: var(--ink); }
    .room-feature-icon { flex-shrink: 0; width: 24px; height: 24px; color: var(--ink); opacity: 0.6; }
    .room-feature-icon svg { width: 100%; height: 100%; }
    .room-back { display: inline-block; margin-top: 24px; margin-bottom: 60px; font-size: 13px; color: #8b8b85; text-decoration: none; }
    .room-back:hover { color: var(--accent); }
    .room-quick-facts {
      margin-bottom: 32px; padding: 24px; background: var(--warm); border-radius: 10px;
    }
    .room-quick-facts h2 { font-size: 16px; font-weight: 600; margin-bottom: 12px; }
    .room-quick-facts ul { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .room-quick-facts li { font-size: 13px; color: #52524e; }
    .room-quick-facts strong { color: var(--ink); }
    .related-rooms { margin-bottom: 60px; }
    .related-rooms h3 { font-size: 16px; font-weight: 600; margin-bottom: 16px; }
    .related-rooms-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .related-room-link {
      display: flex; align-items: center; gap: 14px; padding: 12px;
      border: 1px solid #e4e2de; border-radius: 10px; text-decoration: none; color: inherit;
      transition: border-color 0.15s;
    }
    .related-room-link:hover { border-color: #ccc; }
    .related-room-link img { width: 80px; height: 60px; object-fit: cover; border-radius: 6px; }
    .related-room-link strong { font-size: 14px; display: block; }
    .related-room-link span { font-size: 12px; color: #64645f; }
    @media (max-width: 500px) {
      .room-quick-facts ul { grid-template-columns: 1fr; }
      .related-rooms-grid { grid-template-columns: 1fr; }
    }

    .sticky-cta {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
      border-top: 1px solid #e4e2de;
      padding: 12px 24px;
      display: flex; align-items: center; justify-content: center; gap: 16px;
      transform: translateY(100%); opacity: 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }
    .sticky-cta.visible { transform: translateY(0); opacity: 1; }
    .sticky-cta-name { font-weight: 600; font-size: 15px; }
    .sticky-cta-price { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--accent); }
    .sticky-cta-btn {
      padding: 10px 22px; background: var(--accent); color: white;
      border: none; border-radius: 8px; font-size: 13px; font-weight: 500;
      cursor: pointer; transition: background 0.15s;
    }
    .sticky-cta-btn:hover { background: #245a3b; }
    @media (max-width: 600px) {
      .sticky-cta { padding: 10px 16px; gap: 10px; }
      .sticky-cta-name { font-size: 13px; }
      .sticky-cta-price { font-size: 11px; }
      .sticky-cta-btn { padding: 8px 16px; font-size: 12px; }
    }
  </style>

  <div class="room-page" data-thb-high="5000" data-thb-low="3500" data-room-slug="nest">
    <h1>The Nest</h1>
    <div class="room-rate" data-thb="5000" data-price-tpl="{price} / night (high season)">&#x0E3F;5,000 / night (high season)</div>
    <div class="room-season" data-thb="3500" data-price-tpl="Low season (Apr-Oct): {price} / night">Low season (Apr-Oct): &#x0E3F;3,500 / night</div>
    <div class="room-hero"><img src="/images/rooms/kinhaus-nest-1.jpg" alt="The Nest private room with panoramic mountain views at Kin Haus, Koh Phangan"></div>

    <div class="room-galleries">
      <div class="room-gallery-label">Bedroom</div>
      <div class="room-gallery">
        <img src="/images/rooms/kinhaus-nest-2.jpg" alt="The Nest bedroom with king-size bed at Kin Haus, Koh Phangan" loading="lazy">
        <img src="/images/rooms/kinhaus-nest-3.jpg" alt="The Nest interior with natural light at Kin Haus, Koh Phangan" loading="lazy">
      </div>
      <div class="room-gallery-label">Ensuite Bathroom</div>
      <div class="room-gallery">
        <img src="/images/rooms/kinhaus-nest-bathroom-1.jpg" alt="The Nest ensuite bathroom with rainfall shower at Kin Haus" loading="lazy">
        <img src="/images/rooms/kinhaus-nest-bathroom-2.jpg" alt="The Nest ensuite bathroom vanity at Kin Haus" loading="lazy">
      </div>
    </div>

    <p class="room-desc">A private retreat perched at the top of the house with panoramic views, a king-size bed, and an ensuite bathroom. The most spacious room at Kin Haus, perfect for couples or solo travelers who want extra space and privacy.</p>

    <div class="room-features">
      <span class="room-feature"><span class="room-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/><path d="M12 4v6"/><path d="M2 18h20"/></svg></span>King-size bed</span>
      <span class="room-feature"><span class="room-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/><line x1="10" x2="8" y1="5" y2="7"/><line x1="2" x2="22" y1="12" y2="12"/><line x1="7" x2="7" y1="19" y2="21"/><line x1="17" x2="17" y1="19" y2="21"/></svg></span>Ensuite bathroom</span>
      <span class="room-feature"><span class="room-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="2" x2="22" y1="12" y2="12"/><line x1="12" x2="12" y1="2" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/></svg></span>Air conditioning</span>
      <span class="room-feature"><span class="room-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m8 6 4-4 4 4"/><path d="M16 18a4 4 0 0 0-8 0"/></svg></span>Sunrise, pool &amp; sea views</span>
      <span class="room-feature"><span class="room-feature-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg></span>Blackout blinds</span>
    </div>

    <button class="avail-cta" data-room="nest">Check Availability</button>

    <div class="room-quick-facts">
      <h2>Quick Facts</h2>
      <ul>
        <li><strong>Bed:</strong> King-size</li>
        <li><strong>Bathroom:</strong> Private ensuite</li>
        <li><strong>High season:</strong> 5,000 THB/night (Nov-Mar)</li>
        <li><strong>Low season:</strong> 3,500 THB/night (Apr-Oct)</li>
        <li><strong>Best for:</strong> Couples, privacy seekers</li>
        <li><strong>Check-in:</strong> 3 PM / Check-out: 12 PM</li>
      </ul>
    </div>

    <a href="/rooms" class="room-back">&#x2190; All rooms</a>

    <div class="related-rooms">
      <h3>You might also like</h3>
      <div class="related-rooms-grid">
        <a href="/rooms/master-suite" class="related-room-link">
          <img src="/images/rooms/kinhaus-master-teak-headboard.jpg" alt="Master Suite at Kin Haus" loading="lazy">
          <span><strong>Master Suite</strong> -- from 2,240 THB/night</span>
        </a>
        <a href="/rooms/nomad-room" class="related-room-link">
          <img src="/images/rooms/kinhaus-nomad-bedroom-wide-angle.jpg" alt="Nomad Room at Kin Haus" loading="lazy">
          <span><strong>Nomad Room</strong> -- from 1,680 THB/night</span>
        </a>
      </div>
    </div>
  </div>

  <div class="sticky-cta" id="stickyCta">
    <span class="sticky-cta-name">The Nest</span>
    <span class="sticky-cta-price" data-thb="5000" data-price-tpl="from {price}/night">from &#x0E3F;5,000/night</span>
    <button class="sticky-cta-btn" data-room="nest">Check Availability</button>
  </div>

  <script>
    (function() {
      var hero = document.querySelector('.room-hero');
      var bar = document.getElementById('stickyCta');
      var mainCta = document.querySelector('.avail-cta');
      if (!hero || !bar) return;
      function onScroll() {
        var heroBottom = hero.getBoundingClientRect().bottom;
        var mainCtaTop = mainCta ? mainCta.getBoundingClientRect().top : Infinity;
        var show = heroBottom < 0 && mainCtaTop > window.innerHeight;
        bar.classList.toggle('visible', show);
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    })();
  </script>
</MarketingLayout>
