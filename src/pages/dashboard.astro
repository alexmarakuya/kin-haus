  function resetHkForm() {
    editingHkId = null;
    document.getElementById('hk-form-title').textContent = 'Add Staff Member';
    document.getElementById('hk-name').value = '';
    document.getElementById('hk-role').value = 'housekeeper';
    document.getElementById('hk-phone').value = '';
    document.getElementById('hk-line').value = '';
    document.getElementById('hk-messenger').value = '';
    document.getElementById('hk-email').value = '';
    document.getElementById('hk-rate').value = '';
    document.querySelectorAll('#hk-rooms input').forEach(cb => cb.checked = false);
    document.querySelectorAll('#hk-days input').forEach(cb => {
      const v = parseInt(cb.value);
      cb.checked = v >= 1 && v <= 5;
    });
    document.getElementById('hk-save').textContent = 'Add';
    document.getElementById('hk-cancel-edit').style.display = 'none';
