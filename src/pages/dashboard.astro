  // ─── STAFF TAB ───────────────────────────────────────────────────────────────
  const STAFF_ROLE_LABELS = { housekeeper:'Housekeeper', maintenance:'Maintenance', pool:'Pool Service', pest_control:'Pest Control', gardener:'Gardener', other:'Other' };
  const STAFF_ROLE_COLORS = { housekeeper:'#d4ede3', maintenance:'#fef3cd', pool:'#dbeafe', pest_control:'#fde8e8', gardener:'#dcfce7', other:'#f0eeeb' };
  const STAFF_ROLE_TEXT = { housekeeper:'#1a6b3c', maintenance:'#856404', pool:'#1a56db', pest_control:'#b42a1e', gardener:'#166534', other:'#52524e' };

