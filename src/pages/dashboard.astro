    document.getElementById('room-modal').classList.remove('open');
  });
  // Click overlay background to close for all modals
  ['modal','code-modal','room-modal','rent-modal','pass-modal'].forEach(id => {
    document.getElementById(id).addEventListener('click', e => {
      if (e.target.id === id) document.getElementById(id).classList.remove('open');
    });
  });

  document.getElementById('rm-save').addEventListener('click', async () => {
    if (!currentRoomSlug) return;
    const payload = {};
    payload[currentRoomSlug] = {
      high: parseInt(document.getElementById('rm-high').value) || 0,
      low: parseInt(document.getElementById('rm-low').value) || 0,
    };
    try {
      const res = await fetch('/api/pricing', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      applyPricing(data);
      render();
      const status = document.getElementById('rm-status');
      status.style.display = 'inline';
      setTimeout(() => status.style.display = 'none', 2000);
    } catch (err) {
      console.error('Failed to save pricing:', err);
      alert('Failed to save pricing');
    }
  });

  // ─── GUESTS CRM ─────────────────────────────────────────────────────────────
  let allGuests = [];
  let guestSearchQuery = '';
  let guestFilterTag = 'all';
  let editingGuestId = null;
  let gpTags = [];

  async function loadGuests() {
    try {
      const res = await fetch('/api/guests');
      const data = await res.json();
      allGuests = data.guests || [];
      renderGuests();
    } catch (err) {
      console.error('[guests] load error:', err);
    }
  }

  function getGuestBookings(g) {
    return (g.bookingIds || []).map(bid => allBookings.find(b => b.id === bid)).filter(Boolean);
  }

  function guestStatus(g) {
    const today = new Date().toISOString().slice(0, 10);
    const linked = getGuestBookings(g);
    const current = linked.find(b => b.checkin <= today && b.checkout > today);
    if (current) return 'in-house';
    const upcoming = linked.find(b => b.checkin > today);
    if (upcoming) return 'upcoming';
    if ((g.tags || []).includes('returning') || g.totalStays >= 2) return 'returning';
    if ((g.tags || []).includes('vip')) return 'vip';
    return 'none';
  }

  function renderGuests() {
    const container = document.getElementById('guests-content');
    const countEl = document.getElementById('guest-count');
    const today = new Date().toISOString().slice(0, 10);
    let guests = allGuests;

    // Filter by tag/status
    if (guestFilterTag !== 'all') {
      guests = guests.filter(g => {
        const s = guestStatus(g);
        if (guestFilterTag === 'in-house') return s === 'in-house';
        if (guestFilterTag === 'upcoming') return s === 'upcoming';
        if (guestFilterTag === 'returning') return (g.tags || []).includes('returning') || g.totalStays >= 2;
        if (guestFilterTag === 'vip') return (g.tags || []).includes('vip');
        if (guestFilterTag === 'coworking') return (g.tags || []).includes('coworking');
        return true;
      });
    }

    // Search
    if (guestSearchQuery) {
      const q = guestSearchQuery.toLowerCase();
      guests = guests.filter(g =>
        g.fullName.toLowerCase().includes(q) ||
        (g.nationality || '').toLowerCase().includes(q) ||
        (g.passportNumber || '').toLowerCase().includes(q) ||
        (g.email || '').toLowerCase().includes(q) ||
        (g.phone || '').toLowerCase().includes(q)
      );
    }

    countEl.textContent = guests.length ? `(${guests.length})` : '';

    if (!guests.length) {
      container.innerHTML = guestSearchQuery
        ? '<div style="color:#8b8b85; font-size:13px; padding:20px 0;">No guests matching your search</div>'
        : '<div style="color:#8b8b85; font-size:13px; padding:20px 0;">No guest profiles yet. Scan a passport in the chat or add one manually.</div>';
      return;
    }

    container.innerHTML = `<div class="guest-grid">${guests.map(g => {
      const linked = getGuestBookings(g);
      const currentStay = linked.find(b => b.checkin <= today && b.checkout > today);
      const upcomingStay = linked.find(b => b.checkin > today);
      const pastStays = linked.filter(b => b.checkout <= today).length;
      const status = guestStatus(g);

      const statusMap = {
        'in-house': '<span class="guest-status guest-status-current">In-house</span>',
        'upcoming': '<span class="guest-status guest-status-upcoming">Upcoming</span>',
        'returning': '<span class="guest-status guest-status-returning">Returning</span>',
        'vip': '<span class="guest-status guest-status-vip">VIP</span>',
      };
      const isCoworking = (g.tags || []).includes('coworking');
      const coworkingBadge = isCoworking ? '<span class="guest-status guest-status-coworking">Co-working</span>' : '';
      const statusTag = (statusMap[status] || (pastStays > 0 ? `<span class="guest-status guest-status-past">${pastStays} stay${pastStays > 1 ? 's' : ''}</span>` : '')) + coworkingBadge;

      const genderIcon = g.gender === 'M' ? '&#9794;' : g.gender === 'F' ? '&#9792;' : '';
      const tags = (g.tags || []).map(t => `<span class="guest-tag">${t}</span>`).join('');

      let stayInfo = '';
      if (currentStay) stayInfo = `<div class="guest-card-stay">In ${ROOM_LABELS[currentStay.room] || currentStay.room} until ${fmtDateShort(currentStay.checkout)}</div>`;
      else if (upcomingStay) stayInfo = `<div class="guest-card-stay">Next: ${ROOM_LABELS[upcomingStay.room] || upcomingStay.room} from ${fmtDateShort(upcomingStay.checkin)}</div>`;

      const revenueDisplay = g.totalRevenue > 0 ? `<span class="guest-card-revenue">&#x0E3F;${g.totalRevenue.toLocaleString()}</span>` : '';
      const stayCount = g.totalStays > 0 ? `${g.totalStays} stay${g.totalStays > 1 ? 's' : ''}` : '';
      const meta = [stayCount, revenueDisplay].filter(Boolean).join(' &middot; ');

      return `<div class="guest-card" data-id="${g.id}" onclick="openGuestPanel('${g.id}')">
        <div class="guest-card-header">
          <div class="guest-card-avatar">${esc(g.fullName.charAt(0).toUpperCase())}</div>
          <div class="guest-card-info">
            <div class="guest-card-name">${esc(g.fullName)} ${genderIcon ? '<span class="guest-gender">' + genderIcon + '</span>' : ''}</div>
            <div class="guest-card-detail">${esc(g.nationality || 'Unknown')}${g.source ? ' &middot; via ' + esc(g.source) : ''}</div>
          </div>
          ${statusTag}
        </div>
        ${stayInfo}
        ${meta ? `<div class="guest-card-meta">${meta}</div>` : ''}
        ${tags ? `<div class="guest-card-tags">${tags}</div>` : ''}
      </div>`;
    }).join('')}</div>`;
  }

  // Search
  document.getElementById('guest-search')?.addEventListener('input', (e) => {
    guestSearchQuery = e.target.value;
    renderGuests();
  });

  // Filter chips
  document.getElementById('guest-filter-chips')?.addEventListener('click', (e) => {
    const chip = e.target.closest('[data-gf]');
    if (!chip) return;
    guestFilterTag = chip.dataset.gf;
    document.querySelectorAll('#guest-filter-chips .filter-chip').forEach(c => c.classList.remove('active'));
    chip.classList.add('active');
    renderGuests();
  });

  // Import guests from existing bookings
  document.getElementById('btn-import-guests')?.addEventListener('click', async () => {
    const btn = document.getElementById('btn-import-guests');
    if (btn.disabled) return;
    btn.disabled = true;
    btn.textContent = 'Importing...';
    try {
      const res = await fetch('/api/guests/import', { method: 'POST' });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Import failed');
      btn.textContent = `${data.imported} new, ${data.updated} updated`;
      await loadGuests();
      setTimeout(() => { btn.textContent = 'Import from bookings'; btn.disabled = false; }, 3000);
    } catch (err) {
      console.error('[guests] import error:', err);
      btn.textContent = 'Import failed';
      setTimeout(() => { btn.textContent = 'Import from bookings'; btn.disabled = false; }, 3000);
    }
  });

  // Add guest - opens empty panel
  document.getElementById('btn-add-guest')?.addEventListener('click', () => {
    openGuestPanel(null);
  });

  // ─── GUEST DETAIL PANEL ─────────────────────────────────────────────────────
  let gpEditMode = false;

  function relativeDate(dateStr) {
    if (!dateStr) return '';
    const now = new Date();
    const date = new Date(dateStr.length <= 10 ? dateStr + 'T00:00:00' : dateStr);
    const diffMs = date - now;
    const diffDays = Math.round(diffMs / 86400000);
    if (diffDays === 0) return 'today';
    if (diffDays === 1) return 'tomorrow';
    if (diffDays === -1) return 'yesterday';
    if (diffDays > 1 && diffDays <= 30) return `in ${diffDays} days`;
    if (diffDays < -1 && diffDays >= -30) return `${Math.abs(diffDays)} days ago`;
    const absDays = Math.abs(diffDays);
    if (absDays <= 60) { const w = Math.round(absDays / 7); return diffDays > 0 ? `in ${w} week${w > 1 ? 's' : ''}` : `${w} week${w > 1 ? 's' : ''} ago`; }
    const diffMonths = Math.round(absDays / 30);
    if (diffMonths <= 12) return diffDays > 0 ? `in ${diffMonths} month${diffMonths > 1 ? 's' : ''}` : `${diffMonths} month${diffMonths > 1 ? 's' : ''} ago`;
    const diffYears = Math.round(absDays / 365);
    return diffDays > 0 ? `in ${diffYears} year${diffYears > 1 ? 's' : ''}` : `${diffYears} year${diffYears > 1 ? 's' : ''} ago`;
  }

  function instagramUrl(val) {
    if (!val) return '';
    if (val.startsWith('http')) return val;
    const handle = val.replace(/^@/, '');
    return `https://www.instagram.com/${handle}`;
  }

  function instagramHandle(val) {
    if (!val) return '';
    if (val.includes('instagram.com/')) {
      const parts = val.split('instagram.com/');
      return '@' + parts[1].split(/[?/]/)[0];
    }
    return val.startsWith('@') ? val : '@' + val;
  }

  const GENDER_LABELS = { 'M': 'Male', 'F': 'Female' };
  const SOURCE_LABELS = { 'airbnb': 'Airbnb', 'direct': 'Direct', 'referral': 'Referral', 'repeat': 'Returning', 'whatsapp': 'WhatsApp' };

  function renderGpViewMode(g) {
    const el = document.getElementById('gp-view-content');
    if (!g) { el.innerHTML = ''; return; }

    let html = '';

    // Identity
    const identityFields = [];
    if (g.nationality) identityFields.push(['Nationality', g.nationality]);
    if (g.gender) identityFields.push(['Gender', GENDER_LABELS[g.gender] || g.gender]);
    if (g.passportNumber) identityFields.push(['Passport', g.passportNumber]);
    if (g.dateOfBirth) identityFields.push(['Date of Birth', fmtDateShort(g.dateOfBirth)]);
    if (identityFields.length) {
      html += `<div class="gp-view-section"><div class="gp-view-label">Identity</div><div class="gp-view-row-2">`;
      identityFields.forEach(([label, value]) => {
        html += `<div><div class="gp-view-label" style="font-size:9px;">${label}</div><div class="gp-view-value">${value}</div></div>`;
      });
      html += `</div></div>`;
    }

    // Contact
    html += `<div class="gp-view-section"><div class="gp-view-label">Contact</div><div class="gp-view-row-2">`;
    html += g.email
      ? `<div><div class="gp-view-label" style="font-size:9px;">Email</div><div class="gp-view-value"><a href="mailto:${g.email}">${g.email}</a></div></div>`
      : `<div><div class="gp-view-empty" data-gp-add="email">+ Add email</div></div>`;
    html += g.phone
      ? `<div><div class="gp-view-label" style="font-size:9px;">Phone</div><div class="gp-view-value">${g.phone}</div></div>`
      : `<div><div class="gp-view-empty" data-gp-add="phone">+ Add phone</div></div>`;
    html += `</div><div class="gp-view-row-2">`;
    html += g.whatsapp
      ? `<div><div class="gp-view-label" style="font-size:9px;">WhatsApp</div><div class="gp-view-value"><a href="https://wa.me/${g.whatsapp.replace(/[^0-9]/g,'')}" target="_blank">${g.whatsapp}</a></div></div>`
      : `<div><div class="gp-view-empty" data-gp-add="whatsapp">+ Add WhatsApp</div></div>`;
    html += `<div></div></div></div>`;

    // Social
    const socialLinks = [];
    if (g.instagram) socialLinks.push(`<a class="gp-social-link" href="${instagramUrl(g.instagram)}" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>${instagramHandle(g.instagram)}</a>`);
    if (g.linkedin) socialLinks.push(`<a class="gp-social-link" href="${g.linkedin}" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>LinkedIn</a>`);
    if (g.website) socialLinks.push(`<a class="gp-social-link" href="${g.website}" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>Website</a>`);
    if (socialLinks.length) {
      html += `<div class="gp-view-section"><div class="gp-view-label">Social</div><div>${socialLinks.join('')}</div></div>`;
    }

    // Preferences
    const prefParts = [];
    if (g.preferredRoom) prefParts.push(['Preferred Room', ROOM_LABELS[g.preferredRoom] || g.preferredRoom]);
    if (g.source) prefParts.push(['Source', SOURCE_LABELS[g.source] || g.source]);
    if (g.preferences) prefParts.push(['Preferences', g.preferences]);
    if (prefParts.length) {
      html += `<div class="gp-view-section"><div class="gp-view-label">Preferences</div>`;
      prefParts.forEach(([label, value]) => {
        html += `<div class="gp-view-label" style="font-size:9px;">${label}</div><div class="gp-view-value">${value}</div>`;
      });
      html += `</div>`;
    }

    // Tags
    if (g.tags && g.tags.length) {
      html += `<div class="gp-view-section"><div class="gp-view-label">Tags</div><div class="gp-view-tags">${g.tags.map(t => `<span class="gp-tag">${t}</span>`).join('')}</div></div>`;
    }

    // Notes
    if (g.notes) {
      html += `<div class="gp-view-section"><div class="gp-view-label">Notes</div><div class="gp-view-value" style="white-space:pre-wrap;">${esc(g.notes)}</div></div>`;
    }

    el.innerHTML = html;
  }

  function renderGpStaysTab(g) {
    const summaryEl = document.getElementById('gp-stays-summary');
    const listEl = document.getElementById('gp-stays-list');
    if (!g) { summaryEl.innerHTML = ''; listEl.innerHTML = '<div class="gp-stays-empty">No stays recorded yet</div>'; return; }

    const linked = getGuestBookings(g).sort((a, b) => b.checkin.localeCompare(a.checkin));

    // Summary
    const stats = [];
    if (g.totalStays > 0) stats.push(`<span>${g.totalStays} stay${g.totalStays > 1 ? 's' : ''}</span>`);
    if (g.totalRevenue > 0) stats.push(`<span>&#x0E3F;${g.totalRevenue.toLocaleString()}</span>`);
    if (g.firstStay) stats.push(`<span>First: ${fmtDateShort(g.firstStay)}</span>`);
    if (g.lastStay && g.lastStay !== g.firstStay) stats.push(`<span>Last: ${fmtDateShort(g.lastStay)}</span>`);
    summaryEl.innerHTML = stats.length ? `<div class="gp-stays-summary">${stats.join('')}</div>` : '';

    // Cards
    if (!linked.length) {
      listEl.innerHTML = '<div class="gp-stays-empty">No stays recorded yet</div>';
      return;
    }

    listEl.innerHTML = linked.map(b => {
      const nights = Math.round((new Date(b.checkout) - new Date(b.checkin)) / 86400000);
      const rel = relativeDate(b.checkin);
      return `<div class="gp-stay-card" style="border-left-color:var(--${b.type})">
        <div class="gp-stay-header">
          <span class="gp-stay-room">${ROOM_LABELS[b.room] || b.room}</span>
          <span class="gp-stay-type" style="color:var(--${b.type})">${b.type}</span>
        </div>
        <div class="gp-stay-dates">${fmtDateShort(b.checkin)} &ndash; ${fmtDateShort(b.checkout)}${rel ? ` <span class="gp-stay-relative">&middot; ${rel}</span>` : ''}</div>
        <div class="gp-stay-meta">${nights} night${nights !== 1 ? 's' : ''}${b.amount > 0 ? ` &middot; &#x0E3F;${b.amount.toLocaleString()}` : ''}</div>
      </div>`;
    }).join('');
  }

  function setGpEditMode(editing) {
    gpEditMode = editing;
    const panel = document.getElementById('guest-panel');
    const editBtn = document.getElementById('gp-edit-btn');
    if (editing) {
      panel.classList.add('gp-edit-mode');
      document.getElementById('gp-view-content').style.display = 'none';
      document.getElementById('gp-edit-content').style.display = '';
      editBtn.textContent = 'Cancel';
    } else {
      panel.classList.remove('gp-edit-mode');
      document.getElementById('gp-view-content').style.display = '';
      document.getElementById('gp-edit-content').style.display = 'none';
      editBtn.textContent = 'Edit';
    }
  }

  function populateGpEditForm(g) {
    document.getElementById('gp-name').value = g?.fullName || '';
    document.getElementById('gp-nationality').value = g?.nationality || '';
    document.getElementById('gp-gender').value = g?.gender || '';
    document.getElementById('gp-passport').value = g?.passportNumber || '';
    document.getElementById('gp-dob').value = g?.dateOfBirth || '';
    document.getElementById('gp-email').value = g?.email || '';
    document.getElementById('gp-phone').value = g?.phone || '';
    document.getElementById('gp-whatsapp').value = g?.whatsapp || '';
    document.getElementById('gp-instagram').value = g?.instagram || '';
    document.getElementById('gp-linkedin').value = g?.linkedin || '';
    document.getElementById('gp-website').value = g?.website || '';
    document.getElementById('gp-room').value = g?.preferredRoom || '';
    document.getElementById('gp-preferences').value = g?.preferences || '';
    document.getElementById('gp-source').value = g?.source || '';
    document.getElementById('gp-notes').value = g?.notes || '';
  }

  function openGuestPanel(id) {
    editingGuestId = id;
    const panel = document.getElementById('guest-panel');
    const g = id ? allGuests.find(g => g.id === id) : null;

    // ── Profile header ──
    document.getElementById('gp-avatar').textContent = g ? g.fullName.charAt(0).toUpperCase() : '?';
    document.getElementById('gp-header-name').textContent = g ? g.fullName : 'New Guest';

    // Status badge
    const statusEl = document.getElementById('gp-header-status');
    if (g) {
      const status = guestStatus(g);
      const statusMap = {
        'in-house': '<span class="guest-status guest-status-current">In-house</span>',
        'upcoming': '<span class="guest-status guest-status-upcoming">Upcoming</span>',
        'returning': '<span class="guest-status guest-status-returning">Returning</span>',
        'vip': '<span class="guest-status guest-status-vip">VIP</span>',
      };
      statusEl.innerHTML = statusMap[status] || '';
    } else {
      statusEl.innerHTML = '';
    }

    // Meta line
    const metaParts = [];
    if (g?.nationality) metaParts.push(g.nationality);
    if (g?.source) metaParts.push('via ' + (SOURCE_LABELS[g.source] || g.source));
    document.getElementById('gp-header-meta').textContent = metaParts.join(' \u00b7 ');

    // Stats
    const statsEl = document.getElementById('gp-header-stats');
    if (g) {
      const parts = [];
      if (g.totalStays > 0) parts.push(`<span class="gp-header-stat">${g.totalStays} stay${g.totalStays > 1 ? 's' : ''}</span>`);
      if (g.totalRevenue > 0) parts.push(`<span class="gp-header-stat">&#x0E3F;${g.totalRevenue.toLocaleString()}</span>`);
      if (g.createdAt) parts.push(`<span class="gp-header-stat">Member ${relativeDate(g.createdAt) || 'since ' + fmtDateShort(g.createdAt)}</span>`);
      statsEl.innerHTML = parts.join('');
      statsEl.style.display = parts.length ? '' : 'none';
    } else {
      statsEl.style.display = 'none';
    }

    // Quick actions
    const actionsEl = document.getElementById('gp-quick-actions');
    if (g) {
      let btns = '';
      if (g.whatsapp) btns += `<a class="gp-quick-btn" href="https://wa.me/${g.whatsapp.replace(/[^0-9]/g,'')}" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>WhatsApp</a>`;
      if (g.email) btns += `<a class="gp-quick-btn" href="mailto:${g.email}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 6L2 7"/></svg>Email</a>`;
      if (g.instagram) btns += `<a class="gp-quick-btn" href="${instagramUrl(g.instagram)}" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/></svg>Instagram</a>`;
      if (g.linkedin) btns += `<a class="gp-quick-btn" href="${g.linkedin}" target="_blank"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>LinkedIn</a>`;
      btns += `<button class="gp-quick-btn" id="gp-tm30-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>TM30</button>`;
      actionsEl.innerHTML = btns;
      actionsEl.style.display = '';
    } else {
      actionsEl.innerHTML = '';
      actionsEl.style.display = 'none';
    }

    // ── Tabs reset ──
    document.querySelectorAll('.gp-tab').forEach(t => t.classList.remove('active'));
    document.querySelector('.gp-tab[data-gp-tab="profile"]').classList.add('active');
    document.querySelectorAll('.gp-tab-content').forEach(c => c.classList.remove('active'));
    document.getElementById('gp-tab-profile').classList.add('active');

    const staysBtn = document.getElementById('gp-tab-stays-btn');
    const editBtn = document.getElementById('gp-edit-btn');

    if (g) {
      // Existing guest: render view + populate edit form in background + render stays
      renderGpViewMode(g);
      populateGpEditForm(g);
      gpTags = g.tags ? [...g.tags] : [];
      renderGpTags();
      renderGpStaysTab(g);
      setGpEditMode(false);
      staysBtn.classList.remove('disabled');
      editBtn.style.display = '';
      document.getElementById('gp-delete').style.display = '';
    } else {
      // New guest: straight to edit mode, no stays
      renderGpViewMode(null);
      populateGpEditForm(null);
      gpTags = [];
      renderGpTags();
      renderGpStaysTab(null);
      setGpEditMode(true);
      staysBtn.classList.add('disabled');
      editBtn.style.display = 'none';
      document.getElementById('gp-delete').style.display = 'none';
    }

    panel.classList.add('open');
    if (!g) document.getElementById('gp-name').focus();
  }

  function closeGuestPanel() {
    const panel = document.getElementById('guest-panel');
    panel.classList.remove('open', 'gp-edit-mode');
    editingGuestId = null;
    gpEditMode = false;
    // Reset to profile tab
    document.querySelectorAll('.gp-tab').forEach(t => t.classList.remove('active'));
    document.querySelector('.gp-tab[data-gp-tab="profile"]')?.classList.add('active');
    document.querySelectorAll('.gp-tab-content').forEach(c => c.classList.remove('active'));
    document.getElementById('gp-tab-profile')?.classList.add('active');
  }

  function renderGpTags() {
    const container = document.getElementById('gp-tags');
    if (!container) return;
    if (gpEditMode) {
      container.innerHTML = gpTags.map(t =>
        `<span class="gp-tag">${t} <button onclick="removeGpTag('${t}')">&times;</button></span>`
      ).join('') || '<span style="color:#b5b3ad; font-size:12px;">No tags</span>';
    } else {
      container.innerHTML = gpTags.map(t =>
        `<span class="gp-tag">${t}</span>`
      ).join('') || '<span style="color:#b5b3ad; font-size:12px;">No tags</span>';
    }
  }

  window.removeGpTag = function(tag) {
    gpTags = gpTags.filter(t => t !== tag);
    renderGpTags();
  };

  window.openGuestPanel = openGuestPanel;

  // Tab switching
  document.querySelectorAll('.gp-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      if (tab.classList.contains('disabled')) return;
      document.querySelectorAll('.gp-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.gp-tab-content').forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      const target = tab.dataset.gpTab;
      document.getElementById('gp-tab-' + target).classList.add('active');
      // Show edit button only on profile tab
      document.getElementById('gp-edit-btn').style.display = target === 'profile' ? '' : 'none';
    });
  });

  // Edit toggle
  document.getElementById('gp-edit-btn')?.addEventListener('click', () => {
    if (gpEditMode) {
      // Cancel edit — re-render view mode
      const g = editingGuestId ? allGuests.find(g => g.id === editingGuestId) : null;
      if (g) {
        gpTags = [...g.tags || []];
        renderGpViewMode(g);
        setGpEditMode(false);
      }
    } else {
      setGpEditMode(true);
    }
  });

  // Empty-state "Add" link clicks
  document.getElementById('gp-view-content')?.addEventListener('click', (e) => {
    if (e.target.classList.contains('gp-view-empty') || e.target.closest('.gp-view-empty')) {
      setGpEditMode(true);
    }
  });

  document.getElementById('gp-close')?.addEventListener('click', closeGuestPanel);

  document.getElementById('gp-cancel')?.addEventListener('click', () => {
    if (editingGuestId) {
      // Return to view mode for existing guest
      const g = allGuests.find(g => g.id === editingGuestId);
      if (g) {
        gpTags = [...g.tags || []];
        populateGpEditForm(g);
        renderGpViewMode(g);
        setGpEditMode(false);
        return;
      }
    }
    closeGuestPanel();
  });

  document.getElementById('gp-tag-add-btn')?.addEventListener('click', () => {
    const input = document.getElementById('gp-tag-input');
    const tag = input.value.trim().toLowerCase();
    if (tag && !gpTags.includes(tag)) {
      gpTags.push(tag);
      renderGpTags();
    }
    input.value = '';
  });

  document.getElementById('gp-tag-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      document.getElementById('gp-tag-add-btn').click();
    }
  });

  // Save guest
  document.getElementById('gp-save')?.addEventListener('click', async () => {
    const payload = {
      fullName: document.getElementById('gp-name').value.trim(),
      nationality: document.getElementById('gp-nationality').value.trim(),
      gender: document.getElementById('gp-gender').value,
      passportNumber: document.getElementById('gp-passport').value.trim(),
      dateOfBirth: document.getElementById('gp-dob').value,
      email: document.getElementById('gp-email').value.trim(),
      phone: document.getElementById('gp-phone').value.trim(),
      whatsapp: document.getElementById('gp-whatsapp').value.trim(),
      instagram: document.getElementById('gp-instagram').value.trim(),
      linkedin: document.getElementById('gp-linkedin').value.trim(),
      website: document.getElementById('gp-website').value.trim(),
      preferredRoom: document.getElementById('gp-room').value,
      preferences: document.getElementById('gp-preferences').value.trim(),
      source: document.getElementById('gp-source').value,
      notes: document.getElementById('gp-notes').value.trim(),
      tags: gpTags,
    };

    if (!payload.fullName) { alert('Name is required'); return; }

    try {
      let savedGuest;
      if (editingGuestId) {
        const res = await fetch(`/api/guests/${editingGuestId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        savedGuest = data.guest;
      } else {
        const res = await fetch('/api/guests', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        savedGuest = data.guest;
      }
      await loadGuests();
      if (editingGuestId && savedGuest) {
        // Re-open in view mode with fresh data
        openGuestPanel(editingGuestId);
      } else {
        closeGuestPanel();
      }
    } catch (err) {
      console.error('[guests] save error:', err);
      alert('Failed to save guest');
    }
  });

  // Delete guest
  document.getElementById('gp-delete')?.addEventListener('click', async () => {
    if (!editingGuestId || !confirm('Delete this guest profile? This cannot be undone.')) return;
    try {
      await fetch(`/api/guests/${editingGuestId}`, { method: 'DELETE' });
      closeGuestPanel();
      loadGuests();
    } catch (err) {
      console.error('[guests] delete error:', err);
      alert('Failed to delete guest');
    }
  });

  // ─── MONITORS ──────────────────────────────────────────────────────────────────
  let allMonitors = [];
  let allRentals = [];
  let monitorRevenue = {};

  function formatDateDMY(dateStr) {
    if (!dateStr) return '';
    const [y, m, d] = dateStr.split('-');
    return `${d}/${m}/${y}`;
  }

  function fmtDateShort(dateStr) {
    if (!dateStr) return '';
    const d = new Date(dateStr + 'T00:00:00');
    return d.toLocaleDateString('en-GB', { day:'numeric', month:'short' });
  }

  async function loadMonitors() {
    try {
      const [monRes, revRes, histRes] = await Promise.all([
        fetch('/api/monitors'),
        fetch('/api/monitors/revenue'),
        fetch('/api/monitors/history'),
      ]);
      const monData = await monRes.json();
      const revData = await revRes.json();
      const histData = await histRes.json();
      allMonitors = monData.monitors || [];
      allRentals = monData.rentals || [];
      monitorRevenue = revData;
      renderMonitorSummary(revData);
      renderPipeline(allMonitors, allRentals, histData.rentals || []);
    } catch (err) {
      console.error('[monitors] load error:', err);
    }
  }

  function renderMonitorSummary(rev) {
    document.getElementById('ms-revenue').innerHTML = `&#x0E3F;${(rev.totalRevenueThisMonth || 0).toLocaleString()}`;
    document.getElementById('ms-active').textContent = rev.activeRentals || 0;
    document.getElementById('ms-available').textContent = `${rev.availableMonitors || 0} / ${rev.totalMonitors || 0}`;
    document.getElementById('ms-utilisation').textContent = `${rev.utilisationPercent || 0}%`;
  }

  function monitorName(monitorId) {
    return allMonitors.find(m => m.id === monitorId)?.name || monitorId;
  }

  function renderPipeline(monitors, rentals, history) {
    const booked = rentals.filter(r => r.status === 'booked');
    const delivered = rentals.filter(r => r.status === 'delivered');
    const available = monitors.filter(m => m.status === 'available');
    const maintenance = monitors.filter(m => m.status === 'maintenance');

    // Counts
    document.getElementById('count-booked').textContent = booked.length;
    document.getElementById('count-delivered').textContent = delivered.length;

    // Available monitors
    const availContainer = document.getElementById('cards-available');
    const allAvail = [...available, ...maintenance];
    if (!allAvail.length) {
      availContainer.innerHTML = '<div class="pipeline-empty">All rented out</div>';
    } else {
      availContainer.innerHTML = allAvail.map(m => {
        const isMain = m.status === 'maintenance';
        return `<div class="monitor-avail-card">
          <div class="monitor-avail-name">${m.name}</div>
          <div class="monitor-avail-rate">&#x0E3F;${m.dailyRate}/day${isMain ? ' · Maintenance' : ''}</div>
          <div class="monitor-avail-actions">
            ${m.status === 'available' ? `<button class="btn btn-primary btn-sm" onclick="openRentModal('${m.id}')">Rent</button>` : ''}
            <button class="btn btn-sm" onclick="toggleMaintenance('${m.id}')">${isMain ? 'Activate' : 'Maint.'}</button>
          </div>
        </div>`;
      }).join('');
    }

    // Booked cards
    const bookedContainer = document.getElementById('cards-booked');
    if (!booked.length) {
      bookedContainer.innerHTML = '<div class="pipeline-empty">No bookings</div>';
    } else {
      bookedContainer.innerHTML = booked.map(r => {
        const mon = monitors.find(m => m.id === r.monitorId);
        return `<div class="rental-card">
          <div class="rental-card-renter">${r.renter}</div>
          <div class="rental-card-monitor">${mon?.name || r.monitorId} · &#x0E3F;${r.dailyRate}/day</div>
          <div class="rental-card-dates">${fmtDateShort(r.startDate)}${r.endDate ? ' → ' + fmtDateShort(r.endDate) : ''}</div>
          <div class="rental-card-meta">${r.contact}${r.depositHeld ? ' · Deposit held' : ''}</div>
          <div class="rental-card-actions">
            <button class="btn btn-primary btn-sm" onclick="advanceRental('${r.id}','deliver')">Deliver</button>
            <button class="btn btn-sm" onclick="advanceRental('${r.id}','cancel')">Cancel</button>
          </div>
        </div>`;
      }).join('');
    }

    // Delivered cards
    const deliveredContainer = document.getElementById('cards-delivered');
    if (!delivered.length) {
      deliveredContainer.innerHTML = '<div class="pipeline-empty">None out</div>';
    } else {
      deliveredContainer.innerHTML = delivered.map(r => {
        const mon = monitors.find(m => m.id === r.monitorId);
        const enriched = mon ? monitors.find(m2 => m2.rentalId === r.id) || mon : null;
        const daysRented = enriched?.daysRented || 0;
        const daysRemaining = enriched?.daysRemaining;
        const revenue = enriched?.revenueAccrued || 0;
        const overdue = enriched?.overdue || false;
        const daysInfo = daysRemaining !== null && daysRemaining !== undefined
          ? (daysRemaining < 0 ? `<span style="color:var(--airbnb)">${Math.abs(daysRemaining)}d overdue</span>` : `${daysRemaining}d left`)
          : '';
        return `<div class="rental-card ${overdue ? 'rental-card-overdue' : ''}">
          <div class="rental-card-renter">${r.renter}</div>
          <div class="rental-card-monitor">${mon?.name || r.monitorId}</div>
          <div class="rental-card-dates">${daysRented}d${daysInfo ? ' · ' + daysInfo : ''}</div>
          <div class="rental-card-meta">&#x0E3F;${revenue.toLocaleString()}${r.depositHeld ? ' · Deposit' : ''}</div>
          <div class="rental-card-actions">
            <button class="btn btn-primary btn-sm" onclick="advanceRental('${r.id}','return')">Return</button>
          </div>
        </div>`;
      }).join('');
    }

    // History
    renderMonitorHistory(history);
  }

  function renderMonitorHistory(rentals) {
    const container = document.getElementById('history-content');
    if (!rentals.length) {
      container.innerHTML = '<div class="pipeline-empty">No history yet</div>';
      return;
    }
    container.innerHTML = rentals.map(r => {
      const days = r.revenue > 0 ? Math.round(r.revenue / r.dailyRate) : 0;
      const isCancelled = r.status === 'cancelled';
      return `<div class="history-card ${isCancelled ? 'history-card-cancelled' : ''}">
        <div class="history-card-name">${r.renter}</div>
        <div class="history-card-detail">${monitorName(r.monitorId)} · ${days}d</div>
        <div class="history-card-detail">${isCancelled ? 'Cancelled' : '&#x0E3F;' + r.revenue.toLocaleString()}</div>
      </div>`;
    }).join('');
  }

  // ─── MONITOR ACTIONS ───────────────────────────────────────────────────────
  let rentStartPicker, rentEndPicker;

  window.advanceRental = async function(rentalId, action) {
    const labels = { deliver: 'Mark as delivered?', return: 'Mark as returned? Revenue will be calculated.', cancel: 'Cancel this rental?' };
    if (!confirm(labels[action] || `Confirm ${action}?`)) return;
    try {
      const res = await fetch(`/api/monitors/advance/${rentalId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action }),
      });
      if (!res.ok) { const err = await res.json(); alert(err.error || `Failed to ${action}`); return; }
      const data = await res.json();
      if (action === 'return') alert(`Monitor returned. Revenue: ฿${data.revenue.toLocaleString()}`);
      loadMonitors();
    } catch (err) {
      console.error(`[monitors] ${action} error:`, err);
      alert(`Failed to ${action} rental`);
    }
  };

  function openRentModal(monitorId) {
    const modal = document.getElementById('rent-modal');
    const select = document.getElementById('mr-monitor');
    select.innerHTML = allMonitors.filter(m => m.status === 'available').map(m =>
      `<option value="${m.id}" ${m.id === monitorId ? 'selected' : ''}>${m.name} (${m.id})</option>`
    ).join('');

    const mon = allMonitors.find(m => m.id === monitorId);
    document.getElementById('mr-rate').value = mon ? mon.dailyRate : '';
    document.getElementById('mr-renter').value = '';
    document.getElementById('mr-contact').value = '';
    document.getElementById('mr-notes').value = '';
    document.getElementById('mr-deposit').checked = false;
    document.getElementById('mr-deliver-now').checked = false;

    if (rentStartPicker) rentStartPicker.destroy();
    if (rentEndPicker) rentEndPicker.destroy();
    rentStartPicker = flatpickr('#mr-start', { dateFormat: 'Y-m-d', defaultDate: new Date() });
    rentEndPicker = flatpickr('#mr-end', { dateFormat: 'Y-m-d' });

    select.onchange = () => {
      const sel = allMonitors.find(m => m.id === select.value);
      if (sel) document.getElementById('mr-rate').value = sel.dailyRate;
    };

    modal.classList.add('open');
  }

  document.getElementById('mr-cancel').addEventListener('click', () => {
    document.getElementById('rent-modal').classList.remove('open');
  });

  document.getElementById('mr-save').addEventListener('click', async () => {
    const monitorId = document.getElementById('mr-monitor').value;
    const renter = document.getElementById('mr-renter').value.trim();
    const contact = document.getElementById('mr-contact').value.trim();
    const startDate = document.getElementById('mr-start').value;
    const endDate = document.getElementById('mr-end').value;
    const dailyRate = parseInt(document.getElementById('mr-rate').value);
    const depositHeld = document.getElementById('mr-deposit').checked;
    const deliverNow = document.getElementById('mr-deliver-now').checked;
    const notes = document.getElementById('mr-notes').value.trim();

    if (!renter || !contact || !startDate) { alert('Renter, contact, and start date are required.'); return; }
    if (!dailyRate || dailyRate <= 0) { alert('Please enter a valid daily rate.'); return; }

    try {
      const res = await fetch('/api/monitors/rent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ monitorId, renter, contact, startDate, endDate, dailyRate, depositHeld, deliverNow, notes }),
      });
      if (!res.ok) { const err = await res.json(); alert(err.error || 'Failed to create rental'); return; }
      document.getElementById('rent-modal').classList.remove('open');
      loadMonitors();
    } catch (err) {
      console.error('[monitors] rent error:', err);
      alert('Failed to create rental');
    }
  });

  window.openRentModal = openRentModal;

  // New Rental button in pipeline
  document.getElementById('btn-new-rental').addEventListener('click', () => {
    const firstAvailable = allMonitors.find(m => m.status === 'available');
    if (firstAvailable) openRentModal(firstAvailable.id);
    else alert('No monitors available for rental.');
  });

  window.toggleMaintenance = async function(monitorId) {
    const mon = allMonitors.find(m => m.id === monitorId);
    const action = mon?.status === 'maintenance' ? 'make available' : 'put into maintenance';
    if (!confirm(`${action.charAt(0).toUpperCase() + action.slice(1)} ${mon?.name || monitorId}?`)) return;
    try {
      const res = await fetch('/api/monitors/maintenance', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ monitorId }),
      });
      if (!res.ok) { const err = await res.json(); alert(err.error || 'Failed to toggle maintenance'); return; }
      loadMonitors();
    } catch (err) {
      console.error('[monitors] maintenance error:', err);
      alert('Failed to toggle maintenance');
    }
  };

  document.getElementById('btn-export-csv').addEventListener('click', () => {
    window.location.href = '/api/monitors/history?format=csv';
  });

  // ─── DESKS (CO-WORKING) ────────────────────────────────────────────────────────
  let allPasses = [];
  let deskData = {};
  const DESK_PRICING = { day: 350, weekly: 1500, monthly: 5000 };
  const TOTAL_DESKS = 5;

  async function loadDesks() {
    try {
      const res = await fetch('/api/coworking');
      const data = await res.json();
      allPasses = data.passes || [];
      deskData = data;
      renderDeskSummary(data.revenue || {});
      renderDeskToday(data.today || {});
      renderDeskPasses();
    } catch (err) {
      console.error('[desks] load error:', err);
    }
  }

  function renderDeskSummary(rev) {
    document.getElementById('ds-available').textContent = `${rev.desksAvailableToday ?? TOTAL_DESKS} / ${TOTAL_DESKS}`;
    document.getElementById('ds-active').textContent = rev.activePasses || 0;
    document.getElementById('ds-revenue').innerHTML = `&#x0E3F;${(rev.totalRevenueThisMonth || 0).toLocaleString()}`;
    document.getElementById('ds-utilisation').textContent = `${rev.utilisationPercent || 0}%`;
  }

  function renderDeskToday(todayInfo) {
    const checkedIn = todayInfo.checkedIn || 0;
    const available = todayInfo.desksAvailable ?? TOTAL_DESKS;
    const t = new Date().toISOString().slice(0, 10);

    // Desk visual
    const visual = document.getElementById('desk-visual');
    const todayPasses = allPasses.filter(p => p.status === 'active' && p.checkins && p.checkins.includes(t));
    let html = '';
    for (let i = 1; i <= TOTAL_DESKS; i++) {
      const pass = todayPasses[i - 1];
      if (pass) {
        const initial = pass.name.charAt(0).toUpperCase();
        html += `<div class="desk-slot occupied" title="${pass.name}"><span class="desk-slot-num">${initial}</span></div>`;
      } else {
        html += `<div class="desk-slot"><span class="desk-slot-num">${i}</span></div>`;
      }
    }
    visual.innerHTML = html;

    // Checkin cards
    const cards = document.getElementById('desk-checkins');
    if (!todayPasses.length) {
      cards.innerHTML = '<div class="desk-empty">No one checked in yet today</div>';
    } else {
      cards.innerHTML = todayPasses.map(p => {
        const initial = p.name.charAt(0).toUpperCase();
        const badge = `<span class="pass-badge pass-badge-${p.type}">${p.type}</span>`;
        const guestLink = p.guestId ? ` <span style="color:var(--accent);cursor:pointer;font-size:11px;" onclick="event.stopPropagation();openGuestPanel('${p.guestId}')">profile</span>` : '';
        return `<div class="desk-checkin-card">
          <div class="desk-checkin-avatar">${initial}</div>
          <div><div style="font-weight:600;">${p.name} ${badge}${guestLink}</div>
          <div style="font-size:11px;color:#8b8b85;">${p.contact || ''}</div></div>
        </div>`;
      }).join('');
    }
  }

  function deskDaysLeft(endDate) {
    const end = new Date(endDate + 'T00:00:00');
    const now = new Date();
    now.setHours(0,0,0,0);
    const diff = Math.ceil((end - now) / 86400000);
    if (diff < 0) return 'expired';
    if (diff === 0) return 'last day';
    return `${diff}d left`;
  }

  function renderDeskPasses() {
    const active = allPasses.filter(p => p.status === 'active');
    const past = allPasses.filter(p => p.status !== 'active').sort((a, b) => b.updatedAt.localeCompare(a.updatedAt)).slice(0, 20);
    const t = new Date().toISOString().slice(0, 10);

    const borderColors = { day: '#e65100', weekly: '#1565c0', monthly: '#2e7d32' };

    const activeEl = document.getElementById('desk-active-passes');
    if (!active.length) {
      activeEl.innerHTML = '<div class="desk-empty">No active passes</div>';
    } else {
      activeEl.innerHTML = active.map(p => {
        const checkedInToday = p.checkins && p.checkins.includes(t);
        const showCheckin = p.type !== 'day' && !checkedInToday;
        const daysInfo = deskDaysLeft(p.endDate);
        const guestLink = p.guestId ? `<span style="color:var(--accent);cursor:pointer;font-size:11px;margin-left:4px;" onclick="event.stopPropagation();openGuestPanel('${p.guestId}')">&#x1F464;</span>` : '';
        return `<div class="desk-pass-card" style="border-left-color:${borderColors[p.type] || '#ccc'}">
          <div class="desk-pass-card-header">
            <div class="desk-pass-card-name">${p.name}${guestLink} <span class="pass-badge pass-badge-${p.type}">${p.type}</span></div>
          </div>
          <div class="desk-pass-card-dates">${fmtDateShort(p.startDate)} &ndash; ${fmtDateShort(p.endDate)} &middot; ${daysInfo}</div>
          <div class="desk-pass-card-meta">&#x0E3F;${p.amount.toLocaleString()}${p.contact ? ' &middot; ' + p.contact : ''}${checkedInToday ? ' &middot; &#x2714; Checked in' : ''}</div>
          <div class="desk-pass-card-actions">
            ${showCheckin ? `<button class="btn btn-primary btn-sm" onclick="deskCheckin('${p.id}')">Check in</button>` : ''}
            <button class="btn btn-sm" onclick="deskCancelPass('${p.id}')">Cancel</button>
          </div>
        </div>`;
      }).join('');
    }

    const pastEl = document.getElementById('desk-past-passes');
    if (!past.length) {
      pastEl.innerHTML = '<div class="desk-empty">No history yet</div>';
    } else {
      pastEl.innerHTML = past.map(p => {
        const statusLabel = p.status === 'cancelled' ? 'Cancelled' : 'Expired';
        return `<div class="desk-pass-card desk-pass-card-expired" style="border-left-color:${borderColors[p.type] || '#ccc'}">
          <div class="desk-pass-card-header">
            <div class="desk-pass-card-name">${p.name} <span class="pass-badge pass-badge-${p.type}">${p.type}</span></div>
          </div>
          <div class="desk-pass-card-dates">${fmtDateShort(p.startDate)} &ndash; ${fmtDateShort(p.endDate)} &middot; ${statusLabel}</div>
          <div class="desk-pass-card-meta">&#x0E3F;${p.amount.toLocaleString()}${p.contact ? ' &middot; ' + p.contact : ''}</div>
        </div>`;
      }).join('');
    }
  }

  // ─── DESK ACTIONS ────────────────────────────────────────────────────────
  let passStartPicker;

  window.deskCheckin = async function(passId) {
    try {
      const res = await fetch('/api/coworking/checkin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ passId }),
      });
      if (!res.ok) { const err = await res.json(); alert(err.error || 'Check-in failed'); return; }
      loadDesks();
    } catch (err) {
      console.error('[desks] checkin error:', err);
      alert('Check-in failed');
    }
  };

  window.deskCancelPass = async function(passId) {
    if (!confirm('Cancel this pass?')) return;
    try {
      const res = await fetch(`/api/coworking/${passId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'cancelled' }),
      });
      if (!res.ok) { const err = await res.json(); alert(err.error || 'Failed to cancel'); return; }
      loadDesks();
    } catch (err) {
      console.error('[desks] cancel error:', err);
      alert('Failed to cancel pass');
    }
  };

  function openSellPassModal() {
    const modal = document.getElementById('pass-modal');
    document.getElementById('cp-type').value = 'day';
    document.getElementById('cp-name').value = '';
    document.getElementById('cp-contact').value = '';
    document.getElementById('cp-notes').value = '';
    document.getElementById('cp-amount').value = DESK_PRICING.day;
    document.getElementById('cp-guest').value = '';
    document.getElementById('cp-suggestions').style.display = 'none';
    document.getElementById('cp-guest-badge').style.display = 'none';

    if (passStartPicker) passStartPicker.destroy();
    passStartPicker = flatpickr('#cp-start', { dateFormat: 'Y-m-d', defaultDate: new Date() });

    modal.classList.add('open');
    document.getElementById('cp-name').focus();
  }

  // Name autocomplete
  (function() {
    const nameInput = document.getElementById('cp-name');
    const suggestions = document.getElementById('cp-suggestions');
    const guestInput = document.getElementById('cp-guest');
    const badge = document.getElementById('cp-guest-badge');
    const badgeText = document.getElementById('cp-guest-badge-text');
    let debounceTimer;

    function selectGuest(g) {
      nameInput.value = g.fullName;
      guestInput.value = g.id;
      document.getElementById('cp-contact').value = g.whatsapp || g.phone || g.email || '';
      suggestions.style.display = 'none';
      badge.style.display = 'block';
      badgeText.textContent = 'Linked to ' + g.fullName;
    }

    function clearGuestLink() {
      guestInput.value = '';
      badge.style.display = 'none';
    }

    document.getElementById('cp-guest-clear').addEventListener('click', clearGuestLink);

    nameInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      clearGuestLink();
      const q = nameInput.value.trim().toLowerCase();
      if (q.length < 2) { suggestions.style.display = 'none'; return; }

      debounceTimer = setTimeout(() => {
        const matches = (allGuests || []).filter(g => g.fullName.toLowerCase().includes(q)).slice(0, 6);
        if (!matches.length) {
          suggestions.innerHTML = '<div style="padding:10px 14px; font-size:12px; color:#8b8b85;">No matches. A new guest will be created.</div>';
          suggestions.style.display = 'block';
          return;
        }
        suggestions.innerHTML = matches.map(g => {
          const initial = g.fullName.charAt(0).toUpperCase();
          const detail = [g.nationality, g.email, g.phone].filter(Boolean).join(' · ');
          return `<div class="cp-suggest-item" data-id="${g.id}" style="padding:8px 14px; cursor:pointer; display:flex; align-items:center; gap:10px; transition:background 0.1s;">
            <div style="width:28px;height:28px;border-radius:50%;background:var(--accent);color:white;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:11px;flex-shrink:0;">${initial}</div>
            <div><div style="font-size:13px;font-weight:500;">${g.fullName}</div>${detail ? `<div style="font-size:11px;color:#8b8b85;">${detail}</div>` : ''}</div>
          </div>`;
        }).join('');
        suggestions.style.display = 'block';
      }, 150);
    });

    suggestions.addEventListener('click', (e) => {
      const item = e.target.closest('.cp-suggest-item');
      if (!item) return;
      const g = (allGuests || []).find(guest => guest.id === item.dataset.id);
      if (g) selectGuest(g);
    });

    // Hover effect
    suggestions.addEventListener('mouseover', (e) => {
      const item = e.target.closest('.cp-suggest-item');
      if (item) item.style.background = '#f4f3f1';
    });
    suggestions.addEventListener('mouseout', (e) => {
      const item = e.target.closest('.cp-suggest-item');
      if (item) item.style.background = '';
    });

    // Close suggestions on click outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('#cp-suggestions') && e.target.id !== 'cp-name') {
        suggestions.style.display = 'none';
      }
    });
  })();

  // Update amount when type changes
  document.getElementById('cp-type').addEventListener('change', () => {
    const type = document.getElementById('cp-type').value;
    document.getElementById('cp-amount').value = DESK_PRICING[type] || 350;
  });

  document.getElementById('cp-cancel').addEventListener('click', () => {
    document.getElementById('pass-modal').classList.remove('open');
  });

  document.getElementById('cp-save').addEventListener('click', async () => {
    const name = document.getElementById('cp-name').value.trim();
    const type = document.getElementById('cp-type').value;
    const contact = document.getElementById('cp-contact').value.trim();
    const guestId = document.getElementById('cp-guest').value;
    const startDate = document.getElementById('cp-start').value;
    const amount = parseInt(document.getElementById('cp-amount').value);
    const notes = document.getElementById('cp-notes').value.trim();

    if (!name) { alert('Name is required.'); return; }
    if (!amount || amount <= 0) { alert('Please enter a valid amount.'); return; }

    try {
      const res = await fetch('/api/coworking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, type, contact, guestId: guestId || undefined, startDate, amount, notes }),
      });
      if (!res.ok) { const err = await res.json(); alert(err.error || 'Failed to sell pass'); return; }
      document.getElementById('pass-modal').classList.remove('open');
      loadDesks();
      // Refresh guests list so new profile appears
      loadGuests();
    } catch (err) {
      console.error('[desks] sell pass error:', err);
      alert('Failed to sell pass');
    }
  });

  document.getElementById('btn-sell-pass').addEventListener('click', async () => {
    // Ensure guests are loaded for autocomplete
    if (!allGuests || !allGuests.length) {
      try { await loadGuests(); } catch (e) {}
    }
    openSellPassModal();
  });

  // ─── CHAT ──────────────────────────────────────────────────────────────────────
  let chatHistory = [];
  let isStreaming = false;

  function clearChat() {
    if (isStreaming) return;
    chatHistory = [];
    const messagesContainer = document.getElementById('chat-messages');
    if (messagesContainer) {
      const welcome = messagesContainer.querySelector('#chat-welcome');
      messagesContainer.innerHTML = '';
      if (welcome) { welcome.style.display = ''; messagesContainer.appendChild(welcome); }
    }
    const newBtn = document.getElementById('chat-new-btn');
    if (newBtn) newBtn.style.display = 'none';
    // Re-randomize greeting
    const hour = new Date().getHours();
    const greetings = hour < 12 ? ['Good morning', 'Morning!'] : hour < 17 ? ['Good afternoon', 'Hey there'] : ['Good evening', 'Evening!'];
    const welcomeTitle = document.getElementById('chat-welcome-title');
    if (welcomeTitle) welcomeTitle.textContent = greetings[Math.floor(Math.random() * greetings.length)];
  }

  document.getElementById('chat-new-btn')?.addEventListener('click', clearChat);

  function scrollChatToBottom(smooth) {
    const el = document.getElementById('chat-messages');
    if (smooth) {
      requestAnimationFrame(() => { el.scrollTo({ top: el.scrollHeight, behavior: 'smooth' }); });
    } else {
      requestAnimationFrame(() => { el.scrollTop = el.scrollHeight; });
    }
  }

  function isNearBottom() {
    const el = document.getElementById('chat-messages');
    return el.scrollHeight - el.scrollTop - el.clientHeight < 80;
  }

  function renderMarkdown(text) {
    if (typeof marked !== 'undefined' && marked.parse) {
      return marked.parse(text, { breaks: true });
    }
    // Fallback: basic escaping
    return text.replace(/</g, '&lt;').replace(/\n/g, '<br>');
  }

  // ─── ACTION CARD RENDERING ─────────────────────────────────────────────────
  const ACTION_PATTERNS = {
    bookingType: /\[SELECT:booking-type\]/g,
    room: /\[SELECT:room\]/g,
    datepicker: /\[DATEPICKER:checkin-checkout(?::(\w+))?\]/g,
    confirm: /\[CONFIRM:booking\|([^|]+)\|([^|]+)\|([^|]+)\|([^|]+)\|([^|]+)\|([^\]]+)\]/g,
  };

  const BOOKING_TYPE_OPTIONS = [
    { value: 'direct', label: 'Direct' },
    { value: 'friend', label: 'Friend' },
    { value: 'owner', label: 'Owner' },
    { value: 'hold', label: 'Hold' },
    { value: 'blocked', label: 'Blocked' },
    { value: 'waitlist', label: 'Waitlist' },
  ];

  const ROOM_OPTIONS = [
    { value: 'nest', label: 'The Nest' },
    { value: 'master', label: 'The Explorer' },
    { value: 'nomad', label: 'The Nomad' },
    { value: 'theater', label: 'Theater Room' },
    { value: 'full', label: 'Full House' },
  ];

  // ROOM_LABELS already declared at top of script (line ~442)
  const TYPE_LABELS = { direct: 'Direct', friend: 'Friend', owner: 'Owner', hold: 'Hold', blocked: 'Blocked', waitlist: 'Waitlist' };

  function processActionCards(html, bubble) {
    // Replace [SELECT:booking-type]
    html = html.replace(ACTION_PATTERNS.bookingType, () => {
      const btns = BOOKING_TYPE_OPTIONS.map(o =>
        `<button class="chat-action-btn" data-action="booking-type" data-value="${o.value}">${o.label}</button>`
      ).join('');
      return `<div class="chat-action-card"><div class="chat-action-label">Booking Type</div><div class="chat-action-buttons">${btns}</div></div>`;
    });

    // Replace [SELECT:room]
    html = html.replace(ACTION_PATTERNS.room, () => {
      const btns = ROOM_OPTIONS.map(o =>
        `<button class="chat-action-btn" data-action="room" data-value="${o.value}">${o.label}</button>`
      ).join('');
      return `<div class="chat-action-card"><div class="chat-action-label">Room</div><div class="chat-action-buttons">${btns}</div></div>`;
    });

    // Replace [DATEPICKER:checkin-checkout:TYPE]
    html = html.replace(ACTION_PATTERNS.datepicker, (_, bookingType) => {
      const id = 'dp-' + Date.now();
      return `<div class="chat-action-card"><div class="chat-action-label">Select Dates</div><div class="chat-datepicker-wrap" id="${id}" data-booking-type="${bookingType || 'direct'}"></div></div>`;
    });

    // Replace [CONFIRM:booking|type|room|checkin|checkout|guest|amount]
    html = html.replace(ACTION_PATTERNS.confirm, (_, type, room, checkin, checkout, guest, amount) => {
      const ci = new Date(checkin + 'T12:00:00');
      const co = new Date(checkout + 'T12:00:00');
      const nights = Math.round((co - ci) / 86400000);
      const fmtDate = d => new Date(d + 'T12:00:00').toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      const fmtAmt = Number(amount).toLocaleString();
      return `<div class="chat-action-card chat-confirm-card">
        <div class="chat-confirm-row"><span>Type</span><span>${TYPE_LABELS[type] || type}</span></div>
        <div class="chat-confirm-row"><span>Room</span><span>${ROOM_LABELS[room] || room}</span></div>
        <div class="chat-confirm-row"><span>Dates</span><span>${fmtDate(checkin)} - ${fmtDate(checkout)} (${nights} nights)</span></div>
        <div class="chat-confirm-row"><span>Guest</span><span>${guest}</span></div>
        <div class="chat-confirm-row"><span>Amount</span><span>${fmtAmt} THB</span></div>
        <div class="chat-action-buttons">
          <button class="chat-action-btn confirm" data-action="confirm-booking">Confirm Booking</button>
          <button class="chat-action-btn cancel" data-action="cancel-booking">Cancel</button>
        </div>
      </div>`;
    });

    return html;
  }

  // Initialize Flatpickr date pickers that appear in action cards
  function initDatePickers(bubble) {
    bubble.querySelectorAll('.chat-datepicker-wrap').forEach(wrap => {
      if (wrap.dataset.initialized) return;
      wrap.dataset.initialized = 'true';
      const bookingType = wrap.dataset.bookingType || 'direct';
      const isWaitlist = bookingType === 'waitlist';

      const fp = flatpickr(wrap, {
        mode: 'range',
        inline: true,
        minDate: 'today',
        dateFormat: 'Y-m-d',
        onChange: (dates) => {
          if (dates.length === 2) {
            const [ci, co] = dates;
            const ciStr = ci.toISOString().split('T')[0];
            const coStr = co.toISOString().split('T')[0];
            // Disable picker after selection
            fp.set('clickOpens', false);
            wrap.style.opacity = '0.6';
            wrap.style.pointerEvents = 'none';
            // Send dates as user message
            sendChatMessage(`Check-in: ${ciStr}, Check-out: ${coStr}`);
          }
        },
      });

      // Try to load booked dates for room context
      // Look for room selection in chat history
      const lastRoomMsg = chatHistory.filter(m => m.role === 'user').reverse()
        .find(m => ROOM_OPTIONS.some(r => m.content.toLowerCase().includes(r.label.toLowerCase())));
      if (lastRoomMsg) {
        const room = ROOM_OPTIONS.find(r => lastRoomMsg.content.toLowerCase().includes(r.label.toLowerCase()));
        if (room && ['nest', 'master', 'nomad'].includes(room.value)) {
          fetch(`/api/availability/${room.value}`)
            .then(r => r.json())
            .then(data => {
              if (data.bookedDates) {
                const dates = data.bookedDates;
                fp.set('onDayCreate', (dObj, dStr, fpInst, dayElem) => {
                  const d = dayElem.dateObj.toISOString().split('T')[0];
                  if (dates.includes(d)) {
                    dayElem.classList.add('booked');
                    if (isWaitlist) {
                      dayElem.classList.add('waitlist-mode');
                    } else {
                      dayElem.classList.add('flatpickr-disabled');
                    }
                  }
                });
                fp.redraw();
              }
            })
            .catch(() => {}); // Silent fail
        }
      }
    });
  }

  // Delegate clicks on action buttons
  document.getElementById('chat-messages').addEventListener('click', (e) => {
    const btn = e.target.closest('.chat-action-btn');
    if (!btn || btn.disabled || btn.classList.contains('selected')) return;

    const action = btn.dataset.action;
    const value = btn.dataset.value;

    if (action === 'booking-type' || action === 'room') {
      // Mark selected, disable others
      const card = btn.closest('.chat-action-card');
      card.querySelectorAll('.chat-action-btn').forEach(b => {
        b.disabled = true;
        b.classList.remove('selected');
      });
      btn.classList.add('selected');
      btn.disabled = false;

      // Send as user message
      const label = action === 'room' ? (ROOM_LABELS[value] || value) : (TYPE_LABELS[value] || value);
      sendChatMessage(label);
    } else if (action === 'confirm-booking') {
      const card = btn.closest('.chat-action-card');
      card.querySelectorAll('.chat-action-btn').forEach(b => b.disabled = true);
      btn.classList.add('selected');
      sendChatMessage('Yes, confirm this booking');
    } else if (action === 'cancel-booking') {
      const card = btn.closest('.chat-action-card');
      card.querySelectorAll('.chat-action-btn').forEach(b => b.disabled = true);
      btn.classList.add('selected');
      sendChatMessage('Cancel, don\'t create this booking');
    }
  });

  function appendChatMessage(role, content, imageDataUrl) {
    const welcome = document.getElementById('chat-welcome');
    if (welcome) welcome.style.display = 'none';
    const container = document.getElementById('chat-messages');
    const msg = document.createElement('div');
    msg.className = 'chat-msg chat-msg-' + role;

    // Assistant avatar
    if (role === 'assistant') {
      const avatar = document.createElement('div');
      avatar.className = 'chat-avatar';
      avatar.textContent = 'KH';
      msg.appendChild(avatar);
    }

    const bubble = document.createElement('div');
    bubble.className = 'chat-bubble chat-bubble-' + role;
    if (role === 'assistant') {
      let html = renderMarkdown(content);
      html = processActionCards(html, bubble);
      bubble.innerHTML = html;
      requestAnimationFrame(() => initDatePickers(bubble));
    } else {
      // User message: show image if attached
      if (imageDataUrl) {
        const img = document.createElement('img');
        img.src = imageDataUrl;
        img.className = 'chat-user-image';
        img.alt = 'Attached image';
        bubble.appendChild(img);
      }
      if (content) {
        const textEl = document.createElement('span');
        textEl.textContent = content;
        bubble.appendChild(textEl);
      }
    }
    if (role === 'assistant') addCopyButton(bubble);
    msg.appendChild(bubble);
    container.appendChild(msg);
    scrollChatToBottom(true);
    return bubble;
  }

  function addCopyButton(bubble) {
    const btn = document.createElement('button');
    btn.className = 'chat-copy-btn';
    btn.title = 'Copy to clipboard';
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
    btn.addEventListener('click', () => {
      const text = bubble.innerText || bubble.textContent || '';
      navigator.clipboard.writeText(text.trim()).then(() => {
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => {
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        }, 2000);
      });
    });
    bubble.style.position = 'relative';
    bubble.appendChild(btn);
  }

  function showToolIndicator(name) {
    const container = document.getElementById('chat-messages');
    let indicator = document.getElementById('chat-tool-indicator');
    if (!indicator) {
      indicator = document.createElement('div');
      indicator.id = 'chat-tool-indicator';
      indicator.className = 'chat-tool-indicator';
      container.appendChild(indicator);
    }
    const labels = {
      check_availability: 'Checking availability...',
      list_bookings: 'Looking up bookings...',
      get_monthly_stats: 'Calculating stats...',
      calculate_price: 'Calculating price...',
      lookup_pricing: 'Checking rates...',
      validate_promo_code: 'Validating code...',
      list_inquiries: 'Checking inquiries...',
      get_monitors: 'Checking monitors...',
      get_monitor_revenue: 'Getting revenue data...',
      create_booking: 'Creating booking...',
    };
    indicator.textContent = labels[name] || 'Thinking...';
    indicator.style.display = 'block';
    scrollChatToBottom();
  }

  function removeToolIndicator() {
    const indicator = document.getElementById('chat-tool-indicator');
    if (indicator) indicator.style.display = 'none';
  }

  async function sendChatMessage(text, imageDataUrl) {
    if ((!text.trim() && !imageDataUrl) || isStreaming) return;
    isStreaming = true;
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('chat-send');
    input.value = '';
    input.style.height = 'auto';
    sendBtn.disabled = true;

    // Clear image preview
    pendingImage = null;
    document.getElementById('chat-image-preview').style.display = 'none';

    // Build message content (text-only or multipart with image)
    let messageContent;
    if (imageDataUrl) {
      messageContent = [];
      if (text.trim()) messageContent.push({ type: 'text', text: text.trim() });
      messageContent.push({ type: 'image_url', image_url: { url: imageDataUrl, detail: 'low' } });
    } else {
      messageContent = text.trim();
    }

    // Add user message
    chatHistory.push({ role: 'user', content: messageContent });
    appendChatMessage('user', text.trim(), imageDataUrl);

    // Create empty assistant bubble with avatar
    const welcome = document.getElementById('chat-welcome');
    if (welcome) welcome.style.display = 'none';
    const newBtn = document.getElementById('chat-new-btn');
    if (newBtn) newBtn.style.display = '';
    const container = document.getElementById('chat-messages');
    const msg = document.createElement('div');
    msg.className = 'chat-msg chat-msg-assistant';
    const avatar = document.createElement('div');
    avatar.className = 'chat-avatar';
    avatar.textContent = 'KH';
    msg.appendChild(avatar);
    const bubble = document.createElement('div');
    bubble.className = 'chat-bubble chat-bubble-assistant';
    bubble.innerHTML = '<span class="chat-typing"><span class="chat-typing-mid"></span></span>';
    msg.appendChild(bubble);
    container.appendChild(msg);
    scrollChatToBottom();

    let fullContent = '';

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: chatHistory }),
      });

      if (!res.ok) {
        bubble.innerHTML = renderMarkdown('Sorry, something went wrong. Please try again.');
        isStreaming = false;
        sendBtn.disabled = false;
        return;
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const payload = line.slice(6).trim();
          if (payload === '[DONE]') continue;

          try {
            const data = JSON.parse(payload);
            if (data.type === 'delta') {
              fullContent += data.content;
              let html = renderMarkdown(fullContent);
              html = processActionCards(html, bubble);
              bubble.innerHTML = html;
              requestAnimationFrame(() => initDatePickers(bubble));
              scrollChatToBottom();
            } else if (data.type === 'tool') {
              showToolIndicator(data.name);
            } else if (data.type === 'done') {
              removeToolIndicator();
            } else if (data.type === 'error') {
              fullContent = data.content || 'Something went wrong.';
              bubble.innerHTML = renderMarkdown(fullContent);
            }
          } catch {}
        }
      }

      removeToolIndicator();
      if (!fullContent) {
        fullContent = 'No response received.';
        bubble.innerHTML = renderMarkdown(fullContent);
      }
      chatHistory.push({ role: 'assistant', content: fullContent });
      addCopyButton(bubble);

    } catch (err) {
      console.error('[chat] error:', err);
      bubble.innerHTML = renderMarkdown('Connection error. Please try again.');
    }

    isStreaming = false;
    sendBtn.disabled = false;
    input.focus();
  }

  // ─── IMAGE UPLOAD ──────────────────────────────────────────────────────────
  let pendingImage = null; // base64 data URL
  const fileInput = document.getElementById('chat-file-input');
  const attachBtn = document.getElementById('chat-attach');
  const imagePreview = document.getElementById('chat-image-preview');
  const imageThumb = document.getElementById('chat-image-thumb');
  const imageRemove = document.getElementById('chat-image-remove');

  attachBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => {
      pendingImage = reader.result;
      imageThumb.src = pendingImage;
      imagePreview.style.display = 'flex';
      chatSend.disabled = false;
    };
    reader.readAsDataURL(file);
    fileInput.value = ''; // reset so same file can be re-selected
  });
  imageRemove.addEventListener('click', () => {
    pendingImage = null;
    imagePreview.style.display = 'none';
    if (!chatInput.value.trim()) chatSend.disabled = true;
  });

  // ─── TIME-OF-DAY GREETING ──────────────────────────────────────────────────
  const hour = new Date().getHours();
  const greetings = hour < 12 ? ['Good morning', 'Morning!'] : hour < 17 ? ['Good afternoon', 'Hey there'] : ['Good evening', 'Evening!'];
  const welcomeTitle = document.getElementById('chat-welcome-title');
  if (welcomeTitle) welcomeTitle.textContent = greetings[Math.floor(Math.random() * greetings.length)];

  // Chat input handlers
  const chatInput = document.getElementById('chat-input');
  const chatSend = document.getElementById('chat-send');

  chatInput.addEventListener('input', () => {
    chatSend.disabled = !chatInput.value.trim() && !pendingImage;
    // Auto-resize
    chatInput.style.height = 'auto';
