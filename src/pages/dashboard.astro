  const AIRBNB_LINKS = {
    nest: 'https://www.airbnb.com/rooms/1511809226602265595',
    master: 'https://www.airbnb.com/rooms/1618003971883950106',
    nomad: 'https://www.airbnb.com/rooms/1618012678467611754',
  };
  const ROOM_COLORS_CSS = { nest:'var(--nest)', master:'var(--master)', nomad:'var(--nomad)' };
  let currentRoomSlug = null;

  function openRoomModal(slug) {
    currentRoomSlug = slug;
    const name = ROOM_LABELS[slug] || slug;
    document.getElementById('rm-name').textContent = name;
    document.getElementById('rm-dot').style.background = ROOM_COLORS_CSS[slug] || '#ccc';
    document.getElementById('rm-high').value = RATES_HIGH[slug] || 0;
    document.getElementById('rm-low').value = RATES_LOW[slug] || 0;
    document.getElementById('rm-airbnb').href = AIRBNB_LINKS[slug] || '#';
    document.getElementById('rm-status').style.display = 'none';
    document.getElementById('room-modal').classList.add('open');
  }

  document.querySelectorAll('.room-item[data-room]').forEach(el => {
    el.addEventListener('click', () => openRoomModal(el.dataset.room));
  });

  document.getElementById('rm-cancel').addEventListener('click', () => {
    document.getElementById('room-modal').classList.remove('open');
  });
  document.getElementById('room-modal').addEventListener('click', e => {
    if (e.target.id === 'room-modal') document.getElementById('room-modal').classList.remove('open');
  });

  document.getElementById('rm-save').addEventListener('click', async () => {
    if (!currentRoomSlug) return;
    const payload = {};
    payload[currentRoomSlug] = {
      high: parseInt(document.getElementById('rm-high').value) || 0,
      low: parseInt(document.getElementById('rm-low').value) || 0,
    };
    try {
      const res = await fetch('/api/pricing', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      applyPricing(data);
      render();
      const status = document.getElementById('rm-status');
      status.style.display = 'inline';
      setTimeout(() => status.style.display = 'none', 2000);
    } catch (err) {
      console.error('Failed to save pricing:', err);
      alert('Failed to save pricing');
    }
  });

  // ─── INIT ─────────────────────────────────────────────────────────────────────
  fetchPricing(); // Load rates before first render
  loadBookings();
  fetchInquiries(); // Load inquiries on startup for badge count
  setInterval(() => loadBookings(), 30 * 60 * 1000);
  </script>
</BaseLayout>
