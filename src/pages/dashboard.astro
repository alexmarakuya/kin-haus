      if (h.lineId) contacts += `<span class="staff-contact-btn" title="LINE: ${h.lineId}">LINE</span>`;
      if (h.messenger) contacts += `<a class="staff-contact-btn" href="https://m.me/${h.messenger}" target="_blank" title="Messenger">FB</a>`;
