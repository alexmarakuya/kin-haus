        <div class="fg">
          <label>Note (optional)</label>
          <input id="fc-note" type="text" placeholder="e.g. For close friends">
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn" id="fc-cancel">Cancel</button>
        <button class="btn btn-primary" id="fc-save">Create Code</button>
      </div>
    </div>
  </div>

  <!-- ROOM DETAIL MODAL -->
  <div class="overlay" id="room-modal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="rm-title" style="display:flex; align-items:center; gap:8px;">
          <div class="room-dot" id="rm-dot"></div>
          <span id="rm-name"></span>
        </div>
        <button class="modal-close" onclick="document.getElementById('room-modal').classList.remove('open')">&times;</button>
      </div>
      <div class="modal-body">
        <div class="rm-section-label">Nightly Rates</div>
        <div class="pricing-row"><label>High season (Nov-Mar)</label><div class="pricing-input-wrap"><span class="pricing-currency">&#x0E3F;</span><input type="number" id="rm-high" class="pricing-input" min="0" step="100"></div></div>
        <div class="pricing-row"><label>Low season (Apr-Oct)</label><div class="pricing-input-wrap"><span class="pricing-currency">&#x0E3F;</span><input type="number" id="rm-low" class="pricing-input" min="0" step="100"></div></div>
        <div class="rm-section-label" style="margin-top:16px">Airbnb Listing</div>
        <a id="rm-airbnb" class="rm-link" href="#" target="_blank" rel="noopener">View on Airbnb &#x2192;</a>
        <span id="rm-status" style="font-size:11px; color:var(--accent); display:none; margin-top:8px;">Saved!</span>
      </div>
      <div class="modal-footer">
        <button class="btn" id="rm-cancel">Cancel</button>
        <button class="btn btn-primary" id="rm-save">Save Rates</button>
      </div>
    </div>
  </div>

  <!-- RENT MONITOR MODAL -->
  <div class="overlay" id="rent-modal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Rent Monitor</div>
        <button class="modal-close" onclick="document.getElementById('rent-modal').classList.remove('open')">&times;</button>
      </div>
      <div class="modal-body">
        <div class="fg">
          <label>Monitor</label>
          <select id="mr-monitor"></select>
        </div>
        <div class="fg"><label>Renter Name</label><input id="mr-renter" type="text" placeholder="e.g. John Smith"></div>
        <div class="fg"><label>Contact (phone or email)</label><input id="mr-contact" type="text" placeholder="e.g. +66 81 234 5678"></div>
        <div class="fg"><label>Start Date</label><input id="mr-start" type="text" placeholder="Select date" readonly></div>
        <div class="fg"><label>Expected Return Date</label><input id="mr-end" type="text" placeholder="Select date (optional)" readonly></div>
        <div class="fg"><label>Daily Rate (THB)</label><input id="mr-rate" type="number" placeholder="e.g. 150"></div>
        <div class="fg" style="display:flex; align-items:center; gap:8px;">
          <input id="mr-deposit" type="checkbox">
          <label for="mr-deposit" style="margin:0; font-size:13px;">Deposit received</label>
        </div>
        <div class="fg" style="display:flex; align-items:center; gap:8px;">
          <input id="mr-deliver-now" type="checkbox">
          <label for="mr-deliver-now" style="margin:0; font-size:13px;">Hand over now (start billing today)</label>
        </div>
        <div class="fg"><label>Notes (optional)</label><input id="mr-notes" type="text" placeholder="Optional note"></div>
      </div>
      <div class="modal-footer">
        <button class="btn" id="mr-cancel">Cancel</button>
        <button class="btn btn-primary" id="mr-save">Create Rental</button>
      </div>
    </div>
  </div>

  <script is:inline>
  // ─── CONSTANTS ────────────────────────────────────────────────────────────
  // NOTE: These client-side constants mirror the canonical values in
  // src/lib/constants.ts. Keep them in sync when updating room names,
  // types, or pricing defaults.
  const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const ROOMS = ['nest','master','nomad','theater'];
  const ROOM_LABELS = { nest:'The Nest', master:'Master Suite', nomad:'Nomad Room', theater:'Theater Room', full:'Full House' };
  const ROOM_COLORS = { nest:'var(--nest)', master:'var(--master)', nomad:'var(--nomad)', theater:'var(--theater)', full:'#8a6f9e' };
  const TYPE_CLASS = { airbnb:'c-airbnb', direct:'c-direct', friend:'c-friend', blocked:'c-blocked', owner:'c-owner', hold:'c-hold', waitlist:'c-waitlist' };
  const BAR_COLORS = {
    airbnb:  { bg:'var(--airbnb-light)',  accent:'var(--airbnb)',  bs:'' },
    direct:  { bg:'var(--direct-light)',  accent:'var(--direct)',  bs:'' },
    friend:  { bg:'var(--friend-light)',  accent:'var(--friend)',  bs:'' },
    blocked: { bg:'var(--blocked-light)', accent:'var(--blocked)', bs:'' },
    owner:   { bg:'var(--owner-light)',   accent:'var(--owner)',   bs:'' },
    hold:    { bg:'var(--hold-light)',    accent:'var(--hold)',    bs:'bar-dashed' },
    waitlist:{ bg:'var(--waitlist-light)', accent:'var(--waitlist)', bs:'bar-dotted' },
    conflict:{ bg:'var(--conflict-light)',accent:'var(--conflict)', bs:'' },
  };
  let RATES_HIGH = { nest:5000, master:3200, nomad:2400, theater:0, full:10600 };
  let RATES_LOW  = { nest:3500, master:2240, nomad:1680, theater:0, full:7420 };
  const RATES = RATES_HIGH;

  // ─── STATE ──────────────────────────────────────────────────────────────────
  let allBookings = [];
  let currentYear = new Date().getFullYear();
  let currentMonth = new Date().getMonth();
  let currentTab = localStorage.getItem('kin-active-tab') || 'calendar';
  if (currentTab === 'codes') currentTab = 'calendar'; // tab removed
  let activeFilters = { airbnb: true, direct: true, friend: true, blocked: false, owner: false, hold: false, waitlist: false };
  let presentMode = false;

  // ─── UTILITIES ────────────────────────────────────────────────────────────
  // Local date string helper — avoids UTC shift from toISOString()
  Date.prototype.toLocalDateStr = function() {
    const y = this.getFullYear();
    const m = String(this.getMonth() + 1).padStart(2, '0');
    const d = String(this.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  };

  function parseDateLocal(str) {
    const [y, m, d] = str.split('-').map(Number);
    return new Date(y, m - 1, d, 12, 0, 0);
  }

  // ─── PRESENT MODE ─────────────────────────────────────────────────────────
  const FAKE_NAMES = ['Alex T.','Jordan R.','Sam K.','Morgan P.','Casey L.','Riley J.','Jamie W.','Taylor S.','Drew M.','Quinn B.','Avery N.','Dakota H.','Skyler F.','Reese C.','Finley D.','Rowan G.','Emerson V.','Hayden Z.','Parker E.','Blair A.'];
  const nameMap = {};
  let nameIndex = 0;

  function scrambleName(real) {
    if (!real || presentMode === false) return real;
    if (!nameMap[real]) {
      nameMap[real] = FAKE_NAMES[nameIndex % FAKE_NAMES.length];
      nameIndex++;
    }
    return nameMap[real];
  }

  function scramblePhone(num) {
    if (!num || !presentMode) return num;
    // Keep first 4 chars, mask the rest
    if (num.length <= 4) return '****';
    return num.slice(0, 4) + num.slice(4).replace(/[0-9]/g, '*');
  }

  function displayName(booking) {
    return presentMode ? scrambleName(booking.guest || 'Guest') : (booking.guest || '');
  }

  // ─── DRAG STATE ─────────────────────────────────────────────────────────────
  let dragRoom = null;
  let dragStartDay = null;
  let dragEndDay = null;
  let isDragging = false;

  // ─── PRICING HELPERS ──────────────────────────────────────────────────────
  function isLowSeason(dateStr) {
    const m = new Date(dateStr + 'T12:00:00').getMonth(); // 0-indexed
    return m >= 3 && m <= 9; // Apr(3) - Oct(9)
  }
  function getRateForDates(room, dates) {
    if (!dates || dates.length < 1) return RATES_HIGH[room] || 0;
    const checkin = dates[0].toLocalDateStr();
    return isLowSeason(checkin) ? (RATES_LOW[room] || 0) : (RATES_HIGH[room] || 0);
  }

  // ─── CURRENCY ────────────────────────────────────────────────────────────────
  const EUR_RATE = 37, USD_RATE = 34;
  let secondaryCurrency = localStorage.getItem('kin-currency') || 'EUR';

  function fmtAmount(thb, opts = {}) {
    if (!thb && thb !== 0) return '';
    const sym = secondaryCurrency === 'EUR' ? '\u20AC' : '$';
    const rate = secondaryCurrency === 'EUR' ? EUR_RATE : USD_RATE;
    const converted = Math.round(thb / rate);
    const prefix = opts.approx ? '~' : '';
    return `${prefix}\u0E3F${thb.toLocaleString()} <span class="amt-secondary">(~${sym}${converted.toLocaleString()})</span>`;
  }

  function fmtAmountText(thb) {
    // Plain text version (no HTML) for inputs/tooltips
    if (!thb && thb !== 0) return '';
    const sym = secondaryCurrency === 'EUR' ? '\u20AC' : '$';
    const rate = secondaryCurrency === 'EUR' ? EUR_RATE : USD_RATE;
    const converted = Math.round(thb / rate);
    return `\u0E3F${thb.toLocaleString()} (~${sym}${converted.toLocaleString()})`;
  }

  function toggleCurrency() {
    secondaryCurrency = secondaryCurrency === 'EUR' ? 'USD' : 'EUR';
    localStorage.setItem('kin-currency', secondaryCurrency);
    document.getElementById('btn-currency').textContent = secondaryCurrency;
    render();
    // Also update sidebar rates
    for (const room of ['nest','master','nomad']) {
      const el = document.getElementById(`sidebar-rate-${room}`);
      if (el) el.innerHTML = fmtAmount(RATES_HIGH[room]).replace('<span class="amt-secondary">', '<br><span class="amt-secondary">');
    }
  }

  // ─── EVENT LISTENERS ──────────────────────────────────────────────────────
  document.getElementById('btn-currency').addEventListener('click', toggleCurrency);
  document.getElementById('btn-currency').textContent = secondaryCurrency;
  document.getElementById('btn-present').addEventListener('click', togglePresentMode);
  document.getElementById('btn-refresh').addEventListener('click', refreshData);
  document.getElementById('btn-add').addEventListener('click', openModal);
  document.getElementById('btn-cancel').addEventListener('click', closeModal);
  document.getElementById('btn-save').addEventListener('click', saveBooking);
  document.getElementById('dm-cancel').addEventListener('click', closeDetailModal);
  document.getElementById('dm-close').addEventListener('click', closeDetailModal);
  document.getElementById('detail-overlay').addEventListener('click', closeDetailModal);
  document.getElementById('dm-save').addEventListener('click', saveBookingDetail);
  document.getElementById('dm-delete').addEventListener('click', deleteBookingFromModal);
  document.getElementById('dm-promote').addEventListener('click', promoteWaitlist);
  document.getElementById('dm-amount').addEventListener('keydown', (e) => { if (e.key === 'Enter') saveBookingDetail(); });
  document.getElementById('month-prev').addEventListener('click', () => changeMonth(-1));
  document.getElementById('month-next').addEventListener('click', () => changeMonth(1));
  document.getElementById('f-room').addEventListener('change', () => {
    const room = document.getElementById('f-room').value;
    document.getElementById('f-rate').value = getRateForDates(room, datePicker.selectedDates);
    updateEstimate();
  });
  document.getElementById('f-type').addEventListener('change', updateEstimate);
  document.getElementById('f-rate').addEventListener('input', updateEstimate);

  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', function() {
      setTab(this.dataset.tab, this);
    });
  });

  // Restore saved tab on load
  if (currentTab !== 'calendar') {
    const savedTabEl = document.querySelector(`.tab[data-tab="${currentTab}"]`);
    if (savedTabEl) setTab(currentTab, savedTabEl);
  }

  document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', function() {
      const type = this.dataset.filter;
      activeFilters[type] = !activeFilters[type];
      this.classList.toggle('active', activeFilters[type]);
      render();
    });
  });

  // ─── DRAG-TO-SELECT ───────────────────────────────────────────────────────
  document.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    const cell = e.target.closest('.cal-cell.empty');
    if (cell && cell.dataset.room === dragRoom && cell.dataset.date) {
      dragEndDay = cell.dataset.date;
      updateDragHighlight();
    }
  });

  document.addEventListener('mouseup', () => {
    if (!isDragging) return;
    isDragging = false;
    if (dragStartDay && dragEndDay && dragRoom) {
      const start = dragStartDay < dragEndDay ? dragStartDay : dragEndDay;
      const end = dragStartDay < dragEndDay ? dragEndDay : dragStartDay;
      // Add one day to end for checkout date
      const endDate = new Date(end + 'T12:00:00');
      endDate.setDate(endDate.getDate() + 1);
      const checkout = endDate.toLocalDateStr();
      openModalWithRange(start, checkout, dragRoom);
    }
    clearDragHighlight();
    dragRoom = null;
    dragStartDay = null;
    dragEndDay = null;
  });

  function updateDragHighlight() {
    clearDragHighlight();
    if (!dragStartDay || !dragEndDay) return;
    const lo = dragStartDay < dragEndDay ? dragStartDay : dragEndDay;
    const hi = dragStartDay < dragEndDay ? dragEndDay : dragStartDay;
    document.querySelectorAll('.cal-cell.empty').forEach(c => {
      if (c.dataset.room === dragRoom && c.dataset.date >= lo && c.dataset.date <= hi) {
        c.classList.add('drag-selected');
      }
    });
  }

  function clearDragHighlight() {
    document.querySelectorAll('.drag-selected').forEach(c => c.classList.remove('drag-selected'));
  }

  // ─── PRESENT MODE TOGGLE ────────────────────────────────────────────────────
  function togglePresentMode() {
    presentMode = !presentMode;
    const btn = document.getElementById('btn-present');
    if (presentMode) {
      btn.classList.add('btn-present-active');
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-1px"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> Present ON';
      document.body.classList.add('present-mode');
    } else {
      btn.classList.remove('btn-present-active');
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-1px"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> Present';
      document.body.classList.remove('present-mode');
    }
    render();
    if (currentTab === 'inquiries') renderInquiries();
    if (currentTab === 'codes') renderDiscountCodes();
  }

  // ─── API ────────────────────────────────────────────────────────────────────
  async function loadBookings(forceRefresh = false) {
    setLoading(true);
    try {
      const url = forceRefresh ? '/api/bookings?refresh=true' : '/api/bookings';
      const res = await fetch(url);
      const data = await res.json();
      allBookings = data.bookings || [];
      updateSyncStatus(data.meta, true);
      showConflictAlerts(allBookings);
      render();
    } catch (err) {
      updateSyncStatus(null, false);
      showError('Could not connect to server.');
    }
    setLoading(false);
  }

  async function refreshData() { await loadBookings(true); }

  async function deleteBooking(id) {
    try {
      const res = await fetch(`/api/bookings/${id}`, { method: 'DELETE' });
      if (res.ok) await loadBookings();
    } catch (err) {
      showError('Failed to delete booking.');
    }
  }

  async function saveBooking() {
    const dates = datePicker.selectedDates;
    if (!dates || dates.length < 2) {
      alert('Please select a date range (check-in to check-out).');
      return;
    }
    const checkin = dates[0].toLocalDateStr();
    const checkout = dates[1].toLocalDateStr();
    if (checkin >= checkout) {
      alert('Check-out must be after check-in.');
      return;
    }
    const body = {
      guest: document.getElementById('f-guest').value || 'Guest',
      type: document.getElementById('f-type').value,
      room: document.getElementById('f-room').value,
      checkin,
      checkout,
      amount: (() => {
        const type = document.getElementById('f-type').value;
        if (type !== 'direct' && type !== 'waitlist') return 0;
        const rate = parseFloat(document.getElementById('f-rate').value) || 0;
        const nights = Math.round((dates[1] - dates[0]) / 86400000);
        return calcTotal(rate, nights);
      })(),
      notes: document.getElementById('f-notes').value,
    };
    try {
      const res = await fetch('/api/bookings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (res.ok) {
        // If promoting from waitlist, delete the original waitlist entry
        if (_promotingWaitlistId) {
          try { await fetch(`/api/bookings/${encodeURIComponent(_promotingWaitlistId)}`, { method: 'DELETE' }); } catch (_) {}
          _promotingWaitlistId = null;
        }
        closeModal();
        await loadBookings();
      } else {
        const err = await res.json();
        alert('Error: ' + err.error);
      }
    } catch (err) {
      showError('Failed to save booking.');
    }
  }

  // ─── STATUS ─────────────────────────────────────────────────────────────────
  function setLoading(on) {
    document.getElementById('loading-bar').className = on ? 'loading-bar active' : 'loading-bar';
  }

  function updateSyncStatus(meta, ok) {
    const dot = document.getElementById('sync-dot');
    const label = document.getElementById('sync-label');
    if (!ok) { dot.className = 'sync-dot error'; label.textContent = 'Server offline'; return; }
    dot.className = 'sync-dot live';
    const conflicts = meta?.conflicts || 0;
    const lastSync = meta?.lastSync?.nest ? new Date(meta.lastSync.nest) : null;
    const age = lastSync ? Math.round((Date.now() - lastSync) / 60000) : null;
    label.textContent = age !== null ? `Synced ${age}m ago` : 'Live';
    if (conflicts > 0) {
      dot.style.background = 'var(--conflict)';
      label.textContent += ` · ${conflicts} conflict${conflicts>1?'s':''}`;
    }
  }

  function showConflictAlerts(bookings) {
    const alerts = document.getElementById('alerts');
    const conflicts = bookings.filter(b => b.conflict);
    if (conflicts.length === 0) { alerts.innerHTML = ''; return; }
    const details = conflicts.map(b => {
      const room = ROOM_LABELS[b.room] || b.room;
      return `<div class="conflict-item" data-id="${b.id}"><strong>${b.guest || 'Guest'}</strong> in ${room} (${b.checkin} to ${b.checkout})</div>`;
    }).join('');
    alerts.innerHTML = `<div class="alert alert-conflict" id="conflict-banner">
      <div class="alert-main">
        <span>&#x26A0; ${conflicts.length} booking conflict${conflicts.length>1?'s':''} detected</span>
        <div class="alert-actions">
          <button class="alert-btn" id="conflict-show">Show</button>
          <button class="alert-btn alert-dismiss" id="conflict-dismiss">&times;</button>
        </div>
      </div>
      <div class="conflict-details" id="conflict-details" style="display:none">${details}</div>
    </div>`;
    document.getElementById('conflict-dismiss').addEventListener('click', () => {
      document.getElementById('conflict-banner').remove();
    });
    document.getElementById('conflict-show').addEventListener('click', () => {
      const det = document.getElementById('conflict-details');
      const btn = document.getElementById('conflict-show');
      if (det.style.display === 'none') {
        det.style.display = '';
        btn.textContent = 'Hide';
      } else {
        det.style.display = 'none';
        btn.textContent = 'Show';
      }
    });
    document.querySelectorAll('.conflict-item').forEach(el => {
      el.style.cursor = 'pointer';
      el.addEventListener('click', () => openBookingDetail(el.dataset.id));
    });
  }

  function showError(msg) {
    document.getElementById('alerts').innerHTML += `<div class="alert alert-error">&#x2715; ${msg}</div>`;
  }

  // ─── RENDER ─────────────────────────────────────────────────────────────────
  function render() {
    if (currentTab === 'calendar') renderCalendar();
    else renderList();
    renderStats();
    renderSidebar();
    // Update sidebar rates with currency conversion
    for (const room of ['nest','master','nomad']) {
      const el = document.getElementById(`sidebar-rate-${room}`);
      if (el) el.innerHTML = `${fmtAmount(RATES_HIGH[room])} / night`;
    }
  }

  function filteredBookings() {
    return allBookings.filter(b => activeFilters[b.type] !== false);
  }

  // ─── CALENDAR ───────────────────────────────────────────────────────────────
  function renderCalendar() {
    const numDays = new Date(currentYear, currentMonth + 1, 0).getDate();
    const today = new Date();
    const todayStr = ds(today.getFullYear(), today.getMonth(), today.getDate());

    document.getElementById('month-title').textContent = `${MONTHS[currentMonth]} ${currentYear}`;
    const isLow = currentMonth >= 3 && currentMonth <= 9;
    document.getElementById('season-tag').textContent = isLow ? 'Low season (-30%)' : 'High season';

    const hdr = document.getElementById('cal-header');
    hdr.innerHTML = '<div class="grid-room-lbl"></div>';
    for (let d = 1; d <= 31; d++) {
      if (d <= numDays) {
        const dStr = ds(currentYear, currentMonth, d);
        const dow = new Date(currentYear, currentMonth, d).getDay();
        const cls = dStr === todayStr ? 'today' : (dow===0||dow===6 ? 'wknd' : '');
        hdr.innerHTML += `<div class="day-hdr ${cls}">${d}</div>`;
      } else {
        hdr.innerHTML += `<div class="day-hdr" style="visibility:hidden">${d}</div>`;
      }
    }

    const rows = document.getElementById('cal-rows');
    rows.innerHTML = '';

    ROOMS.forEach(room => {
      const row = document.createElement('div');
      row.className = 'cal-row';

      const lbl = document.createElement('div');
      lbl.className = 'row-lbl';
      const shortName = {nest:'Nest',master:'Master',nomad:'Nomad',theater:'Theater'}[room];
      lbl.innerHTML = `<div class="row-lbl-dot" style="background:${ROOM_COLORS[room]}"></div>${shortName}`;
      row.appendChild(lbl);

      for (let d = 1; d <= 31; d++) {
        const cell = document.createElement('div');
        cell.className = 'cal-cell';

        if (d <= numDays) {
          const dStr = ds(currentYear, currentMonth, d);
          if (dStr === todayStr) cell.classList.add('today-outline');

          // Determine bookings: staying (checkin <= d < checkout) and departing (checkout === d)
          const allBks = bookingsOnDay(room, dStr);
          const stayBk = allBks.find(b => b.type !== 'blocked') || allBks[0];
          const deptBk = departingOnDay(room, dStr);

          if (stayBk || deptBk) {
            cell.style.cursor = 'pointer';

            // Departing bar (left half — checkout day)
            if (deptBk) {
              const bar = makeBar(deptBk, 'bar-last');
              cell.appendChild(bar);
            }

            // Staying bar (check-in or middle day)
            if (stayBk) {
              const nonBlocked = allBks.filter(b => b.type !== 'blocked');
              const isOverlapDay = nonBlocked.length >= 2;
              const hasBlock = allBks.some(b => b.type === 'blocked');
              const isCheckin = stayBk.checkin === dStr;
              const isSingleNight = nightCount(stayBk) === 1;

              // Determine bar type (conflict or booking type)
              let barBk = { ...stayBk };
              if (isOverlapDay) barBk._barType = 'conflict';

              // Determine bar class
              let barClass = 'bar-mid';

              if (isCheckin) {
                barClass = isSingleNight ? 'bar-only' : 'bar-first';
              } else if (deptBk) {
                // Departing bar occupies left half, so staying mid-bar takes right half only
                barClass = 'bar-mid-right';
              }

              // Extra classes for hatching
              let extra = '';
              if (hasBlock && nonBlocked.length > 0) extra += ' bar-overridden';
              if (isOverlapDay) extra += ' bar-conflict-hatch';

              const bar = makeBar(barBk, barClass, extra);
              cell.appendChild(bar);

              // Guest initial letter on check-in day
              if (isCheckin) {
                const init = document.createElement('div');
                init.className = 'cell-initial';
                init.style.left = 'calc(50% + 3px)';
                const name = presentMode ? scrambleName(stayBk.guest || '?') : (stayBk.guest || '?');
                init.textContent = name.charAt(0).toUpperCase();
                cell.appendChild(init);
              }
            }

            // Fallback: if only departing (no staying), cell click goes to departing booking
            if (!stayBk && deptBk) {
              cell.addEventListener('click', () => { hideTooltip(); openBookingDetail(deptBk.id); });
            }
          } else {
            cell.classList.add('empty');
            cell.dataset.date = dStr;
            cell.dataset.room = room;
            cell.addEventListener('mousedown', (e) => {
              e.preventDefault();
              dragRoom = room;
              dragStartDay = dStr;
              dragEndDay = dStr;
              isDragging = true;
              updateDragHighlight();
            });
          }

          // Waitlist strip: thin bar at bottom, independent of main booking bars
          const wlBks = waitlistOnDay(room, dStr);
          if (wlBks.length > 0) {
            const wb = wlBks[0];
            const wbar = document.createElement('div');
            wbar.className = 'booking-bar-waitlist';
            if (wb.checkin === dStr) wbar.classList.add('wbar-first');
            const nextDay = new Date(dStr); nextDay.setDate(nextDay.getDate() + 1);
            const nextStr = nextDay.toISOString().slice(0,10);
            if (wb.checkout === nextStr) wbar.classList.add('wbar-last');
            wbar.addEventListener('mouseenter', e => showTooltip(e, wb));
            wbar.addEventListener('mousemove', moveTooltip);
            wbar.addEventListener('mouseleave', hideTooltip);
            wbar.addEventListener('click', () => { hideTooltip(); openBookingDetail(wb.id); });
            cell.appendChild(wbar);
          }
        } else {
          cell.classList.add('inactive');
        }
        row.appendChild(cell);
      }
      rows.appendChild(row);
    });
  }

  function bookingOnDay(room, dStr) {
    return filteredBookings().find(b => {
      if (b.room !== room && b.room !== 'full') return false;
      if (b.type === 'waitlist') return false;
      return dStr >= b.checkin && dStr < b.checkout;
    });
  }

  function bookingsOnDay(room, dStr) {
    return filteredBookings().filter(b => {
      if (b.room !== room && b.room !== 'full') return false;
      if (b.type === 'waitlist') return false;
      return dStr >= b.checkin && dStr < b.checkout;
    });
  }

  function waitlistOnDay(room, dStr) {
    return filteredBookings().filter(b => {
      if (b.room !== room && b.room !== 'full') return false;
      if (b.type !== 'waitlist') return false;
      return dStr >= b.checkin && dStr < b.checkout;
    });
  }

  function departingOnDay(room, dStr) {
    return filteredBookings().find(b => {
      if (b.room !== room && b.room !== 'full') return false;
      if (b.type === 'waitlist') return false;
      return b.checkout === dStr;
    });
  }

  function makeBar(bk, barClass, extra) {
    const bar = document.createElement('div');
    const colors = BAR_COLORS[bk._barType || bk.type] || BAR_COLORS.airbnb;
    bar.className = 'booking-bar ' + barClass + (colors.bs ? ' ' + colors.bs : '') + (extra || '');
    bar.style.background = colors.bg;
    bar.style.borderBottom = '2px solid ' + colors.accent;
    if (colors.bs === 'bar-dashed') bar.style.borderBottomStyle = 'dashed';
    if (colors.bs === 'bar-dotted') bar.style.borderBottomStyle = 'dotted';
    bar.addEventListener('mouseenter', e => showTooltip(e, bk));
    bar.addEventListener('mousemove', moveTooltip);
    bar.addEventListener('mouseleave', hideTooltip);
    bar.addEventListener('click', () => { hideTooltip(); openBookingDetail(bk.id); });
    return bar;
  }

  function ds(y, m, d) {
    return `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
  }

  function nextDay(dStr) {
    const d = new Date(dStr + 'T12:00:00');
    d.setDate(d.getDate() + 1);
    return ds(d.getFullYear(), d.getMonth(), d.getDate());
  }

  // ─── LIST ────────────────────────────────────────────────────────────────────
  function renderList() {
    const todayStr = new Date().toLocalDateStr();
    const sorted = [...filteredBookings()].sort((a,b) => a.checkin.localeCompare(b.checkin));
    const upcoming = sorted.filter(b => b.checkout >= todayStr);
    const past = sorted.filter(b => b.checkout < todayStr);

    let html = '';
    if (upcoming.length === 0 && past.length === 0) {
      html = `<div class="empty-state"><div class="empty-state-title">No bookings yet</div><div>Click "+ Add Booking" to get started</div></div>`;
    } else {
      if (upcoming.length > 0) {
        html += '<div class="list-section-title">Upcoming & Active</div>';
        upcoming.forEach(b => { html += bookingCard(b); });
      }
      if (past.length > 0) {
        html += '<div class="list-section-title">Past</div>';
        past.forEach(b => { html += bookingCard(b); });
      }
    }
    document.getElementById('list-content').innerHTML = html;
  }

  function bookingCard(b) {
    const n = nightCount(b);
    const label = {airbnb:'Airbnb',direct:'Direct',friend:'Friend',blocked:'Blocked',hold:'Hold',waitlist:'Waitlist'}[b.type] || b.type;
    const badgeCls = b.conflict ? 'badge-conflict' : `badge-${b.type}`;
    const rowCls = b.conflict ? 'booking-row has-conflict' : 'booking-row';
    const rawAmt = b.amount > 0 ? b.amount : 0;
    const est = rawAmt > 0 ? fmtAmount(rawAmt) :
      (b.type==='friend'||b.type==='blocked'||b.type==='hold'||b.type==='waitlist') ? '' : fmtAmount(n*(RATES[b.room]||3200), {approx:true});
    const canDelete = b.source === 'manual';
    const conflictNote = b.conflict ? `<div class="b-conflict-note">&#x26A0; Conflict detected</div>` : '';
    const checkinFmt = fmtDate(b.checkin);
    const checkoutFmt = fmtDate(b.checkout);

    const guestName = presentMode ? scrambleName(b.guest || label) : (b.guest || label);
    const notesDisplay = presentMode ? '' : (b.notes ? ' \u00B7 ' + b.notes : '');

    return `
      <div class="${rowCls}" onclick="openBookingDetail('${b.id}')" style="cursor:pointer">
        <div class="b-badge ${badgeCls}">${b.conflict ? '&#x26A0; Conflict' : label}</div>
        <div class="b-info">
          <div class="b-name">${guestName}</div>
          <div class="b-dates">${checkinFmt} &#x2192; ${checkoutFmt}</div>
          <div class="b-room">${ROOM_LABELS[b.room]||b.room}${notesDisplay}</div>
          ${conflictNote}
        </div>
        <div class="b-right">
          <div class="b-nights">${n}n</div>
          ${est ? `<div class="b-amount">${est}</div>` : ''}
        </div>
        ${canDelete ? `<button class="b-delete" onclick="event.stopPropagation();deleteBooking('${b.id}')" title="Delete">\u00D7</button>` : ''}
      </div>`;
  }

  function nightCount(b) {
    return Math.round((new Date(b.checkout) - new Date(b.checkin)) / 86400000);
  }

  function fmtDate(str) {
    return new Date(str + 'T12:00:00').toLocaleDateString('en-GB', {day:'numeric',month:'short'});
  }

  // ─── STATS ───────────────────────────────────────────────────────────────────
  function renderStats() {
    const numDays = new Date(currentYear, currentMonth + 1, 0).getDate();
    const totalRoomNights = numDays * 3;
    let bookedNights = 0, friendNights = 0, holdNights = 0, waitlistNights = 0, revenue = 0;

    ROOMS.forEach(room => {
      for (let d = 1; d <= numDays; d++) {
        const dStr = ds(currentYear, currentMonth, d);
        const bk = bookingOnDay(room, dStr);
        if (bk) {
          if (bk.type === 'waitlist') { waitlistNights++; continue; }
          if (bk.type === 'blocked') { friendNights++; continue; }
          bookedNights++;
          if (bk.type === 'friend' || bk.type === 'owner') friendNights++;
          if (bk.type === 'hold') holdNights++;
        }
      }
    });

    // Revenue: for cross-month bookings, use average nightly rate and count only nights in this month
    const monthStart = new Date(currentYear, currentMonth, 1);
    const monthEnd = new Date(currentYear, currentMonth + 1, 0); // last day of month
    allBookings.filter(b => {
      if (b.type === 'friend' || b.type === 'blocked' || b.type === 'owner' || b.type === 'hold' || b.type === 'waitlist') return false;
      const ci = new Date(b.checkin);
      const co = new Date(b.checkout);
      // Booking overlaps this month if checkin < month end+1 and checkout > month start
      return ci <= monthEnd && co > monthStart;
    }).forEach(b => {
      const totalNights = nightCount(b);
      if (totalNights <= 0) return;
      const ci = new Date(b.checkin);
      const co = new Date(b.checkout);
      // Clamp to current month boundaries
      const overlapStart = ci > monthStart ? ci : monthStart;
      const overlapEndDate = co <= new Date(currentYear, currentMonth + 1, 0, 23, 59) ? co : new Date(currentYear, currentMonth + 1, 1);
      const nightsInMonth = Math.round((overlapEndDate - overlapStart) / 86400000);
      if (nightsInMonth <= 0) return;
      const fallbackRate = isLowSeason(b.checkin) ? (RATES_LOW[b.room] || 2240) : (RATES_HIGH[b.room] || 3200);
      const totalAmount = b.amount > 0 ? b.amount : totalNights * fallbackRate;
      const avgPerNight = totalAmount / totalNights;
      revenue += Math.round(avgPerNight * nightsInMonth);
    });

    const occ = Math.round((bookedNights / totalRoomNights) * 100);

    document.getElementById('stats-footer').innerHTML = `
      <div class="sf-block"><div class="sf-label">Occupancy</div><div class="sf-value">${occ}%</div><div class="sf-sub">${bookedNights}/${totalRoomNights} room-nights</div></div>
      <div class="sf-block"><div class="sf-label">Available</div><div class="sf-value">${totalRoomNights - bookedNights}</div><div class="sf-sub">room-nights open</div></div>
      <div class="sf-block"><div class="sf-label">Friend / Blocked</div><div class="sf-value">${friendNights}</div><div class="sf-sub">off-market nights</div></div>
      ${holdNights > 0 ? `<div class="sf-block"><div class="sf-label">Holds</div><div class="sf-value" style="color:var(--hold)">${holdNights}</div><div class="sf-sub">tentative nights</div></div>` : ''}
      ${waitlistNights > 0 ? `<div class="sf-block"><div class="sf-label">Waitlist</div><div class="sf-value" style="color:var(--waitlist)">${waitlistNights}</div><div class="sf-sub">backup nights</div></div>` : ''}
      <div class="sf-block"><div class="sf-label">Est. Revenue</div><div class="sf-value">${fmtAmount(revenue)}</div><div class="sf-sub">${MONTHS[currentMonth]}</div></div>
      <div class="occ-track">
        <div class="sf-label">Occupancy bar</div>
        <div class="occ-bar"><div class="occ-fill" style="width:${occ}%"></div></div>
        <div class="occ-pct"><span>0%</span><span style="color:var(--accent)">${occ}%</span><span>100%</span></div>
      </div>`;
  }

  function renderSidebar() {
    const bks = allBookings.filter(b => {
      const y = parseInt(b.checkin.split('-')[0]);
      const m = parseInt(b.checkin.split('-')[1]) - 1;
      return y === currentYear && m === currentMonth;
    });
    document.getElementById('sidebar-stats').innerHTML = `
      <div class="stat-line"><span class="stat-line-label">Airbnb</span><span class="stat-line-val">${bks.filter(b=>b.type==='airbnb').length}</span></div>
      <div class="stat-line"><span class="stat-line-label">Direct</span><span class="stat-line-val">${bks.filter(b=>b.type==='direct').length}</span></div>
      <div class="stat-line"><span class="stat-line-label">Friends</span><span class="stat-line-val">${bks.filter(b=>b.type==='friend').length}</span></div>
      <div class="stat-line"><span class="stat-line-label">Holds</span><span class="stat-line-val" style="color:var(--hold)">${bks.filter(b=>b.type==='hold').length}</span></div>
      <div class="stat-line"><span class="stat-line-label">Waitlist</span><span class="stat-line-val" style="color:var(--waitlist)">${bks.filter(b=>b.type==='waitlist').length}</span></div>
      <div class="stat-line"><span class="stat-line-label">Conflicts</span><span class="stat-line-val" style="color:${allBookings.filter(b=>b.conflict).length>0?'var(--conflict)':'inherit'}">${allBookings.filter(b=>b.conflict).length}</span></div>`;
  }

  // ─── BOOKING DETAIL MODAL ───────────────────────────────────────────────────
  let detailBookingId = null;
  let detailBookingSource = null;
  let detailDatePicker = null;

  function openBookingDetail(id) {
    const b = allBookings.find(x => x.id === id);
    if (!b) return;
    detailBookingId = id;
    detailBookingSource = b.source || (b.id.startsWith('airbnb-') ? 'ical' : 'manual');
    const isManual = detailBookingSource === 'manual';
    const typeLabel = {airbnb:'Airbnb',direct:'Direct Booking',friend:'Friend / Personal',blocked:'Blocked',owner:'Owner / Host Block',hold:'Hold (Tentative)',waitlist:'Waitlist (Backup)'}[b.type]||b.type;
    const n = nightCount(b);
    const dmName = presentMode ? scrambleName(b.guest || typeLabel) : (b.guest || typeLabel);

    document.getElementById('dm-title').textContent = dmName;

    // Type: show editable select for manual, read-only badge for iCal
    document.getElementById('dm-type-readonly').style.display = isManual ? 'none' : '';
    document.getElementById('dm-type-edit').style.display = isManual && !presentMode ? '' : 'none';
    if (isManual) {
      document.getElementById('dm-type-select').value = b.type;
    } else {
      document.getElementById('dm-type').innerHTML = `<span class="b-badge badge-${b.type}">${typeLabel}</span>`;
    }

    // Room: show editable select for manual, read-only text for iCal
    document.getElementById('dm-room-readonly').style.display = isManual ? 'none' : '';
    document.getElementById('dm-room-edit').style.display = isManual && !presentMode ? '' : 'none';
    if (isManual) {
      document.getElementById('dm-room-select').value = b.room;
    } else {
      document.getElementById('dm-room').textContent = ROOM_LABELS[b.room] || b.room;
    }

    // Dates: show flatpickr for manual, read-only text for iCal
    document.getElementById('dm-dates-readonly').style.display = isManual ? 'none' : '';
    document.getElementById('dm-dates-edit').style.display = isManual && !presentMode ? '' : 'none';
    if (isManual && !presentMode) {
      if (detailDatePicker) detailDatePicker.destroy();
      detailDatePicker = flatpickr('#dm-dates-input', {
        mode: 'range',
        dateFormat: 'Y-m-d',
        altInput: true,
        altFormat: 'j M Y',
        locale: { rangeSeparator: '  \u2192  ' },
        parseDate: (str) => parseDateLocal(str),
        defaultDate: [b.checkin, b.checkout],
        onChange: function(dates) {
          if (dates.length === 2) {
            const nn = Math.round((dates[1] - dates[0]) / 86400000);
            document.getElementById('dm-nights').textContent = `${nn} night${nn !== 1 ? 's' : ''}`;
          }
        }
      });
    } else {
      document.getElementById('dm-dates').textContent = `${fmtDate(b.checkin)} \u2192 ${fmtDate(b.checkout)}`;
    }

    // Nights
    document.getElementById('dm-nights').textContent = `${n} night${n !== 1 ? 's' : ''}`;

    // Notes: editable for all bookings (manual + iCal) unless present mode
    const notesRow = document.getElementById('dm-notes-row');
    const notesEdit = document.getElementById('dm-notes-edit');
    if (!presentMode) {
      notesRow.style.display = 'none';
      notesEdit.style.display = '';
      document.getElementById('dm-notes-input').value = b.notes || '';
    } else {
      notesEdit.style.display = 'none';
      if (b.notes) { notesRow.style.display = ''; document.getElementById('dm-notes').textContent = b.notes; }
      else { notesRow.style.display = 'none'; }
    }

    // Guest + amount (always editable unless present mode)
    document.getElementById('dm-guest').value = presentMode ? dmName : (b.guest || '');
    document.getElementById('dm-amount').value = b.amount > 0 ? b.amount : '';
    document.getElementById('dm-rate').value = (b.amount > 0 && n > 0) ? Math.round(b.amount / n) : '';
    document.getElementById('dm-guest').readOnly = presentMode;
    document.getElementById('dm-amount').readOnly = presentMode;
    document.getElementById('dm-rate').readOnly = presentMode;

    // Show EUR conversion info
    updateDetailAmountInfo(n);

    // Delete button: only for manual bookings
    document.getElementById('dm-delete').style.display = isManual && !presentMode ? '' : 'none';

    // Promote button: only for waitlist bookings
    document.getElementById('dm-promote').style.display = b.type === 'waitlist' && isManual && !presentMode ? '' : 'none';

    // Save button
    document.getElementById('dm-save').style.display = presentMode ? 'none' : '';

    document.getElementById('detail-panel').classList.add('open');
    document.getElementById('detail-overlay').classList.add('open');
    if (!presentMode) document.getElementById('dm-guest').focus();
  }

  function updateDetailAmountInfo(nights) {
    const el = document.getElementById('dm-amount-info');
    const thb = parseFloat(document.getElementById('dm-amount').value) || 0;
    if (!thb) { el.textContent = ''; return; }
    const sym = secondaryCurrency === 'EUR' ? '\u20AC' : '$';
    const fxRate = secondaryCurrency === 'EUR' ? EUR_RATE : USD_RATE;
    const converted = Math.round(thb / fxRate);
    let info = `~${sym}${converted.toLocaleString()} total`;
    if (nights) {
      const perNightThb = Math.round(thb / nights);
      const perNightConverted = Math.round(perNightThb / fxRate);
      info += ` \u00B7 ~${sym}${perNightConverted.toLocaleString()} / night`;
    }
    el.textContent = info;
  }

  // Bidirectional: total -> rate
  document.getElementById('dm-amount').addEventListener('input', () => {
    const nightsText = document.getElementById('dm-nights').textContent;
    const n = parseInt(nightsText) || 0;
    const total = parseFloat(document.getElementById('dm-amount').value) || 0;
    document.getElementById('dm-rate').value = (total && n) ? Math.round(total / n) : '';
    updateDetailAmountInfo(n);
  });

  // Bidirectional: rate -> total
  document.getElementById('dm-rate').addEventListener('input', () => {
    const nightsText = document.getElementById('dm-nights').textContent;
    const n = parseInt(nightsText) || 0;
    const rate = parseFloat(document.getElementById('dm-rate').value) || 0;
    document.getElementById('dm-amount').value = (rate && n) ? Math.round(rate * n) : '';
    updateDetailAmountInfo(n);
  });

  function closeDetailModal() {
    document.getElementById('detail-panel').classList.remove('open');
    document.getElementById('detail-overlay').classList.remove('open');
    if (detailDatePicker) { detailDatePicker.destroy(); detailDatePicker = null; }
    detailBookingId = null;
    detailBookingSource = null;
  }

  async function saveBookingDetail() {
    if (!detailBookingId) return;
    const guest = document.getElementById('dm-guest').value.trim();
    const amount = parseFloat(document.getElementById('dm-amount').value) || 0;
    const isManual = detailBookingSource === 'manual';

    const notes = document.getElementById('dm-notes-input').value.trim();
    const payload = { amount, guest, notes };

    if (isManual) {
      // Include all editable fields for manual bookings
      payload.type = document.getElementById('dm-type-select').value;
      payload.room = document.getElementById('dm-room-select').value;

      if (detailDatePicker && detailDatePicker.selectedDates.length === 2) {
        payload.checkin = detailDatePicker.selectedDates[0].toLocalDateStr();
        payload.checkout = detailDatePicker.selectedDates[1].toLocalDateStr();
      }
    }

    try {
      const res = await fetch(`/api/bookings/${encodeURIComponent(detailBookingId)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('Save failed');
    } catch (err) {
      console.error('[save] error:', err);
      showError('Failed to save.');
    }
    closeDetailModal();
    loadBookings();
  }

  async function deleteBookingFromModal() {
    if (!detailBookingId) return;
    if (!confirm('Delete this booking?')) return;
    await deleteBooking(detailBookingId);
    closeDetailModal();
  }

  // ─── TOOLTIP ─────────────────────────────────────────────────────────────────
  function showTooltip(e, b) {
    const tt = document.getElementById('tooltip');
    const typeLabel = {airbnb:'Airbnb',direct:'Direct Booking',friend:'Friend / Personal',blocked:'Blocked',hold:'Hold (Tentative)',waitlist:'Waitlist (Backup)'}[b.type]||b.type;
    const typeColor = {airbnb:'var(--airbnb)',direct:'var(--direct)',friend:'var(--friend)',blocked:'var(--blocked)',hold:'var(--hold)',waitlist:'var(--waitlist)'}[b.type]||'#8a8070';
    const n = nightCount(b);
    const ttName = presentMode ? scrambleName(b.guest || typeLabel) : (b.guest || typeLabel);
    const ttNotes = presentMode ? '' : (b.notes ? `<div class="tt-detail" style="margin-top:3px">${b.notes}</div>` : '');
    tt.innerHTML = `
      <div class="tt-name">${ttName}</div>
      <div class="tt-detail">${fmtDate(b.checkin)} &#x2192; ${fmtDate(b.checkout)} (${n}n)</div>
      <div class="tt-detail">${ROOM_LABELS[b.room]||b.room}</div>
      ${ttNotes}
      <div class="tt-badge" style="background:${typeColor}22;color:${typeColor}">${typeLabel}</div>
      ${b.conflict ? `<div class="tt-conflict">&#x26A0; Booking conflict</div>` : ''}`;
    tt.style.display = 'block';
    moveTooltip(e);
  }
  function moveTooltip(e) {
    const tt = document.getElementById('tooltip');
    tt.style.left = (e.clientX + 14) + 'px';
    tt.style.top = (e.clientY + 14) + 'px';
  }
  function hideTooltip() { document.getElementById('tooltip').style.display = 'none'; }

  // ─── DATE RANGE PICKER ──────────────────────────────────────────────────────
  const datePicker = flatpickr('#f-dates', {
    mode: 'range',
    dateFormat: 'Y-m-d',
    altInput: true,
    altFormat: 'j M Y',
    locale: { rangeSeparator: '  \u2192  ' },
    parseDate: (str) => parseDateLocal(str),
    onChange: (dates) => {
      if (dates.length === 2) {
        const nn = Math.round((dates[1] - dates[0]) / 86400000);
        document.getElementById('f-nights-label').textContent = `${nn} night${nn !== 1 ? 's' : ''}`;
        document.getElementById('f-nights-row').style.display = '';
      } else {
        document.getElementById('f-nights-row').style.display = 'none';
      }
      updateEstimate();
    },
  });

  function getDiscount(nights) {
    if (nights >= 28) return { pct: 0.40, label: '40% monthly discount' };
    if (nights >= 7)  return { pct: 0.15, label: '15% weekly discount' };
    return { pct: 0, label: null };
  }

  function calcTotal(rate, nights) {
    const base = rate * nights;
    const { pct } = getDiscount(nights);
    return Math.round(base * (1 - pct));
  }

  function updateEstimate() {
    const type = document.getElementById('f-type').value;
    const rateRow = document.getElementById('f-rate-row');
    const totalRow = document.getElementById('f-total-row');
    const totalLabel = document.getElementById('f-total');
    const showPrice = type === 'direct' || type === 'waitlist';
    rateRow.style.display = showPrice ? '' : 'none';
    totalRow.style.display = showPrice ? '' : 'none';

    // Always update night count display regardless of type
    const dates = datePicker.selectedDates;
    if (dates && dates.length === 2) {
      const nn = Math.round((dates[1] - dates[0]) / 86400000);
      document.getElementById('f-nights-label').textContent = `${nn} night${nn !== 1 ? 's' : ''}`;
      document.getElementById('f-nights-row').style.display = '';
    } else {
      document.getElementById('f-nights-row').style.display = 'none';
    }

    if (!showPrice) return;

    // Auto-update rate based on season when dates are selected
    if (dates && dates.length >= 1) {
      const room = document.getElementById('f-room').value;
      const seasonRate = getRateForDates(room, dates);
      const currentRate = parseFloat(document.getElementById('f-rate').value) || 0;
      // Only auto-update if rate matches a known rate (user hasn't manually overridden)
      const allKnown = [...Object.values(RATES_HIGH), ...Object.values(RATES_LOW)];
      if (allKnown.includes(currentRate) || currentRate === 0) {
        document.getElementById('f-rate').value = seasonRate;
      }
    }

    if (!dates || dates.length < 2) {
      totalLabel.textContent = 'Select dates to see total';
      return;
    }
    const nights = Math.round((dates[1] - dates[0]) / 86400000);
    const rate = parseFloat(document.getElementById('f-rate').value) || 0;
    const checkinStr = dates[0].toLocalDateStr();
    const low = isLowSeason(checkinStr);
    const base = rate * nights;
    const { pct, label: discountLabel } = getDiscount(nights);
    const total = Math.round(base * (1 - pct));
    const sym = secondaryCurrency === 'EUR' ? '\u20AC' : '$';
    const cRate = secondaryCurrency === 'EUR' ? EUR_RATE : USD_RATE;
    const converted = Math.round(total / cRate);
    let text = '\u0E3F' + total.toLocaleString() + ' (~' + sym + converted.toLocaleString() + ') \u00B7 ' + nights + ' night' + (nights !== 1 ? 's' : '') + ' x \u0E3F' + rate.toLocaleString();
    if (low) text += ', low season';
    if (discountLabel) {
      text += ' \u2014 ' + discountLabel;
    }
    text += '';
    totalLabel.textContent = text;
  }

