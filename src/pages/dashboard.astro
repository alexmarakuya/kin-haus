---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/dashboard.css';
---

<BaseLayout title="Kin Haus — Occupancy Hub">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover, interactive-widget=resizes-content">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Kin Haus">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#2c6e49">
  <link rel="manifest" href="/manifest.json">
  <style>
    .flatpickr-day.selected, .flatpickr-day.startRange, .flatpickr-day.endRange,
    .flatpickr-day.selected.inRange, .flatpickr-day.startRange.inRange, .flatpickr-day.endRange.inRange,
    .flatpickr-day.selected:focus, .flatpickr-day.startRange:focus, .flatpickr-day.endRange:focus,
    .flatpickr-day.selected:hover, .flatpickr-day.startRange:hover, .flatpickr-day.endRange:hover,
    .flatpickr-day.selected.prevMonthDay, .flatpickr-day.startRange.prevMonthDay, .flatpickr-day.endRange.prevMonthDay,
    .flatpickr-day.selected.nextMonthDay, .flatpickr-day.startRange.nextMonthDay, .flatpickr-day.endRange.nextMonthDay {
      background: var(--accent); border-color: var(--accent);
    }
    .flatpickr-day.inRange { background: #d4ede3; border-color: #d4ede3; box-shadow: -5px 0 0 #d4ede3, 5px 0 0 #d4ede3; }
    .flatpickr-day.inRange:hover { background: #b0dcc8; border-color: #b0dcc8; }
  </style>
  <div class="loading-bar" id="loading-bar"></div>
  <div class="present-banner"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-1px"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> Present mode active -- guest details are scrambled</div>

  <div class="header">
    <div class="header-left">
      <div class="header-title">Kin Haus</div>
      <div class="header-sub">Occupancy Hub</div>
    </div>
    <div class="header-right">
      <div class="sync-status">
        <div class="sync-dot" id="sync-dot"></div>
        <span id="sync-label">Loading...</span>
      </div>
      <button class="btn btn-sm btn-currency" id="btn-currency" title="Toggle secondary currency">EUR</button>
      <button class="btn btn-sm" id="btn-present" title="Scramble guest details for screen sharing"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-1px"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> Present</button>
      <button class="btn btn-sm" id="btn-refresh">&#x21bb; Refresh</button>
      <button class="btn btn-primary btn-sm" id="btn-add">+ Add Booking</button>
    </div>
  </div>

  <div class="alerts" id="alerts"></div>

  <div class="layout">
    <div class="sidebar">
      <div>
        <div class="sidebar-title">Rooms</div>
        <div class="room-item" data-room="nest"><div class="room-dot" style="background:var(--nest)"></div><div><div class="room-name">The Nest</div><div class="room-rate" id="sidebar-rate-nest">&#x0E3F;5,000 / night</div></div></div>
        <div class="room-item" data-room="master"><div class="room-dot" style="background:var(--master)"></div><div><div class="room-name">Master Suite</div><div class="room-rate" id="sidebar-rate-master">&#x0E3F;3,200 / night</div></div></div>
        <div class="room-item" data-room="nomad"><div class="room-dot" style="background:var(--nomad)"></div><div><div class="room-name">Nomad Room</div><div class="room-rate" id="sidebar-rate-nomad">&#x0E3F;2,400 / night</div></div></div>
        <div class="room-item"><div class="room-dot" style="background:var(--theater)"></div><div><div class="room-name">Theater Room</div></div></div>
      </div>
      <div>
        <div class="sidebar-title">Legend</div>
        <div class="legend-row"><div class="legend-chip" style="background:var(--airbnb)"></div>Airbnb</div>
        <div class="legend-row"><div class="legend-chip" style="background:var(--direct)"></div>Direct</div>
        <div class="legend-row"><div class="legend-chip" style="background:var(--friend)"></div>Friend / Personal</div>
        <div class="legend-row"><div class="legend-chip" style="background:var(--blocked)"></div>Blocked</div>
        <div class="legend-row"><div class="legend-chip" style="background:var(--owner)"></div>Owner / Host</div>
        <div class="legend-row"><div class="legend-chip" style="background:var(--hold);border:1px dashed var(--hold)"></div>Hold</div>
        <div class="legend-row"><div class="legend-chip" style="background:var(--waitlist);border:1px dotted var(--waitlist)"></div>Waitlist</div>
        <div class="legend-row"><div class="legend-chip" style="background:var(--conflict)"></div>&#x26A0; Conflict</div>
      </div>
      <div>
        <div class="sidebar-title">This Month</div>
        <div id="sidebar-stats"></div>
      </div>
    </div>

    <div class="main">
      <div class="tab-bar">
        <div class="tab active" data-tab="calendar">Calendar</div>
        <div class="tab" data-tab="list">Bookings</div>
        <div class="tab" data-tab="inquiries">Inquiries <span class="inquiry-badge" id="inquiry-badge"></span></div>
        <div class="tab" data-tab="guests">Guests</div>
        <div class="tab" data-tab="monitors">Monitors</div>
        <div class="tab-spacer"></div>
      </div>

      <!-- FILTER BAR -->
      <div class="filter-bar" id="filter-bar">
        <span class="filter-label">Show:</span>
        <button class="filter-chip active" data-filter="airbnb"><span class="filter-dot" style="background:var(--airbnb)"></span>Airbnb</button>
        <button class="filter-chip active" data-filter="direct"><span class="filter-dot" style="background:var(--direct)"></span>Direct</button>
        <button class="filter-chip active" data-filter="friend"><span class="filter-dot" style="background:var(--friend)"></span>Friends</button>
        <button class="filter-chip" data-filter="blocked"><span class="filter-dot" style="background:var(--blocked)"></span>Blocked</button>
        <button class="filter-chip" data-filter="owner"><span class="filter-dot" style="background:var(--owner)"></span>Owner</button>
        <button class="filter-chip" data-filter="hold"><span class="filter-dot" style="background:var(--hold)"></span>Hold</button>
        <button class="filter-chip" data-filter="waitlist"><span class="filter-dot" style="background:var(--waitlist)"></span>Waitlist</button>
      </div>

      <!-- CALENDAR TAB -->
      <div id="tab-calendar" class="cal-pane">
        <div class="cal-nav">
          <button class="month-btn" id="month-prev">&#x2039;</button>
          <div class="month-title" id="month-title"></div>
          <button class="month-btn" id="month-next">&#x203A;</button>
          <div class="season-tag" id="season-tag"></div>
        </div>
        <div class="cal-scroll">
          <div class="cal-grid-header" id="cal-header"></div>
          <div class="cal-rows" id="cal-rows"></div>
        </div>
      </div>

      <!-- LIST TAB -->
      <div id="tab-list" class="list-pane" style="display:none">
        <div id="list-content"></div>
      </div>

      <!-- INQUIRIES TAB -->
      <div id="tab-inquiries" class="list-pane" style="display:none">
        <div id="inquiries-content"></div>
      </div>

      <!-- PROMO CODES TAB -->
      <div id="tab-codes" class="list-pane" style="display:none">
        <div style="padding:20px 28px 12px; display:flex; justify-content:space-between; align-items:center;">
          <div class="list-section-title" style="margin:0; border:none; padding:0;">Active Codes</div>
          <button class="btn btn-primary" id="btn-create-code" style="font-size:12px; padding:7px 16px;">+ Create Code</button>
        </div>
        <div id="codes-content" style="padding:0 28px 28px;"></div>
      </div>

      <!-- GUESTS TAB -->
      <div id="tab-guests" class="list-pane" style="display:none">
        <div class="guest-toolbar">
          <div class="guest-toolbar-left">
            <div class="list-section-title" style="margin:0; border:none; padding:0;">Guests <span class="guest-count" id="guest-count"></span></div>
            <div class="guest-filter-chips" id="guest-filter-chips">
              <button class="filter-chip active" data-gf="all">All</button>
              <button class="filter-chip" data-gf="in-house">In-house</button>
              <button class="filter-chip" data-gf="upcoming">Upcoming</button>
              <button class="filter-chip" data-gf="returning">Returning</button>
              <button class="filter-chip" data-gf="vip">VIP</button>
            </div>
          </div>
          <div class="guest-toolbar-right">
            <input type="text" id="guest-search" placeholder="Search..." style="font-size:12px; padding:6px 12px; border:1px solid #dddbd7; border-radius:8px; width:160px; font-family:inherit;">
            <button class="btn btn-primary" id="btn-add-guest" style="font-size:12px; padding:7px 16px;">+ Add Guest</button>
          </div>
        </div>
        <div id="guests-content" style="padding:0 28px 28px;"></div>
      </div>

      <!-- MONITORS TAB -->
      <div id="tab-monitors" class="list-pane" style="display:none">
        <!-- Revenue Summary -->
        <div class="monitor-summary" id="monitor-summary">
          <div class="monitor-stat"><span class="monitor-stat-value" id="ms-revenue">&#x0E3F;0</span><span class="monitor-stat-label">Revenue this month</span></div>
          <div class="monitor-stat"><span class="monitor-stat-value" id="ms-active">0</span><span class="monitor-stat-label">Active rentals</span></div>
          <div class="monitor-stat"><span class="monitor-stat-value" id="ms-available">0</span><span class="monitor-stat-label">Available</span></div>
          <div class="monitor-stat"><span class="monitor-stat-value" id="ms-utilisation">0%</span><span class="monitor-stat-label">Utilisation</span></div>
        </div>

        <!-- Kanban Pipeline -->
        <div class="kanban" id="monitor-pipeline">
          <!-- Available -->
          <div class="kanban-col" id="pipeline-available">
            <div class="kanban-col-header">
              <span class="kanban-col-title">Available</span>
              <button class="btn btn-primary btn-sm" id="btn-new-rental" style="padding:4px 10px; font-size:11px;">+ New Rental</button>
            </div>
            <div class="kanban-col-cards" id="cards-available"></div>
          </div>

          <!-- Booked -->
          <div class="kanban-col" id="pipeline-booked">
            <div class="kanban-col-header">
              <span class="kanban-col-title">Booked <span class="pipeline-count" id="count-booked">0</span></span>
            </div>
            <div class="kanban-col-cards" id="cards-booked"></div>
          </div>

          <!-- Delivered -->
          <div class="kanban-col" id="pipeline-delivered">
            <div class="kanban-col-header">
              <span class="kanban-col-title">Delivered <span class="pipeline-count" id="count-delivered">0</span></span>
            </div>
            <div class="kanban-col-cards" id="cards-delivered"></div>
          </div>

          <!-- History -->
          <div class="kanban-col kanban-col-history" id="pipeline-history">
            <div class="kanban-col-header">
              <span class="kanban-col-title">History</span>
              <button class="btn btn-sm" id="btn-export-csv" style="padding:4px 10px; font-size:11px;">CSV</button>
            </div>
            <div class="kanban-col-cards" id="history-content"></div>
          </div>
        </div>
      </div>

      <div class="stats-footer" id="stats-footer"></div>
    </div>
  </div>

  <div class="tooltip" id="tooltip"></div>

  <!-- CHAT FAB + PANEL -->
  <button class="chat-fab" id="chat-fab" aria-label="Open chat">
    <svg class="chat-fab-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
  </button>

  <div class="chat-overlay" id="chat-overlay"></div>
  <div class="chat-panel" id="chat-panel">
    <div class="chat-panel-header">
      <div class="chat-header-avatar">KH</div>
      <span class="chat-panel-title">KH</span>
      <button class="chat-panel-close" id="chat-panel-close">&times;</button>
    </div>
    <div class="chat-messages" id="chat-messages">
      <div class="chat-welcome" id="chat-welcome">
        <div class="chat-welcome-icon">KH</div>
        <div class="chat-welcome-title" id="chat-welcome-title">Hey there</div>
        <div class="chat-welcome-sub">Your Kin Haus villa manager. Ask me anything.</div>
        <div class="chat-suggestions" id="chat-suggestions">
          <button class="chat-suggestion" data-q="Add a booking">Add a booking</button>
          <button class="chat-suggestion" data-q="When is The Nest available next?">Availability</button>
          <button class="chat-suggestion" data-q="What's our occupancy this month?">Occupancy</button>
          <button class="chat-suggestion" data-q="How's our revenue looking this month?">Revenue</button>
        </div>
      </div>
    </div>
    <button class="chat-scroll-btn" id="chat-scroll-btn" aria-label="Scroll to latest">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="chat-image-preview" id="chat-image-preview" style="display:none">
      <img id="chat-image-thumb" alt="Preview">
      <button class="chat-image-remove" id="chat-image-remove" aria-label="Remove image">&times;</button>
    </div>
    <div class="chat-input-area" id="chat-input-area">
      <button class="chat-attach" id="chat-attach" aria-label="Attach image">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
      </button>
      <input type="file" id="chat-file-input" accept="image/*" style="display:none">
      <textarea id="chat-input" placeholder="Ask anything..." rows="1" autocomplete="off" autocorrect="on" autocapitalize="sentences" enterkeyhint="send"></textarea>
      <button class="chat-send" id="chat-send" disabled aria-label="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>

  <!-- GUEST DETAIL PANEL -->
  <div class="detail-panel" id="guest-panel">
    <div class="detail-panel-header">
      <div class="detail-panel-title" id="gp-title">Guest Profile</div>
      <button class="detail-panel-close" id="gp-close">&times;</button>
    </div>
    <div class="detail-panel-body">
      <div class="gp-section">
        <div class="gp-section-title">Identity</div>
        <div class="fg"><label>Full Name</label><input id="gp-name" type="text" placeholder="Full name as on passport"></div>
        <div class="gp-row-2">
          <div class="fg"><label>Nationality</label><input id="gp-nationality" type="text" placeholder="e.g. British"></div>
          <div class="fg"><label>Gender</label><select id="gp-gender"><option value="">-</option><option value="M">Male</option><option value="F">Female</option></select></div>
        </div>
        <div class="gp-row-2">
          <div class="fg"><label>Passport #</label><input id="gp-passport" type="text" placeholder="AB1234567"></div>
          <div class="fg"><label>Date of Birth</label><input id="gp-dob" type="date"></div>
        </div>
      </div>

      <div class="gp-section">
        <div class="gp-section-title">Contact</div>
        <div class="fg"><label>Email</label><input id="gp-email" type="email" placeholder="guest@example.com"></div>
        <div class="gp-row-2">
          <div class="fg"><label>Phone</label><input id="gp-phone" type="text" placeholder="+66..."></div>
          <div class="fg"><label>WhatsApp</label><input id="gp-whatsapp" type="text" placeholder="+66..."></div>
        </div>
      </div>

      <div class="gp-section">
        <div class="gp-section-title">Preferences</div>
        <div class="fg"><label>Preferred Room</label><select id="gp-room"><option value="">No preference</option><option value="nest">The Nest</option><option value="master">Master Suite</option><option value="nomad">Nomad Room</option></select></div>
        <div class="fg"><label>Preferences & Requests</label><textarea id="gp-preferences" rows="2" placeholder="Dietary needs, habits, special requests..."></textarea></div>
        <div class="fg"><label>Source</label><select id="gp-source"><option value="">Unknown</option><option value="airbnb">Airbnb</option><option value="direct">Direct / website</option><option value="referral">Referral</option><option value="repeat">Returning guest</option><option value="whatsapp">WhatsApp</option></select></div>
      </div>

      <div class="gp-section">
        <div class="gp-section-title">Tags</div>
        <div class="gp-tags" id="gp-tags"></div>
        <div class="gp-tag-add">
          <input id="gp-tag-input" type="text" placeholder="Add tag..." style="font-size:12px; padding:4px 8px; border:1px solid #dddbd7; border-radius:6px; width:120px;">
          <button class="btn btn-sm" id="gp-tag-add-btn">+</button>
        </div>
      </div>

      <div class="gp-section">
        <div class="gp-section-title">Notes</div>
        <div class="fg"><textarea id="gp-notes" rows="3" placeholder="Internal notes..."></textarea></div>
      </div>

      <div class="gp-section" id="gp-history-section">
        <div class="gp-section-title">Stay History</div>
        <div id="gp-history"></div>
      </div>

      <div class="gp-stats" id="gp-stats"></div>
    </div>
    <div class="detail-panel-footer">
      <button class="btn btn-danger" id="gp-delete">Delete</button>
      <div class="detail-panel-footer-right">
        <button class="btn" id="gp-cancel">Cancel</button>
        <button class="btn btn-primary" id="gp-save">Save</button>
      </div>
    </div>
  </div>

  <!-- ADD BOOKING MODAL -->
  <div class="overlay" id="modal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Add Booking</div>
        <button class="modal-close" onclick="closeModal()">&times;</button>
      </div>
      <div class="modal-body">
        <div class="fg"><label>Guest / Name</label><input id="f-guest" type="text" placeholder="e.g. Nad, John Smith"></div>
        <div class="fg">
          <label>Type</label>
          <select id="f-type">
            <option value="direct">Direct Booking</option>
            <option value="friend">Friend / Personal</option>
            <option value="blocked">Blocked</option>
            <option value="owner">Owner / Host Block</option>
            <option value="hold">Hold (Tentative)</option>
            <option value="waitlist">Waitlist (Backup)</option>
          </select>
        </div>
        <div class="fg">
          <label>Room</label>
          <select id="f-room">
            <option value="nest">The Nest</option>
            <option value="master">Master Suite</option>
            <option value="nomad">Nomad Room</option>
            <option value="theater">Theater Room</option>
            <option value="full">Full House</option>
          </select>
        </div>
        <div class="fg"><label>Check-in → Check-out</label><input id="f-dates" type="text" placeholder="Select dates" readonly></div>
        <div id="f-nights-row" style="padding:2px 0 8px;font-size:13px;color:#8b8b85;display:none"><span id="f-nights-label"></span></div>
        <div class="fg" id="f-rate-row"><label>Rate / night (THB)</label><input id="f-rate" type="number" placeholder="e.g. 2400"></div>
        <div class="fg" id="f-total-row" style="padding:10px 0 0"><span id="f-total" style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#52524e">Select dates to see total</span></div>
        <div class="fg"><label>Notes</label><input id="f-notes" type="text" placeholder="Optional note"></div>
      </div>
      <div class="modal-footer">
        <button class="btn" id="btn-cancel">Cancel</button>
        <button class="btn btn-primary" id="btn-save">Save Booking</button>
      </div>
    </div>
  </div>

  <!-- BOOKING DETAIL PANEL -->
  <div class="detail-overlay" id="detail-overlay"></div>
  <div class="detail-panel" id="detail-panel">
    <div class="detail-panel-header">
      <div class="detail-panel-title" id="dm-title">Booking Details</div>
      <button class="detail-panel-close" id="dm-close">&times;</button>
    </div>
    <div class="detail-panel-body">
      <!-- Type: read-only for iCal, editable for manual -->
      <div class="detail-row" id="dm-type-readonly"><span class="detail-label">Type</span><span class="detail-value" id="dm-type"></span></div>
      <div class="fg" id="dm-type-edit" style="display:none">
        <label>Type</label>
        <select id="dm-type-select">
          <option value="direct">Direct Booking</option>
          <option value="friend">Friend / Personal</option>
          <option value="blocked">Blocked</option>
          <option value="owner">Owner / Host Block</option>
          <option value="hold">Hold (Tentative)</option>
          <option value="waitlist">Waitlist (Backup)</option>
        </select>
      </div>

      <!-- Room: read-only for iCal, editable for manual -->
      <div class="detail-row" id="dm-room-readonly"><span class="detail-label">Room</span><span class="detail-value" id="dm-room"></span></div>
      <div class="fg" id="dm-room-edit" style="display:none">
        <label>Room</label>
        <select id="dm-room-select">
          <option value="nest">The Nest</option>
          <option value="master">Master Suite</option>
          <option value="nomad">Nomad Room</option>
          <option value="theater">Theater Room</option>
          <option value="full">Full House</option>
        </select>
      </div>

      <!-- Dates: read-only for iCal, flatpickr for manual -->
      <div class="detail-row" id="dm-dates-readonly"><span class="detail-label">Check-in → Check-out</span><span class="detail-value" id="dm-dates"></span></div>
      <div class="fg" id="dm-dates-edit" style="display:none">
        <label>Check-in → Check-out</label>
        <input id="dm-dates-input" type="text" placeholder="Select dates" readonly>
      </div>

      <!-- Nights (always read-only, auto-calculated) -->
      <div class="detail-row"><span class="detail-label">Nights</span><span class="detail-value" id="dm-nights"></span></div>

      <!-- Notes: editable for all bookings -->
      <div id="dm-notes-row" class="detail-row"><span class="detail-label">Notes</span><span class="detail-value" id="dm-notes"></span></div>
      <div class="fg" id="dm-notes-edit" style="display:none">
        <label>Notes</label>
        <input id="dm-notes-input" type="text" placeholder="Optional note">
      </div>

      <div class="fg" style="margin-top:16px">
        <label>Guest Name</label>
        <input id="dm-guest" type="text" placeholder="e.g. John Smith">
      </div>
      <div class="detail-amount-row">
        <div class="fg" style="flex:1">
          <label>Total (THB)</label>
          <input id="dm-amount" type="number" placeholder="e.g. 22400" min="0">
        </div>
        <div class="fg" style="flex:1">
          <label>Rate / Night (THB)</label>
          <input id="dm-rate" type="number" placeholder="e.g. 3200" min="0">
        </div>
      </div>
      <div class="detail-amount-info" id="dm-amount-info"></div>
    </div>
    <div class="detail-panel-footer">
      <button class="btn btn-danger" id="dm-delete" style="display:none">Delete Booking</button>
      <button class="btn" id="dm-promote" style="display:none;background:var(--waitlist);color:white;border-color:var(--waitlist)">Promote to Booking</button>
      <div class="detail-panel-footer-right">
        <button class="btn" id="dm-cancel">Cancel</button>
        <button class="btn btn-primary" id="dm-save">Save</button>
      </div>
    </div>
  </div>

  <!-- CREATE PROMO CODE MODAL -->
  <div class="overlay" id="code-modal">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Create Promo Code</div>
        <button class="modal-close" onclick="document.getElementById('code-modal').classList.remove('open')">&times;</button>
      </div>
      <div class="modal-body">
        <div class="fg">
          <label>Code</label>
          <input id="fc-code" type="text" placeholder="e.g. FRIENDS25" style="text-transform:uppercase">
