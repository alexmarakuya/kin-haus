  function applyPricing(data) {
    for (const room of ['nest','master','nomad']) {
      if (data[room]) {
        RATES_HIGH[room] = data[room].high || 0;
        RATES_LOW[room] = data[room].low || 0;
      }
    }
    RATES_HIGH.full = RATES_HIGH.nest + RATES_HIGH.master + RATES_HIGH.nomad;
    RATES_LOW.full = RATES_LOW.nest + RATES_LOW.master + RATES_LOW.nomad;
    for (const room of ['nest','master','nomad']) {
      const el = document.getElementById(`sidebar-rate-${room}`);
      if (el) el.innerHTML = `${fmtAmount(RATES_HIGH[room])} / night`;
    }
