  function renderDiscountCodes() {
    const container = document.getElementById('codes-content');
    if (!allDiscountCodes.length) {
      container.innerHTML = '<div style="padding:24px 0; text-align:center; color:#8b8b85; font-size:13px;">No promo codes yet. Create one to get started.</div>';
      return;
    }
    const active = allDiscountCodes.filter(c => c.active);
    const inactive = allDiscountCodes.filter(c => !c.active);
    let html = '';
    if (active.length) {
      active.forEach(c => { html += codeCard(c); });
    }
    if (inactive.length) {
      html += '<div class="list-section-title" style="margin-top:20px;">Inactive</div>';
      inactive.forEach(c => { html += codeCard(c); });
    }
    container.innerHTML = html;
  }

  function codeCard(c) {
    const date = new Date(c.createdAt);
    const dateStr = date.toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' });
    const statusClass = c.active ? 'inq-status-new' : 'inq-status-archived';
    const statusLabel = c.active ? 'Active' : 'Inactive';
    return '<div class="inq-card" style="margin-bottom:10px;">'
      + '<div class="inq-card-header">'
      + '<span class="inq-status ' + statusClass + '">' + statusLabel + '</span>'
      + '<span class="inq-time">' + dateStr + '</span>'
      + '</div>'
      + '<div class="inq-card-body">'
      + '<div style="font-family:JetBrains Mono,monospace; font-size:18px; font-weight:600; letter-spacing:0.05em; margin-bottom:4px;">' + c.code + '</div>'
      + '<div style="display:flex; align-items:center; gap:8px;">'
      + '<span style="background:var(--accent); color:white; padding:2px 8px; border-radius:4px; font-size:11px; font-weight:600;">' + c.discount + '% OFF</span>'
      + (c.note ? '<span style="font-size:12px; color:#8b8b85;">' + c.note + '</span>' : '')
      + '</div>'
      + '</div>'
      + '<div class="inq-card-actions" style="margin-top:12px;">'
      + '<button class="inq-action-btn" onclick="toggleCodeStatus(\'' + c.id + '\',' + !c.active + ')">' + (c.active ? 'Deactivate' : 'Activate') + '</button>'
      + '<button class="inq-action-btn inq-action-delete" onclick="deleteDiscountCode(\'' + c.id + '\')">Delete</button>'
      + '</div>'
      + '</div>';
  }

  // Make functions available to onclick handlers
  window.toggleCodeStatus = async function(id, active) {
