  // ─── TODAY VIEW ──────────────────────────────────────────────────────────────
  async function renderTodayView() {
    const container = document.getElementById('today-view');
    if (!container) return;

    // Load guests if not loaded yet (for TM30 status)
    if (!allGuests.length) { try { await loadGuests(); } catch(e) {} }

    const now = new Date();
    const today = ds(now.getFullYear(), now.getMonth(), now.getDate());
    const todayDate = new Date(today + 'T12:00:00');
    const dayName = todayDate.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long' });

    const allBk = allBookings || [];
    const skip = b => b.type === 'blocked' || b.type === 'waitlist';

    // Room status
    const rooms = ['nest', 'master', 'nomad'];
    const roomStatus = rooms.map(room => {
      const occupied = allBk.find(b => (b.room === room || b.room === 'full') && today >= b.checkin && today < b.checkout && !skip(b));
      const departing = allBk.find(b => (b.room === room || b.room === 'full') && b.checkout === today && !skip(b));
      const arriving = allBk.find(b => (b.room === room || b.room === 'full') && b.checkin === today && !skip(b));
      return { room, occupied, departing, arriving };
    });

    // Movements today
    const checkingIn = allBk.filter(b => b.checkin === today && !skip(b));
    const checkingOut = allBk.filter(b => b.checkout === today && !skip(b));

    // Currently in-house (including today's arrivals)
    const inHouse = allBk.filter(b => today >= b.checkin && today < b.checkout && !skip(b));

    // Housekeeping tasks
    const todayTasks = (housekeepingData || []).filter(t => t.date === today);
    const pendingHk = todayTasks.filter(t => t.status !== 'done').length;

    // Helper: find linked guest profile for a booking
    function guestForBooking(b) {
      if (b.guestId) return allGuests.find(g => g.id === b.guestId);
      if (b.guest) return allGuests.find(g => g.fullName && g.fullName.toLowerCase() === b.guest.toLowerCase());
      return null;
    }

    // Helper: TM30 readiness
    function tm30Status(guest) {
      if (!guest) return { ready: false, label: 'No profile', cls: 'today-badge-empty' };
      const has = guest.nationality && guest.passportNumber && guest.dateOfBirth;
      if (has) return { ready: true, label: 'TM30 ready', cls: 'today-badge-checkin' };
      const missing = [];
      if (!guest.nationality) missing.push('nationality');
      if (!guest.passportNumber) missing.push('passport');
      if (!guest.dateOfBirth) missing.push('DOB');
      return { ready: false, label: 'Missing: ' + missing.join(', '), cls: 'today-badge-turnover' };
    }

    // Helper: render guest card
    function guestCard(b, badge, badgeClass) {
      const name = presentMode ? scrambleName(b.guest || 'Guest') : (b.guest || 'Guest');
      const room = ROOM_LABELS[b.room] || b.room;
      const initial = (b.guest || '?').charAt(0).toUpperCase();
      const nights = Math.round((new Date(b.checkout) - new Date(b.checkin)) / 86400000);
      const guest = guestForBooking(b);
      const tm30 = tm30Status(guest);
      const daysLeft = Math.round((new Date(b.checkout) - new Date(today)) / 86400000);
      const detail = badge === 'Arriving'
        ? `${room} &middot; ${nights} night${nights!==1?'s':''} &middot; until ${new Date(b.checkout+'T12:00:00').toLocaleDateString('en-GB',{day:'numeric',month:'short'})}`
        : badge === 'Departing'
        ? `${room}`
        : `${room} &middot; ${daysLeft} night${daysLeft!==1?'s':''} left`;

      return `<div class="today-guest-card" onclick="openBookingDetail('${b.id}')">
        <div class="today-guest-avatar">${initial}</div>
        <div class="today-guest-info">
          <div class="today-guest-name">${name}</div>
          <div class="today-guest-detail">${detail}</div>
        </div>
        <div class="today-guest-badges">
          <span class="today-badge ${badgeClass}">${badge}</span>
          <span class="today-badge ${tm30.cls}" title="${tm30.label}">${tm30.ready ? 'TM30 \u2713' : 'TM30 \u2717'}</span>
        </div>
      </div>`;
    }

    const occupiedCount = roomStatus.filter(r => r.occupied || r.arriving).length;

    let html = `
      <div class="today-header">
        <div class="today-date">${dayName}</div>
      </div>

      <!-- ROOM STATUS ROW -->
      <div class="today-rooms-row">
        ${roomStatus.map(r => {
          const label = ROOM_LABELS[r.room] || r.room;
          const color = ROOM_COLORS[r.room] || '#999';
          let status = '', statusClass = '', guest = '';
          if (r.arriving && r.departing) { status = 'Turnover'; statusClass = 'today-badge-turnover'; }
          else if (r.arriving) { status = 'Check-in'; statusClass = 'today-badge-checkin'; }
          else if (r.departing) { status = 'Check-out'; statusClass = 'today-badge-checkout'; }
          else if (r.occupied) { status = 'Occupied'; statusClass = 'today-badge-occupied'; }
          else { status = 'Available'; statusClass = 'today-badge-empty'; }
          const bk = r.occupied || r.arriving;
          if (bk) guest = presentMode ? scrambleName(bk.guest || '') : (bk.guest || '');
          return `<div class="today-room-tile">
            <div class="today-room-tile-bar" style="background:${color}"></div>
            <div class="today-room-tile-name">${label}</div>
            ${guest ? `<div class="today-room-tile-guest">${guest}</div>` : '<div class="today-room-tile-guest" style="opacity:0.3">--</div>'}
            <span class="today-badge ${statusClass}">${status}</span>
          </div>`;
        }).join('')}
      </div>

      <!-- MOVEMENTS: CHECK-IN / CHECK-OUT -->
      ${(checkingIn.length || checkingOut.length) ? `
      <div class="today-section">
        <div class="today-section-title">Movements</div>
        <div class="today-movements">
          ${checkingIn.map(b => guestCard(b, 'Arriving', 'today-badge-checkin')).join('')}
          ${checkingOut.map(b => guestCard(b, 'Departing', 'today-badge-checkout')).join('')}
        </div>
      </div>` : ''}

      <!-- IN-HOUSE -->
      <div class="today-section">
        <div class="today-section-title">In-house (${inHouse.length})</div>
        ${inHouse.length ? inHouse.map(b => guestCard(b, 'Staying', 'today-badge-occupied')).join('')
          : '<div class="today-empty">No guests in-house</div>'}
      </div>

      <!-- HOUSEKEEPING -->
      ${todayTasks.length ? `
      <div class="today-section">
        <div class="today-section-title">Housekeeping${pendingHk ? ` (${pendingHk} pending)` : ''}</div>
        ${todayTasks.map(t => {
          const icon = HK_TYPE_ICONS[t.type] || '\u{1F4CC}';
          const room = ROOM_LABELS[t.room] || t.room;
          const statusLabel = t.status === 'pending' ? 'Pending' : t.status === 'in_progress' ? 'In progress' : 'Done';
          const statusClass = t.status === 'pending' ? 'today-badge-checkout' : t.status === 'in_progress' ? 'today-badge-turnover' : 'today-badge-empty';
          return `<div class="today-task-card">
            <span class="hk-status-dot" style="background:${HK_STATUS_COLORS[t.status]}"></span>
            <div class="today-task-info">
              <div class="today-task-title">${icon} ${t.title}</div>
              <div class="today-task-detail">${room}</div>
            </div>
            <span class="today-badge ${statusClass}">${statusLabel}</span>
          </div>`;
        }).join('')}
      </div>` : ''}
    `;

    container.innerHTML = html;
  }

  // ─── INIT ─────────────────────────────────────────────────────────────────────
  const isMobileChat = window.innerWidth <= 768;

  // ─── CHAT: TOGGLE PANEL (desktop) / ALWAYS OPEN (mobile) ────────────────────
  const chatPanelEl = document.getElementById('chat-panel');
  const chatOverlayEl = document.getElementById('chat-overlay');
  const chatFabEl = document.getElementById('chat-fab');

  function openChat() {
    chatPanelEl.classList.add('open');
    chatOverlayEl.classList.add('open');
    chatFabEl.classList.add('hidden');
    document.getElementById('chat-input').focus();
  }

  function closeChat() {
    chatPanelEl.classList.remove('open');
    chatOverlayEl.classList.remove('open');
    chatFabEl.classList.remove('hidden');
  }

  if (isMobileChat) {
    // Mobile: always open, full-screen, body scroll locked
    chatPanelEl.classList.add('open');
    document.body.style.overflow = 'hidden';
    document.getElementById('chat-input').focus();

    // Handle mobile virtual keyboard — resize chat panel to avoid whitespace
    if (window.visualViewport) {
      let vpRAF = null;
      const onViewportResize = () => {
        if (vpRAF) return;
        vpRAF = requestAnimationFrame(() => {
          vpRAF = null;
          const vvh = window.visualViewport.height;
          const vvOffset = window.visualViewport.offsetTop;
          chatPanelEl.style.height = vvh + 'px';
          chatPanelEl.style.top = vvOffset + 'px';
          if (isNearBottom()) scrollChatToBottom();
        });
      };
      window.visualViewport.addEventListener('resize', onViewportResize);
      window.visualViewport.addEventListener('scroll', onViewportResize);
    }
  } else {
    // Desktop: toggle via FAB + close button + overlay click
    chatFabEl.addEventListener('click', openChat);
    document.getElementById('chat-panel-close').addEventListener('click', closeChat);
    chatOverlayEl.addEventListener('click', closeChat);
  }

  // Scroll-to-bottom button
  const scrollBtn = document.getElementById('chat-scroll-btn');
  const messagesEl = document.getElementById('chat-messages');
  messagesEl.addEventListener('scroll', () => {
    scrollBtn.classList.toggle('visible', !isNearBottom());
  });
  scrollBtn.addEventListener('click', () => {
    scrollChatToBottom(true);
    scrollBtn.classList.remove('visible');
  });

  // ─── DASHBOARD INIT ─────────────────────────────────────────────────────────
  // Mobile = chat-only mode, skip all dashboard initialization
  if (!isMobileChat) {
    const savedTab = localStorage.getItem('kin-active-tab');
    if (savedTab) {
      const tabEl = document.querySelector(`[data-tab="${savedTab}"]`);
      if (tabEl) setTab(savedTab, tabEl);
    }
    fetchPricing();
    loadBookings();
    fetchInquiries();
    setInterval(() => loadBookings(), 30 * 60 * 1000);
  }
  </script>
</BaseLayout>
