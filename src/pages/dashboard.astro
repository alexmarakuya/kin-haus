  document.getElementById('hk-list').addEventListener('click', async (e) => {
    const copyBtn = e.target.closest('.hk-copy-ical');
    if (copyBtn) {
      const url = copyBtn.dataset.url;
      await navigator.clipboard.writeText(url);
      const orig = copyBtn.innerHTML;
      copyBtn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Copied';
      setTimeout(() => copyBtn.innerHTML = orig, 2000);
      return;
    }

    const editBtn = e.target.closest('.hk-edit');
    if (editBtn) {
      const hk = allHousekeepers.find(h => h.id === editBtn.dataset.id);
      if (hk) populateHkForm(hk);
      return;
    }

    const delBtn = e.target.closest('.hk-delete');
    if (delBtn) {
      if (!confirm('Delete this housekeeper?')) return;
      await fetch(`/api/housekeepers/${delBtn.dataset.id}`, { method: 'DELETE' });
