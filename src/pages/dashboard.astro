  function setTab(tab, el) {
    currentTab = tab;
    localStorage.setItem('kin-active-tab', tab);
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('tab-today').style.display = tab === 'today' ? 'block' : 'none';
    document.getElementById('tab-calendar').style.display = tab === 'calendar' ? 'flex' : 'none';
    document.getElementById('tab-list').style.display = tab === 'list' ? 'block' : 'none';
    document.getElementById('tab-inquiries').style.display = tab === 'inquiries' ? 'block' : 'none';
    document.getElementById('tab-guests').style.display = tab === 'guests' ? 'block' : 'none';
    document.getElementById('tab-staff').style.display = tab === 'staff' ? 'block' : 'none';
    document.getElementById('tab-monitors').style.display = tab === 'monitors' ? 'block' : 'none';
    document.getElementById('tab-desks').style.display = tab === 'desks' ? 'block' : 'none';
    document.getElementById('filter-bar').style.display = tab === 'calendar' ? '' : 'none';
