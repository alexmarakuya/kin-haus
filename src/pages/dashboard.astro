  // ─── INQUIRIES ───────────────────────────────────────────────────────────────
  let allInquiries = [];

  async function fetchInquiries() {
    try {
      const res = await fetch('/api/inquiries');
      const data = await res.json();
      allInquiries = data.inquiries || [];
      renderInquiries();
      updateInquiryBadge();
    } catch (err) {
      console.error('[inquiries] fetch error:', err);
    }
  }

  function updateInquiryBadge() {
    const badge = document.getElementById('inquiry-badge');
    const newCount = allInquiries.filter(i => i.status === 'new').length;
    if (newCount > 0) {
      badge.textContent = newCount;
      badge.style.display = 'inline-flex';
    } else {
      badge.style.display = 'none';
    }
  }

  function renderInquiries() {
    const container = document.getElementById('inquiries-content');
    if (allInquiries.length === 0) {
      container.innerHTML = '<div class="empty-state"><div class="empty-state-title">No inquiries yet</div><div>Inquiries from the booking form will appear here</div></div>';
      return;
    }

    const newInq = allInquiries.filter(i => i.status === 'new');
    const respondedInq = allInquiries.filter(i => i.status === 'responded');
    const bookedInq = allInquiries.filter(i => i.status === 'booked');
    const archivedInq = allInquiries.filter(i => i.status === 'archived');

    let html = '';
    if (newInq.length > 0) {
      html += '<div class="list-section-title">New</div>';
      newInq.forEach(i => { html += inquiryCard(i); });
    }
    if (respondedInq.length > 0) {
      html += '<div class="list-section-title">Responded</div>';
      respondedInq.forEach(i => { html += inquiryCard(i); });
    }
    if (bookedInq.length > 0) {
      html += '<div class="list-section-title">Booked</div>';
      bookedInq.forEach(i => { html += inquiryCard(i); });
    }
    if (archivedInq.length > 0) {
      html += '<div class="list-section-title">Archived</div>';
      archivedInq.forEach(i => { html += inquiryCard(i); });
    }
    container.innerHTML = html;
  }

  function waLink(num) {
    var cleaned = num.replace(/[\s\-\(\)]/g, '');
    if (cleaned.startsWith('+')) cleaned = cleaned.slice(1);
    return 'https://wa.me/' + cleaned;
  }

  function inquiryCard(inq) {
    const statusClass = 'inq-status-' + inq.status;
    const statusLabel = {new:'New',responded:'Responded',booked:'Booked',archived:'Archived'}[inq.status] || inq.status;
    const timeAgo = formatTimeAgo(inq.createdAt);
    const amountStr = inq.amount > 0 ? fmtAmount(inq.amount) : '';

    let actions = '';
    if (inq.whatsapp && !presentMode) {
      actions += `<a class="inq-action-btn inq-action-wa" href="${waLink(inq.whatsapp)}" target="_blank" rel="noopener" onclick="event.stopPropagation()"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:-1px;margin-right:3px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.37 0-4.567-.82-6.293-2.188l-.44-.358-3.281 1.1 1.1-3.281-.358-.44A9.95 9.95 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>Reply</a>`;
    }
    if (inq.status === 'new') {
      actions += `<button class="inq-action-btn" onclick="event.stopPropagation();updateInquiryStatus('${inq.id}','responded')">Mark Responded</button>`;
      actions += `<button class="inq-action-btn inq-action-convert" onclick="event.stopPropagation();convertToBooking('${inq.id}')">Convert to Booking</button>`;
    } else if (inq.status === 'responded') {
      actions += `<button class="inq-action-btn inq-action-convert" onclick="event.stopPropagation();convertToBooking('${inq.id}')">Convert to Booking</button>`;
      actions += `<button class="inq-action-btn" onclick="event.stopPropagation();updateInquiryStatus('${inq.id}','archived')">Archive</button>`;
    } else if (inq.status === 'booked') {
      actions += `<button class="inq-action-btn" onclick="event.stopPropagation();updateInquiryStatus('${inq.id}','archived')">Archive</button>`;
    }
    actions += `<button class="inq-action-btn inq-action-delete" onclick="event.stopPropagation();deleteInquiry('${inq.id}')">Delete</button>`;

    return `
      <div class="inq-card">
        <div class="inq-card-header">
          <span class="inq-status ${statusClass}">${statusLabel}</span>
          <span class="inq-time">${timeAgo}</span>
        </div>
        <div class="inq-card-body">
          <div class="inq-guest">${esc(presentMode ? scrambleName(inq.guest) : inq.guest)}${inq.whatsapp ? `<span class="inq-wa-num">${esc(presentMode ? scramblePhone(inq.whatsapp) : inq.whatsapp)}</span>` : ''}</div>
          <div class="inq-detail">${esc(inq.room)} &middot; ${fmtDate(inq.checkin)} \u2192 ${fmtDate(inq.checkout)} &middot; ${inq.nights}n</div>
          ${amountStr ? `<div class="inq-amount">${amountStr}</div>` : ''}
          ${inq.message && !presentMode ? `<div class="inq-message">"${esc(inq.message)}"</div>` : ''}
        </div>
        ${presentMode ? '' : `<div class="inq-card-actions">${actions}</div>`}
      </div>`;
  }

  function formatTimeAgo(iso) {
    const diff = Date.now() - new Date(iso).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'just now';
    if (mins < 60) return mins + 'm ago';
    const hours = Math.floor(mins / 60);
    if (hours < 24) return hours + 'h ago';
    const days = Math.floor(hours / 24);
    if (days < 7) return days + 'd ago';
    return fmtDate(iso.split('T')[0]);
  }

  async function updateInquiryStatus(id, status) {
    try {
      const res = await fetch(`/api/inquiries/${encodeURIComponent(id)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      });
      if (res.ok) fetchInquiries();
    } catch (err) {
      showError('Failed to update inquiry.');
    }
  }

  async function deleteInquiry(id) {
    if (!confirm('Delete this inquiry?')) return;
    try {
      const res = await fetch(`/api/inquiries/${encodeURIComponent(id)}`, { method: 'DELETE' });
      if (res.ok) fetchInquiries();
    } catch (err) {
      showError('Failed to delete inquiry.');
    }
  }

  function convertToBooking(id) {
    const inq = allInquiries.find(i => i.id === id);
    if (!inq) return;
    // Open add booking modal pre-filled with inquiry data
    document.getElementById('modal').classList.add('open');
    document.getElementById('f-guest').value = inq.guest || '';
    document.getElementById('f-type').value = 'direct';
    const slugMap = {nest:'nest',master:'master',nomad:'nomad',theater:'theater'};
    document.getElementById('f-room').value = slugMap[inq.roomSlug] || 'nest';
    if (inq.checkin && inq.checkout) {
      datePicker.setDate([inq.checkin, inq.checkout]);
    }
    document.getElementById('f-rate').value = getRateForDates(inq.roomSlug || 'nest', datePicker.selectedDates);
    updateEstimate();
    // Archive the inquiry
    updateInquiryStatus(id, 'booked');
  }

  // ─── WAITLIST PROMOTE ────────────────────────────────────────────────────────
  let _promotingWaitlistId = null;

  function promoteWaitlist() {
    const b = allBookings.find(x => x.id === detailBookingId);
    if (!b || b.type !== 'waitlist') return;
    // Close detail panel
    closeDetailModal();
    // Open add booking modal pre-filled with waitlist data
    document.getElementById('modal').classList.add('open');
    document.getElementById('f-guest').value = b.guest || '';
    document.getElementById('f-type').value = 'direct';
    document.getElementById('f-room').value = b.room || 'nest';
    if (b.checkin && b.checkout) {
      datePicker.setDate([b.checkin, b.checkout]);
    }
    // Use the waitlist amount to derive nightly rate, or fall back to seasonal rate
    const n = nightCount(b);
    if (b.amount > 0 && n > 0) {
      document.getElementById('f-rate').value = Math.round(b.amount / n);
    } else {
      document.getElementById('f-rate').value = getRateForDates(b.room || 'nest', datePicker.selectedDates);
    }
    updateEstimate();
    // Store waitlist ID for deletion after booking is saved
    _promotingWaitlistId = b.id;
  }

  // ─── PROMO CODES ──────────────────────────────────────────────────────────────
  let allDiscountCodes = [];

  async function fetchDiscountCodes() {
    try {
      const res = await fetch('/api/discount-codes');
      const data = await res.json();
      allDiscountCodes = data.codes || [];
      renderDiscountCodes();
    } catch (err) {
      console.error('Failed to fetch discount codes:', err);
    }
