  document.getElementById('hk-save').addEventListener('click', async () => {
    const name = document.getElementById('hk-name').value.trim();
    if (!name) return;
    const role = document.getElementById('hk-role').value;
    const phone = document.getElementById('hk-phone').value.trim() || undefined;
    const lineId = document.getElementById('hk-line').value.trim() || undefined;
    const messenger = document.getElementById('hk-messenger').value.trim() || undefined;
    const email = document.getElementById('hk-email').value.trim() || undefined;
    const rate = document.getElementById('hk-rate').value.trim() || undefined;
    const assignedRooms = [...document.querySelectorAll('#hk-rooms input:checked')].map(cb => cb.value);
    const availableDays = [...document.querySelectorAll('#hk-days input:checked')].map(cb => parseInt(cb.value));

    if (editingHkId) {
      await fetch(`/api/housekeepers/${editingHkId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, role, phone, lineId, messenger, email, rate, assignedRooms, availableDays })
      });
    } else {
      await fetch('/api/housekeepers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, role, phone, lineId, messenger, email, rate, assignedRooms, availableDays })
      });
