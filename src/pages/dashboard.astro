  function populateHkForm(hk) {
    editingHkId = hk.id;
    document.getElementById('hk-form-title').textContent = 'Edit Staff Member';
    document.getElementById('hk-name').value = hk.name;
    document.getElementById('hk-role').value = hk.role || 'housekeeper';
    document.getElementById('hk-phone').value = hk.phone || '';
    document.getElementById('hk-line').value = hk.lineId || '';
    document.getElementById('hk-messenger').value = hk.messenger || '';
    document.getElementById('hk-email').value = hk.email || '';
    document.getElementById('hk-rate').value = hk.rate || '';
    document.querySelectorAll('#hk-rooms input').forEach(cb => {
      cb.checked = hk.assignedRooms.includes(cb.value);
    });
    document.querySelectorAll('#hk-days input').forEach(cb => {
      cb.checked = hk.availableDays.includes(parseInt(cb.value));
    });
    document.getElementById('hk-save').textContent = 'Update';
    document.getElementById('hk-cancel-edit').style.display = '';
  }

