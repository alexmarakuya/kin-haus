  // ─── PRICING ──────────────────────────────────────────────────────────────────
  async function fetchPricing() {
    try {
      const res = await fetch('/api/pricing');
      const data = await res.json();
      applyPricing(data);
    } catch (err) { console.error('Failed to fetch pricing:', err); }
  }

  function applyPricing(data) {
    for (const room of ['nest','master','nomad']) {
      if (data[room]) {
        RATES_HIGH[room] = data[room].high || 0;
        RATES_LOW[room] = data[room].low || 0;
      }
    }
    RATES_HIGH.full = RATES_HIGH.nest + RATES_HIGH.master + RATES_HIGH.nomad;
    RATES_LOW.full = RATES_LOW.nest + RATES_LOW.master + RATES_LOW.nomad;
    for (const room of ['nest','master','nomad']) {
      const el = document.getElementById(`sidebar-rate-${room}`);
      if (el) el.innerHTML = `${fmtAmount(RATES_HIGH[room])} / night`;
    }
  }

  // ─── ROOM MODAL ─────────────────────────────────────────────────────────────
  const AIRBNB_LINKS = {
    nest: 'https://www.airbnb.com/rooms/1511809226602265595',
    master: 'https://www.airbnb.com/rooms/1618003971883950106',
    nomad: 'https://www.airbnb.com/rooms/1618012678467611754',
  };
