---
import BaseLayout from '../layouts/BaseLayout.astro';
const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Login — Kin Haus">
  <style>
    .login-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
    }
    .login-card {
      width: 340px;
      max-width: 100%;
    }
    .login-brand {
      font-family: 'DM Serif Display', serif;
      font-size: 28px;
      text-align: center;
      margin-bottom: 6px;
    }
    .login-sub {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #8b8b85;
      text-align: center;
      margin-bottom: 32px;
    }
    .login-pw-wrap {
      position: relative;
      margin-bottom: 12px;
    }
    .login-input {
      width: 100%;
      padding: 10px 40px 10px 14px;
      border: 1px solid #d9d7d3;
      border-radius: 6px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      color: var(--ink);
      background: white;
      outline: none;
    }
    .login-input:focus {
      border-color: var(--accent);
    }
    .login-pw-toggle {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
      color: #b0b0a8;
      transition: color 0.15s;
      display: flex;
      align-items: center;
    }
    .login-pw-toggle:hover { color: #64645f; }
    .login-btn {
      width: 100%;
      padding: 10px;
      background: var(--accent);
      color: white;
      border: none;
      border-radius: 6px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s;
    }
    .login-btn:hover {
      background: #225539;
    }
    .login-error {
      background: #fde8e8;
      border: 1px solid #e05a5a;
      color: #8a1010;
      padding: 8px 12px;
      border-radius: 6px;
      font-size: 12px;
      margin-bottom: 12px;
      text-align: center;
    }
    .login-back {
      display: block;
      text-align: center;
      margin-top: 20px;
      font-size: 12px;
      color: #8b8b85;
      text-decoration: none;
    }
    .login-back:hover { color: var(--accent); }
  </style>

  <div class="login-page">
    <div class="login-card">
      <div class="login-brand">Kin Haus</div>
      <div class="login-sub">Occupancy Hub</div>

      {error && <div class="login-error">Incorrect password</div>}

      <form method="POST" action="/api/auth">
        <div class="login-pw-wrap">
          <input
            type="password"
            name="password"
            id="loginPw"
            class="login-input"
            placeholder="Password"
            autofocus
            required
          />
          <button type="button" class="login-pw-toggle" id="loginPwToggle" aria-label="Show password">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <button type="submit" class="login-btn">Sign In</button>
      </form>

      <script is:inline>
        (function() {
          var pw = document.getElementById('loginPw');
          var tog = document.getElementById('loginPwToggle');
          var eyeOpen = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
          var eyeClosed = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
          if (pw && tog) {
            tog.addEventListener('click', function() {
              var show = pw.type === 'password';
              pw.type = show ? 'text' : 'password';
              tog.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
              tog.innerHTML = show ? eyeClosed : eyeOpen;
            });
          }
        })();
      </script>

      <a href="/" class="login-back">&larr; Back to site</a>
    </div>
  </div>
</BaseLayout>
