---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kinhaus.space/" },
    { "@type": "ListItem", "position": 2, "name": "Location", "item": "https://kinhaus.space/location" },
  ],
};
---

<MarketingLayout
  title="Location -- How to Find Kin Haus in Koh Phangan, Thailand"
  description="Kin Haus is located near Thongsala, Koh Phangan. 5 minutes from the ferry pier by scooter, close to shops and restaurants. Directions, getting here, and what's nearby."
  jsonLd={jsonLd}
>
  <style>
    .location-page { padding: 60px 40px; max-width: 800px; margin: 0 auto; }
    .location-page h1 { font-weight: 600; font-size: 36px; margin-bottom: 8px; }
    .location-intro { font-size: 15px; color: #64645f; line-height: 1.6; margin-bottom: 32px; }

    .location-map {
      width: 100%;
      height: 360px;
      border-radius: 12px;
      border: 1px solid #e4e2de;
      margin-bottom: 40px;
      overflow: hidden;
    }
    .location-map iframe {
      width: 100%;
      height: 100%;
      border: 0;
    }

    .location-details {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      margin-bottom: 40px;
    }
    .location-block h3 {
      font-weight: 600;
      font-size: 18px;
      margin-bottom: 10px;
    }
    .location-block p, .location-block li {
      font-size: 14px;
      color: #52524e;
      line-height: 1.6;
    }
    .location-block ul {
      list-style: none;
      padding: 0;
    }
    .location-block li { padding: 4px 0; }
    .location-block li::before {
      content: '\2192';
      margin-right: 8px;
      color: var(--accent);
    }

    .location-cta {
      text-align: center;
      padding: 40px 20px;
      border-top: 1px solid #e4e2de;
    }
    .location-cta h3 { font-weight: 600; font-size: 22px; margin-bottom: 6px; }
    .location-cta p { font-size: 14px; color: #8b8b85; margin-bottom: 16px; }
    .location-cta-btn {
      display: inline-block;
      padding: 12px 28px;
      background: var(--accent);
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.15s;
    }
    .location-cta-btn:hover { background: #245a3b; }

    @media (max-width: 768px) {
      .location-details { grid-template-columns: 1fr; }
    }
  </style>

  <div class="location-page">
    <h1>Location</h1>
    <p class="location-intro">Kin Haus is located between Thongsala and Ban Tai on Koh Phangan. We're a short scooter ride from shops, restaurants, and the ferry pier -- close to everything but tucked away enough to feel peaceful.</p>

    <div class="location-map">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1971.5!2d100.0180681!3d9.7092811!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3054fd0079838ec7%3A0xb5b2caf269e19d68!2sKIN%20Haus!5e0!3m2!1sen!2sth!4v1" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>

    <div class="location-details">
      <div class="location-block">
        <h3>Getting Here</h3>
        <ul>
          <li>Ferry from Koh Samui: ~30 min</li>
          <li>Ferry from Surat Thani: ~2.5 hours</li>
          <li>From Thongsala Pier: 5 min by scooter</li>
          <li>Airport: fly to Koh Samui (USM), then ferry</li>
        </ul>
      </div>
      <div class="location-block">
        <h3>Nearby</h3>
        <ul>
          <li>7-Eleven & ATMs: ~5 min scooter</li>
          <li>Thongsala Pier: ~10-15 min scooter</li>
          <li>Thongsala Walking Street: ~10-15 min scooter</li>
          <li>Pantip Market: ~10-15 min scooter</li>
          <li>Haad Rin: ~15-20 min scooter</li>
          <li>Zen Beach: ~20 min scooter</li>
        </ul>
      </div>
    </div>

    <div class="location-cta">
      <h3>Ready to visit?</h3>
      <p>Browse our rooms and check availability.</p>
      <a href="/rooms" class="location-cta-btn">View Rooms &rarr;</a>
    </div>
  </div>
</MarketingLayout>
